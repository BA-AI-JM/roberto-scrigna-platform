    57	export function MeasurementsView({ snapshots, loading }: { snapshots: MeasurementSnapshot[] | undefined; loading: boolean }) {
    58	  if (loading) {
    59	    return <div style={{ ...cardStyle, color: "#6b7280", fontSize: "14px" }}>Caricamento misurazioni…</div>;
    60	  }
    61	
    62	  const rows = snapshots ?? [];
    63	  if (rows.length === 0) {
    64	    return (
    65	      <div style={{ ...cardStyle, textAlign: "center", padding: "32px 20px" }}>
    66	        <div style={{ fontSize: "32px", marginBottom: "8px" }} aria-hidden>⚖️</div>
    67	        <p style={{ fontSize: "14px", fontWeight: 600, color: "#374151", margin: "0 0 4px" }}>Nessuna misurazione</p>
    68	        <p style={{ fontSize: "13px", color: "#6b7280", margin: 0 }}>Le tue misurazioni compariranno qui dopo il primo check-in.</p>
    69	      </div>
    70	    );
    71	  }
    72	
    73	  const latest = latestMeasurements(rows);
    74	  // Ascending for the charts.
    75	  const asc = [...rows].reverse();
    76	
    77	  return (
    78	    <div>
    79	      {/* Current values */}
    80	      <div style={{ ...cardStyle }}>
    81	        <p style={{ fontSize: "16px", fontWeight: 700, color: "#1a1a2e", margin: "0 0 14px" }}>Composizione corporea</p>
    82	        <div style={{ display: "flex", flexWrap: "wrap", gap: "10px" }}>
    83	          {[
    84	            { label: "Peso", value: latest.weight, unit: " kg" },
    85	            { label: "Massa grassa", value: latest.bodyFat, unit: "%" },
    86	            { label: "Massa magra", value: latest.lean, unit: " kg" },
    87	            { label: "Grasso", value: latest.fat, unit: " kg" },
    88	          ].map((m) => (
    89	            <div key={m.label} style={{ flex: "1 1 90px", minWidth: "80px", textAlign: "center", padding: "12px 8px", background: "#f8fafc", borderRadius: "10px" }}>
    90	              <div style={{ fontSize: "20px", fontWeight: 700, color: "#1a1a2e" }}>{m.value != null ? `${m.value}${m.unit}` : "—"}</div>
    91	              <div style={{ fontSize: "11px", color: "#6b7280", marginTop: "2px" }}>{m.label}</div>
    92	            </div>
    93	          ))}
    94	        </div>
    95	      </div>
    96	
    97	      {/* Per-metric trends */}
    98	      {METRICS.map((metric) => {
    99	        const points = asc
   100	          .filter((s) => typeof s[metric.key] === "number" && s.taken_at)
   101	          .map((s) => ({ date: s.taken_at as string, value: s[metric.key] as number }));
   102	        const series: TrendSeries[] = [{ key: String(metric.key), label: metric.label, color: metric.color, unit: metric.unit, points }];
   103	        if (totalDataPoints(series) < 2) return null;
   104	        return (
   105	          <div key={String(metric.key)} style={cardStyle}>
   106	            <p style={{ fontSize: "13px", fontWeight: 600, color: "#6b7280", marginBottom: "4px" }}>Andamento {metric.label.toLowerCase()}</p>
   107	            <TrendChart series={series} height={180} />
   108	          </div>
   109	        );
   110	      })}
