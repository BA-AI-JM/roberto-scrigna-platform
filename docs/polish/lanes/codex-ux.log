---ENGAGEMENT RENDERER---
     1	/**
     2	 * Engagement-letter HTML renderer (Requirement #29, Stage 1).
     3	 *
     4	 * Pure function: a FILLED letter body (markdown) → a branded A4 HTML document
     5	 * ready for Puppeteer. Mirrors invoice-renderer.ts brand styling (self-contained
     6	 * inline <style>, #1a1a2e, "Roberto Scrigna"). Tested via string assertions.
     7	 *
     8	 * The body is a small, fixed markdown subset (the IT-03 template uses only
     9	 * headings, bold/italic, horizontal rules and paragraphs). Any remaining gap —
    10	 * an unfilled `{{merge_token}}` or a `[PLACEHOLDER: ...]` Roberto still owes — is
    11	 * highlighted so a preview makes the gaps obvious. This renders a DRAFT for
    12	 * preview; the binding copy is produced by the eIDAS e-signature provider later.
    13	 */
    14	
    15	export interface EngagementLetterRenderData {
    16	  bodyMd: string;
    17	  documentName: string;
    18	  versionLabel: string;
    19	  language: string;
    20	  /** When true, shows a "BOZZA / ANTEPRIMA" banner (not a signed document). */
    21	  draft?: boolean;
    22	  /**
    23	   * When present, renders the SIGNED copy: a "FIRMATO" stamp instead of the draft
    24	   * banner, plus an SES acceptance attestation block. Used by the internal SES
    25	   * provider's on-demand regeneration.
    26	   */
    27	  signature?: SignatureStamp;
    28	}
    29	
    30	/** Internal-SES acceptance details stamped onto the signed letter (KB §11 / eIDAS SES). */
    31	export interface SignatureStamp {
    32	  signerName: string;
    33	  /** Codice fiscale, when held (n/d otherwise). */
    34	  signerCodiceFiscale?: string | null;
    35	  /** ISO timestamp the patient accepted. */
    36	  acceptedAt: string;
    37	  versionNumber: number;
    38	  contentHash: string;
    39	  /** e.g. "in_app_ses". */
    40	  method: string;
    41	}
    42	
    43	// ── Markdown subset → HTML ──────────────────────────────────────────────────────
    44	
    45	function esc(s: string): string {
    46	  return s
    47	    .replace(/&/g, "&amp;")
    48	    .replace(/</g, "&lt;")
    49	    .replace(/>/g, "&gt;")
    50	    .replace(/"/g, "&quot;");
    51	}
    52	
    53	/** Escape, then apply inline bold/italic and highlight remaining gaps. */
    54	function renderInline(text: string): string {
    55	  let out = esc(text);
    56	  out = out.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
    57	  out = out.replace(/\*(.+?)\*/g, "<em>$1</em>");
    58	  // Highlight unfilled gaps: [PLACEHOLDER: ...] (Roberto owes) and {{token}} (merge miss).
    59	  out = out.replace(/\[PLACEHOLDER:[^\]]*\]/g, (m) => `<span class="gap">${m}</span>`);
    60	  out = out.replace(/\{\{[a-z_]+\}\}/g, (m) => `<span class="gap">${m}</span>`);
    61	  return out;
    62	}
    63	
    64	/** Convert the fixed markdown subset (headings, hr, bold/italic, paragraphs) to HTML. */
    65	export function letterMarkdownToHtml(md: string): string {
    66	  const lines = md.replace(/\r\n/g, "\n").split("\n");
    67	  const blocks: string[] = [];
    68	  let para: string[] = [];
    69	
    70	  const flushPara = () => {
    71	    if (para.length) {
    72	      blocks.push(`<p>${para.map(renderInline).join("<br/>")}</p>`);
    73	      para = [];
    74	    }
    75	  };
    76	
    77	  for (const raw of lines) {
    78	    const line = raw.trimEnd();
    79	    if (line.trim() === "") {
    80	      flushPara();
    81	      continue;
    82	    }
    83	    if (line.trim() === "---") {
    84	      flushPara();
    85	      blocks.push("<hr/>");
    86	      continue;
    87	    }
    88	    const h = /^(#{1,3})\s+(.*)$/.exec(line);
    89	    if (h) {
    90	      flushPara();
    91	      const level = h[1]!.length;
    92	      blocks.push(`<h${level}>${renderInline(h[2]!)}</h${level}>`);
    93	      continue;
    94	    }
    95	    para.push(line.trim());
    96	  }
    97	  flushPara();
    98	  return blocks.join("\n");
    99	}
