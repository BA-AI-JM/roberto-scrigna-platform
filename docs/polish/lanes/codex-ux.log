   127	const DEFAULT_WIDTH = 640;
   128	const PAD = { top: 14, right: 14, bottom: 24, left: 14 };
   129	
   130	// ── Component ────────────────────────────────────────────────────────────────
   131	
   132	export function TrendChart({ series, height = 220 }: TrendChartProps) {
   133	  const containerRef = useRef<HTMLDivElement>(null);
   134	  const svgRef = useRef<SVGSVGElement>(null);
   135	  const [width, setWidth] = useState(DEFAULT_WIDTH);
   136	  const [hoverDate, setHoverDate] = useState<string | null>(null);
   137	
   138	  // Measure container width for crisp pixel-coordinate rendering (no-op under SSR/jsdom).
   139	  useEffect(() => {
   140	    const el = containerRef.current;
   141	    if (!el || typeof ResizeObserver === "undefined") return;
   142	    const ro = new ResizeObserver((entries) => {
   143	      const w = entries[0]?.contentRect.width;
   144	      if (w && w > 0) setWidth(Math.round(w));
   145	    });
   146	    ro.observe(el);
   147	    return () => ro.disconnect();
   148	  }, []);
   149	
   150	  const dates = useMemo(() => collectDates(series), [series]);
   151	
   152	  // ── 0 points ──
   153	  if (dates.length === 0) {
   154	    return (
   155	      <div style={{ ...cardStyle, fontSize: "13px", color: "#6b7280" }}>
   156	        Nessun dato disponibile per il grafico.
   157	      </div>
   158	    );
   159	  }
   160	
   161	  // ── 1 point ── (a single measurement → no trend line; show the value(s))
   162	  if (dates.length === 1) {
   163	    const only = dates[0]!;
   164	    return (
   165	      <div style={{ ...cardStyle, fontSize: "13px", color: "#374151" }}>
   166	        <div style={{ display: "flex", flexWrap: "wrap", gap: "12px", marginBottom: "6px" }}>
   167	          {tooltipRows(series, only).map((r) =>
   168	            r.value == null ? null : (
   169	              <span key={r.key}>
   170	                <span style={{ color: r.color, fontWeight: 700 }}>●</span>{" "}
   171	                <span style={{ fontWeight: 600 }}>{r.label}:</span> {r.value}
   172	                {r.unit}
   173	              </span>
   174	            )
   175	          )}
   176	        </div>
   177	        <span style={{ color: "#6b7280" }}>
   178	          Prima misurazione — andamento disponibile dal prossimo dato.
   179	        </span>
   180	      </div>
   181	    );
   182	  }
   183	
   184	  // ── many points ──
   185	  const times = dates.map(parseTime);
   186	  const t0 = times[0]!;
   187	  const t1 = times[times.length - 1]!;
   188	  const span = t1 - t0 || 1;
   189	
   190	  const plotW = Math.max(1, width - PAD.left - PAD.right);
   191	  const plotH = Math.max(1, height - PAD.top - PAD.bottom);
   192	
   193	  const xOf = (t: number) => PAD.left + ((t - t0) / span) * plotW;
   194	
   195	  const lines = series
   196	    .map((s) => {
   197	      const extent = seriesExtent(s.points);
   198	      if (!extent) return null;
   199	      const [lo, hi] = extent;
   200	      const range = hi - lo || 1;
   201	      const pts = (s.points ?? [])
   202	        .filter(hasValue)
   203	        .slice()
   204	        .sort((a, b) => parseTime(a.date) - parseTime(b.date))
   205	        .map((p) => ({
   206	          x: xOf(parseTime(p.date)),
   207	          y: PAD.top + (1 - (p.value - lo) / range) * plotH,
   208	        }));
   209	      return { key: s.key, color: s.color, pts };
   210	    })
   211	    .filter((l): l is { key: string; color: string; pts: { x: number; y: number }[] } => l != null);
   212	
   213	  // Date label positions (first, middle, last) to avoid crowding.
   214	  const labelIdx = Array.from(new Set([0, Math.floor((dates.length - 1) / 2), dates.length - 1]));
   215	
   216	  function handlePointer(clientX: number) {
   217	    const svg = svgRef.current;
   218	    if (!svg) return;
   219	    const rect = svg.getBoundingClientRect();
   220	    const ratio = rect.width > 0 ? width / rect.width : 1;
   221	    const localX = (clientX - rect.left) * ratio;
   222	    // nearest date by x
   223	    let best = 0;
   224	    let bestDist = Infinity;
   225	    for (let i = 0; i < times.length; i++) {
   226	      const d = Math.abs(xOf(times[i]!) - localX);
   227	      if (d < bestDist) {
   228	        bestDist = d;
   229	        best = i;
   230	      }
   231	    }
   232	    setHoverDate(dates[best]!);
   233	  }
   234	
   235	  const hoverX = hoverDate != null ? xOf(parseTime(hoverDate)) : null;
   236	  const tooltip = hoverDate != null ? tooltipRows(series, hoverDate) : null;
   237	  // keep the tooltip box inside the plot
   238	  const tipLeftPct =
   239	    hoverX != null ? Math.min(85, Math.max(2, (hoverX / width) * 100)) : 0;
   240	
   241	  return (
   242	    <div ref={containerRef} style={{ ...cardStyle, position: "relative" }}>
   243	      {/* Legend */}
   244	      <div style={{ display: "flex", flexWrap: "wrap", gap: "12px", marginBottom: "10px" }}>
   245	        {series.map((s) => {
   246	          const lv = latestValue(s);
   247	          return (
   248	            <span key={s.key} style={{ fontSize: "12px", color: "#374151", display: "inline-flex", alignItems: "center", gap: "5px" }}>
   249	              <span style={{ width: "10px", height: "10px", borderRadius: "2px", background: s.color, display: "inline-block" }} />
   250	              <span style={{ fontWeight: 600 }}>{s.label}</span>
   251	              {lv != null && (
   252	                <span style={{ color: "#6b7280" }}>
   253	                  {lv}
   254	                  {s.unit}
   255	                </span>
   256	              )}
   257	            </span>
   258	          );
   259	        })}
   260	      </div>
   261	
   262	      <div style={{ overflowX: "auto" }}>
   263	        <svg
   264	          ref={svgRef}
   265	          width={width}
   266	          height={height}
   267	          style={{ display: "block", maxWidth: "100%", touchAction: "pan-y" }}
   268	          role="img"
   269	          aria-label="Grafico andamento metriche"
   270	          onMouseMove={(e) => handlePointer(e.clientX)}
   271	          onMouseLeave={() => setHoverDate(null)}
   272	          onTouchStart={(e) => e.touches[0] && handlePointer(e.touches[0].clientX)}
   273	          onTouchMove={(e) => e.touches[0] && handlePointer(e.touches[0].clientX)}
   274	        >
   275	          {/* baseline */}
   276	          <line x1={PAD.left} y1={height - PAD.bottom} x2={width - PAD.right} y2={height - PAD.bottom} stroke="#e2e8f0" strokeWidth={1} />
   277	
   278	          {/* hover guide */}
   279	          {hoverX != null && (
   280	            <line x1={hoverX} y1={PAD.top} x2={hoverX} y2={height - PAD.bottom} stroke="#cbd5e1" strokeWidth={1} strokeDasharray="3 3" />
   281	          )}
   282	
   283	          {/* series lines + points */}
   284	          {lines.map((l) => (
   285	            <g key={l.key}>
   286	              <polyline
   287	                fill="none"
   288	                stroke={l.color}
   289	                strokeWidth={2}
   290	                strokeLinejoin="round"
   291	                strokeLinecap="round"
   292	                points={l.pts.map((p) => `${p.x},${p.y}`).join(" ")}
   293	              />
   294	              {l.pts.map((p, i) => (
   295	                <circle key={i} cx={p.x} cy={p.y} r={hoverDate != null && xOf(parseTime(hoverDate)) === p.x ? 4 : 2.5} fill={l.color} />
   296	              ))}
   297	            </g>
   298	          ))}
   299	
   300	          {/* x-axis date labels */}
   301	          {labelIdx.map((i) => (
   302	            <text key={i} x={Math.min(width - 2, Math.max(2, xOf(times[i]!)))} y={height - 8} textAnchor={i === 0 ? "start" : i === dates.length - 1 ? "end" : "middle"} fontSize={10} fill="#6b7280">
   303	              {formatShortDate(dates[i]!)}
   304	            </text>
   305	          ))}
   306	        </svg>
   307	      </div>
   308	
   309	      {/* Tooltip */}
   310	      {hoverDate != null && tooltip != null && (
   311	        <div
   312	          style={{
   313	            position: "absolute",
   314	            left: `${tipLeftPct}%`,
   315	            top: "34px",
   316	            background: "#ffffff",
   317	            border: "1px solid #e2e8f0",
   318	            borderRadius: "8px",
   319	            boxShadow: "0 4px 12px rgba(0,0,0,0.08)",
   320	            padding: "8px 10px",
   321	            fontSize: "12px",
   322	            color: "#374151",
   323	            pointerEvents: "none",
   324	            zIndex: 5,
   325	            minWidth: "120px",
   326	          }}
   327	        >
   328	          <div style={{ fontWeight: 700, color: "#1a1a2e", marginBottom: "4px" }}>{formatShortDate(hoverDate)}</div>
   329	          {tooltip.map((r) => (
   330	            <div key={r.key} style={{ display: "flex", justifyContent: "space-between", gap: "10px" }}>
   331	              <span style={{ display: "inline-flex", alignItems: "center", gap: "5px" }}>
   332	                <span style={{ width: "8px", height: "8px", borderRadius: "2px", background: r.color, display: "inline-block" }} />
   333	                {r.label}
   334	              </span>
   335	              <span style={{ fontWeight: 600, color: r.value == null ? "#cbd5e1" : "#1a1a2e" }}>
   336	                {r.value == null ? "—" : `${r.value}${r.unit}`}
   337	              </span>
   338	            </div>
   339	          ))}
   340	        </div>
