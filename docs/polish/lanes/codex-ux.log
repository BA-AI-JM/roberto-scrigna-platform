   104	  }
   105	
   106	  if (!plan) {
   107	    return (
   108	      <div style={cardStyle}>
   109	        <p style={sectionTitle}>Piano Attivo</p>
   110	        <div style={{ padding: "28px", background: "#f8fafc", borderRadius: "10px", textAlign: "center", border: "1px dashed #cbd5e1" }}>
   111	          <div style={{ fontSize: "32px", marginBottom: "12px" }}>📋</div>
