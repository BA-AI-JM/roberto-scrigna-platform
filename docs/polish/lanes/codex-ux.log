    68	                target="_blank"
    69	                rel="noopener noreferrer"
    70	                download
    71	                style={{
    72	                  display: "flex",
    73	                  justifyContent: "space-between",
    74	                  alignItems: "center",
    75	                  gap: "10px",
    76	                  padding: "12px 14px",
    77	                  background: "#f8fafc",
    78	                  border: "1px solid #e2e8f0",
    79	                  borderRadius: "10px",
    80	                  textDecoration: "none",
    81	                  color: "#1a1a2e",
    82	                }}
    83	              >
    84	                <div style={{ minWidth: 0 }}>
    85	                  <div style={{ fontSize: "13px", fontWeight: 700, color: "#1a1a2e", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{doc.title}</div>
    86	                  <div style={{ fontSize: "11px", color: "#6b7280", marginTop: "2px" }}>
    87	                    {docTypeLabel(doc.doc_type)} · {formatDate(doc.created_at)}{size ? ` · ${size}` : ""}
    88	                  </div>
    89	                </div>
    90	                <span style={{ fontSize: "13px", fontWeight: 700, color: "#1d4ed8", whiteSpace: "nowrap" }}>Scarica ↓</span>
    91	              </a>
    92	            );
    93	          })}
    94	        </div>
    95	      )}
    96	    </div>
    97	  );
    98	}
