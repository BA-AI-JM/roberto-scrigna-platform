   231	  trainingTime?: { startTime?: string; endTime?: string } | null;
   232	}) {
   233	  const plansWithMeals = dayTypePlans.filter((p) => p.mealPlan && p.mealPlan.slots.length > 0);
   234	  if (plansWithMeals.length === 0) return null;
   235	
   236	  return (
   237	    <div>
   238	      <p style={{ fontSize: "14px", fontWeight: 700, color: "#374151", marginBottom: "12px" }}>I tuoi pasti</p>
   239	      {plansWithMeals.map((dayPlan) => (
   240	        <div key={dayPlan.dayType} style={{ marginBottom: "20px" }}>
   241	          <div style={{ fontSize: "13px", fontWeight: 600, color: "#6b7280", marginBottom: "8px", textTransform: "uppercase", letterSpacing: "0.05em" }}>
   242	            {dayPlan.label}
   243	          </div>
   244	          {/* #18 nutrient timing — the same timed session box + pre/intra/post
   245	              grouping the coach sees, on a training day when a time is set
   246	              (else the component renders nothing, leaving the normal meal list). */}
   247	          <div style={{ marginBottom: "10px" }}>
   248	            <PeriWorkoutTimingCard
   249	              compact
   250	              dayType={dayPlan.dayType}
   251	              slots={dayPlan.mealPlan!.slots.map((sl) => ({
   252	                slot: sl.slot,
   253	                mealName: sl.primary?.template?.name,
   254	              }))}
   255	              startTime={trainingTime?.startTime}
   256	              endTime={trainingTime?.endTime}
   257	            />
   258	          </div>
   259	          <div style={{ display: "flex", flexDirection: "column", gap: "10px" }}>
   260	            {dayPlan.mealPlan!.slots.map((slot) => {
   261	              const macros = slot.primary.actualMacros;
   262	              const ingredients = slot.primary.scaledIngredients;
   263	              return (
   264	                <div key={slot.slot} style={{ border: "1px solid #e2e8f0", borderRadius: "10px", overflow: "hidden" }}>
   265	                  <div style={{ padding: "12px 16px", background: "#f8fafc", display: "flex", justifyContent: "space-between", alignItems: "center", flexWrap: "wrap", gap: "6px" }}>
   266	                    <span style={{ fontSize: "14px", fontWeight: 700, color: "#1a1a2e" }}>{MEAL_LABELS[slot.slot] ?? slot.slot.replace(/_/g, " ")}</span>
   267	                    <div style={{ display: "flex", gap: "10px", flexWrap: "wrap" }}>
   268	                      <span style={{ fontSize: "12px", color: "#6b7280" }}>{Math.round(macros.kcal)} kcal</span>
   269	                      <span style={{ fontSize: "12px", color: "#3b82f6" }}>P {Math.round(macros.proteinG)}g</span>
   270	                      <span style={{ fontSize: "12px", color: "#f59e0b" }}>C {Math.round(macros.carbsG)}g</span>
   271	                      <span style={{ fontSize: "12px", color: "#ef4444" }}>G {Math.round(macros.fatG)}g</span>
   272	                    </div>
   273	                  </div>
   274	                  <div style={{ padding: "10px 16px 4px", fontSize: "13px", fontWeight: 600, color: "#374151" }}>{slot.primary.template.name}</div>
   275	                  {ingredients.length > 0 ? (
   276	                    <div style={{ padding: "4px 16px 12px" }}>
   277	                      {ingredients.map((ing, idx) => (
   278	                        <div key={idx} style={{ display: "flex", justifyContent: "space-between", padding: "5px 0", borderBottom: idx < ingredients.length - 1 ? "1px solid #f1f5f9" : "none" }}>
   279	                          <span style={{ fontSize: "13px", color: "#374151" }}>{ing.name}</span>
   280	                          <span style={{ fontSize: "13px", fontWeight: 600, color: "#1a1a2e", whiteSpace: "nowrap" }}>{formatIngredientQuantity(ing.foodId, ing.grams)}</span>
   281	                        </div>
   282	                      ))}
   283	                    </div>
   284	                  ) : (
   285	                    <div style={{ padding: "8px 16px 12px" }}>
   286	                      <p style={{ fontSize: "13px", color: "#6b7280", margin: 0 }}>Nessun ingrediente specificato.</p>
   287	                    </div>
   288	                  )}
   289	                </div>
   290	              );
   291	            })}
   292	          </div>
   293	        </div>
   294	      ))}
   295	    </div>
   296	  );
   297	}
