---INVOICE RENDERER---
     1	/**
     2	 * Invoice HTML renderer.
     3	 *
     4	 * Produces a branded A4 HTML document for Roberto Scrigna invoices.
     5	 * Designed to render correctly in Puppeteer for PDF output.
     6	 *
     7	 * Layout:
     8	 * - Header: Roberto Scrigna branding + invoice number
     9	 * - Issuer / Client block (two columns)
    10	 * - Line items table
    11	 * - Totals (Subtotale, IVA, Totale)
    12	 * - Footer: payment notes, contacts
    13	 */
    14	
    15	interface LineItem {
    16	  description: string;
    17	  quantity: number;
    18	  unitPriceCents: number;
    19	  taxPct?: number;
    20	}
    21	
    22	export interface InvoiceRenderData {
    23	  invoiceNumber: string;
    24	  status: string;
    25	  amountCents: number;
    26	  currency: string;
    27	  taxPct: number;
    28	  issuedDate: string | null;
    29	  dueDate: string | null;
    30	  paidDate: string | null;
    31	  description: string | null;
    32	  lineItems: LineItem[];
    33	  client: {
    34	    full_name: string;
    35	    email: string | null;
    36	    phone: string | null;
    37	  } | null;
    38	  partnerName: string;
    39	  partnerEmail: string;
    40	}
    41	
    42	// ── Helpers ───────────────────────────────────────────────────────────────────
    43	
    44	function formatCurrency(cents: number, currency = "EUR"): string {
    45	  return new Intl.NumberFormat("it-IT", {
    46	    style: "currency",
    47	    currency,
    48	  }).format(cents / 100);
    49	}
    50	
    51	function formatDate(iso: string | null): string {
    52	  if (!iso) return "—";
    53	  return new Intl.DateTimeFormat("it-IT", {
    54	    timeZone: "Europe/Rome",
    55	    day: "2-digit",
    56	    month: "2-digit",
    57	    year: "numeric",
    58	  }).format(new Date(iso));
    59	}
    60	
    61	const STATUS_LABELS: Record<string, string> = {
    62	  draft: "Bozza",
    63	  sent: "Inviata",
    64	  paid: "Pagata",
    65	  overdue: "Scaduta",
    66	  cancelled: "Annullata",
    67	};
    68	
    69	const STATUS_COLORS: Record<string, { bg: string; color: string }> = {
    70	  draft: { bg: "#f1f5f9", color: "#475569" },
    71	  sent: { bg: "#dbeafe", color: "#1d4ed8" },
    72	  paid: { bg: "#dcfce7", color: "#15803d" },
    73	  overdue: { bg: "#fee2e2", color: "#b91c1c" },
    74	  cancelled: { bg: "#f3f4f6", color: "#6b7280" },
    75	};
    76	
    77	function esc(s: string | null | undefined): string {
    78	  if (!s) return "";
    79	  return s
    80	    .replace(/&/g, "&amp;")
    81	    .replace(/</g, "&lt;")
    82	    .replace(/>/g, "&gt;")
    83	    .replace(/"/g, "&quot;");
    84	}
    85	
    86	// ── Renderer ──────────────────────────────────────────────────────────────────
    87	
    88	export function renderInvoiceHtml(data: InvoiceRenderData): string {
    89	  const {
    90	    invoiceNumber,
    91	    status,
    92	    amountCents,
    93	    currency,
    94	    taxPct,
    95	    issuedDate,
    96	    dueDate,
    97	    paidDate,
    98	    description,
    99	    lineItems,
   100	    client,
   101	    partnerName,
   102	    partnerEmail,
   103	  } = data;
   104	
   105	  const subtotalCents = lineItems.reduce(
   106	    (s, li) => s + li.quantity * li.unitPriceCents,
   107	    0
   108	  );
   109	  const taxCents = amountCents - subtotalCents;
   110	
   111	  const statusCfg = STATUS_COLORS[status] ?? {
   112	    bg: "#f3f4f6",
   113	    color: "#374151",
   114	  };
   115	  const statusLabel = STATUS_LABELS[status] ?? status;
   116	
   117	  const lineItemRows = lineItems
   118	    .map(
   119	      (li) => `
   120	    <tr>
   121	      <td class="td-desc">${esc(li.description)}</td>
   122	      <td class="td-right">${li.quantity % 1 === 0 ? li.quantity : li.quantity.toFixed(2)}</td>
   123	      <td class="td-right">${formatCurrency(li.unitPriceCents, currency)}</td>
   124	      <td class="td-right td-total">${formatCurrency(
   125	        li.quantity * li.unitPriceCents,
   126	        currency
   127	      )}</td>
   128	    </tr>`
   129	    )
   130	    .join("");
   131	
   132	  const paidRow =
   133	    status === "paid" && paidDate
   134	      ? `<tr>
   135	           <td class="meta-label">Data pagamento:</td>
   136	           <td class="meta-value">${formatDate(paidDate)}</td>
   137	         </tr>`
   138	      : "";
   139	
   140	  return `<!DOCTYPE html>
