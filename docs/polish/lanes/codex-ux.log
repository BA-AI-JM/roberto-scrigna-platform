   111	@layer base {
   112	  * {
   113	    @apply border-border;
   114	  }
   115	  body {
   116	    @apply bg-background text-foreground;
   117	    font-family: system-ui, -apple-system, sans-serif;
   118	    /* Body reading rhythm + crisp smoothing. */
   119	    line-height: 1.6;
   120	    -webkit-font-smoothing: antialiased;
   121	    -moz-osx-font-smoothing: grayscale;
   122	    text-rendering: optimizeLegibility;
   123	  }
   124	  /* Figures read "engineered": data entry uses tabular + lining numerals so
   125	     weights / macros / energy align. Prose stays proportional. */
   126	  input,
   127	  select,
   128	  textarea {
   129	    font-variant-numeric: tabular-nums lining-nums;
   130	  }
   131	  /* WCAG 2.4.7 — a visible, branded keyboard-focus ring on every interactive
   132	     element. Two earlier attempts failed on prod: a plain stylesheet `outline`
   133	     is overridden by the many legacy inline `outline: none` styles, and a
   134	     `box-shadow` ring gets CLIPPED by the `overflow: hidden` cards/tables the
   135	     controls live in. `outline` with `!important` beats the inline `outline:none`
   136	     (author-important > inline) AND is never clipped by overflow — so the ring
   137	     is genuinely visible everywhere. Keyboard focus only (`:focus-visible`), so
   138	     no ring appears on mouse click. */
   139	  :focus-visible {
   140	    outline: 2px solid var(--ring) !important;
   141	    outline-offset: 2px;
   142	  }
   143	  /* Respect reduced-motion app-wide — refinement, not decoration. */
   144	  @media (prefers-reduced-motion: reduce) {
   145	    *,
   146	    ::before,
   147	    ::after {
   148	      animation-duration: 0.01ms !important;
   149	      animation-iteration-count: 1 !important;
   150	      transition-duration: 0.01ms !important;
   151	      scroll-behavior: auto !important;
   152	    }
   153	  }
   154	}
   155	
   156	@layer components {
   157	  /* Patient reading surface — a comfortable column on mobile that widens
   158	     gracefully on desktop (no lonely 640px column, no over-stretch). */
   159	  .portal-container {
   160	    @apply mx-auto w-full max-w-[640px] px-4 py-6 sm:px-6 lg:max-w-3xl lg:py-10;
   161	  }
   162	  /* Coach dense surface — fluid, breathes on large screens, tightens on small. */
   163	  .coach-container {
   164	    @apply mx-auto w-full max-w-[1280px] px-4 py-6 lg:px-8;
   165	  }
   166	  /* Data tables must scroll on narrow screens, never crush (fixes the
   167	     overflow:hidden tables). Wrap a table in <div class="table-scroll">. */
   168	  .table-scroll {
   169	    @apply w-full overflow-x-auto;
   170	  }
   171	}
   172	
   173	@layer utilities {
   174	  /* Opt-in tabular + lining numerals for any figure rendered via shared markup. */
   175	  .tnum {
   176	    font-variant-numeric: tabular-nums lining-nums;
   177	  }
   178	}
