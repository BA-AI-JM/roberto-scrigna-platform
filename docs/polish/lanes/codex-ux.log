   101	// ── Renderer ──────────────────────────────────────────────────────────────────
   102	
   103	function formatStampDateTime(iso: string): string {
   104	  return new Intl.DateTimeFormat("it-IT", {
   105	    timeZone: "Europe/Rome",
   106	    day: "2-digit",
   107	    month: "2-digit",
   108	    year: "numeric",
   109	    hour: "2-digit",
   110	    minute: "2-digit",
   111	    second: "2-digit",
   112	    timeZoneName: "short",
   113	  }).format(new Date(iso));
   114	}
