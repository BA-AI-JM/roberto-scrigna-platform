   196	      if (e?.data?.code === "PRECONDITION_FAILED" && /intern/i.test(msg)) setExternalBlocked(true);
   197	    },
   198	  });
   199	  const justSigned = accept.isSuccess;
   200	
   201	  // Move focus to the confirmation when signing completes (a11y).
   202	  useEffect(() => {
   203	    if (justSigned) confirmRef.current?.focus();
   204	  }, [justSigned]);
   205	
   206	  // ── loading ──
   207	  if (requestQuery.isLoading) {
   208	    return (
   209	      <Frame>
   210	        <div style={card}>
   211	          <div style={{ height: "20px", width: "55%", background: "#eef2f6", borderRadius: "6px", marginBottom: "14px" }} />
   212	          <div style={{ height: "120px", background: "#f1f5f9", borderRadius: "10px" }} />
   213	        </div>
   214	      </Frame>
   215	    );
   216	  }
   217	
   218	  // ── deny / not-this-patient / not-found ──
   219	  if (requestQuery.error) {
   220	    return (
   221	      <Frame>
   222	        <Notice tone="danger" title="Documento non disponibile">
   223	          {denyMessage(requestQuery.error.data?.code)}
