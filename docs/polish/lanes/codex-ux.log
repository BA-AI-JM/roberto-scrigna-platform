    17	
    18	export function DiaryEntryList({ entries, loading }: { entries: DiaryEntry[] | undefined; loading: boolean }) {
    19	  if (loading) {
    20	    return (
    21	      <div style={{ ...cardStyle, color: "#6b7280", fontSize: "14px" }}>Caricamento diario…</div>
    22	    );
    23	  }
    24	
    25	  const total = sumDayTotals(entries);
    26	
    27	  if (!entries || entries.length === 0) {
    28	    return (
    29	      <div style={{ ...cardStyle, textAlign: "center", padding: "32px 20px" }}>
    30	        <div style={{ fontSize: "32px", marginBottom: "8px" }} aria-hidden>📓</div>
    31	        <p style={{ fontSize: "14px", fontWeight: 600, color: "#374151", margin: "0 0 4px" }}>Nessun pasto registrato</p>
    32	        <p style={{ fontSize: "13px", color: "#6b7280", margin: 0 }}>Aggiungi il tuo primo pasto qui sotto.</p>
    33	      </div>
    34	    );
    35	  }
    36	
    37	  return (
    38	    <div>
    39	      {/* Day total */}
    40	      <div style={{ ...cardStyle, background: "#1a1a2e", color: "#ffffff", display: "flex", flexWrap: "wrap" }}>
    41	        {[
    42	          { label: "Kcal", value: `${total.kcal}` },
    43	          { label: "Proteine", value: `${total.protein}g` },
    44	          { label: "Carboidrati", value: `${total.carbs}g` },
    45	          { label: "Grassi", value: `${total.fat}g` },
    46	        ].map((c) => (
    47	          <div key={c.label} style={{ flex: "1 1 80px", minWidth: "70px", textAlign: "center", padding: "4px" }}>
    48	            <div style={{ fontSize: "18px", fontWeight: 700 }}>{c.value}</div>
    49	            <div style={{ fontSize: "11px", opacity: 0.6 }}>{c.label}</div>
    50	          </div>
    51	        ))}
    52	      </div>
    53	
    54	      {/* Entries */}
    55	      {entries.map((e) => (
    56	        <div key={e.id} style={cardStyle}>
    57	          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: "8px" }}>
    58	            <span style={{ fontSize: "14px", fontWeight: 700, color: "#1a1a2e" }}>{mealSlotLabel(e.meal_slot)}</span>
    59	            <span style={{ fontSize: "12px", color: "#6b7280" }}>{Math.round(e.total_kcal ?? 0)} kcal</span>
    60	          </div>
    61	          {(e.food_items ?? []).map((f, i) => (
    62	            <div key={i} style={{ display: "flex", justifyContent: "space-between", padding: "4px 0", borderBottom: i < (e.food_items?.length ?? 0) - 1 ? "1px solid #f1f5f9" : "none" }}>
    63	              <span style={{ fontSize: "13px", color: "#374151" }}>{f.name}</span>
    64	              <span style={{ fontSize: "13px", color: "#1a1a2e", fontWeight: 600, whiteSpace: "nowrap" }}>{f.grams} g · {Math.round(f.kcal)} kcal</span>
    65	            </div>
    66	          ))}
    67	          {e.notes && <div style={{ fontSize: "12px", color: "#6b7280", marginTop: "6px" }}>{e.notes}</div>}
    68	        </div>
    69	      ))}
    70	    </div>
    71	  );
    72	}

