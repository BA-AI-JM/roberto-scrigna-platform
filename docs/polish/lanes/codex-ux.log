     3	/**
     4	 * TrendChart — metric-agnostic time-series line chart (zero dependency, inline SVG).
     5	 *
     6	 * Built without a charting library to match this codebase's zero-chart-lib,
     7	 * inline-styled house style and to stay unit-testable in the repo's node-only
     8	 * vitest (the pure helpers below render no DOM). Responsiveness comes from a
     9	 * measured-width pixel coordinate system wrapped in the existing overflowX:auto
    10	 * pattern; interactivity from a pointer/touch hover tooltip.
    11	 *
    12	 * Multiple series are overlaid, each auto-scaled to its OWN min/max range so
    13	 * metrics with very different units (kg vs % vs kcal vs steps) remain
    14	 * shape-comparable; exact values + units are shown in the tooltip and legend.
    15	 *
    16	 * A calorie/macro series (e.g. { key: "kcal", unit: "kcal", points }) plugs in
    17	 * unchanged once a per-day nutrition-log query exists (backend gap — not built).
    18	 */
    19	
    20	import { useEffect, useMemo, useRef, useState } from "react";
    21	
    22	// ── Public types ───────────────────────────────────────────────────────────────
    23	
    24	export interface TrendSeriesPoint {
    25	  date: string;
    26	  value: number;
    27	}
    28	
    29	export interface TrendSeries {
    30	  key: string;
    31	  label: string;
    32	  color: string;
    33	  unit: string;
    34	  /** When true, a downward trend is the "good" direction (e.g. body fat %). */
    35	  lowerIsBetter?: boolean;
    36	  points: TrendSeriesPoint[];
    37	}
    38	
    39	export interface TrendChartProps {
    40	  series: TrendSeries[];
    41	  height?: number;
    42	}
    43	
    44	// ── Pure helpers (exported for testing — no DOM required) ────────────────────────
    45	
    46	export function parseTime(date: string): number {
    47	  const t = new Date(date).getTime();
    48	  return Number.isNaN(t) ? 0 : t;
    49	}
    50	
    51	function hasValue(p: TrendSeriesPoint): boolean {
    52	  return p != null && p.date != null && typeof p.value === "number" && Number.isFinite(p.value);
    53	}
    54	
    55	/** Sorted-ascending union of all dates that carry a finite value across series. */
    56	export function collectDates(series: TrendSeries[]): string[] {
    57	  const byTime = new Map<number, string>();
    58	  for (const s of series) {
    59	    for (const p of s.points ?? []) {
    60	      if (!hasValue(p)) continue;
    61	      const t = parseTime(p.date);
    62	      if (!byTime.has(t)) byTime.set(t, p.date);
    63	    }
    64	  }
    65	  return [...byTime.entries()].sort((a, b) => a[0] - b[0]).map((e) => e[1]);
    66	}
    67	
    68	/** Number of distinct dated data points — drives the 0 / 1 / many states. */
    69	export function totalDataPoints(series: TrendSeries[]): number {
    70	  return collectDates(series).length;
    71	}
    72	
    73	/** Min/max of a series' finite values; pads a flat series so it doesn't divide by zero. */
    74	export function seriesExtent(points: TrendSeriesPoint[]): [number, number] | null {
    75	  const vals = (points ?? []).filter(hasValue).map((p) => p.value);
    76	  if (vals.length === 0) return null;
    77	  let lo = Math.min(...vals);
    78	  let hi = Math.max(...vals);
    79	  if (lo === hi) {
    80	    lo -= 1;
    81	    hi += 1;
    82	  }
    83	  return [lo, hi];
    84	}
    85	
    86	/** Tooltip rows for a given date: each series' value at that date (null when absent). */
    87	export function tooltipRows(
    88	  series: TrendSeries[],
    89	  date: string
    90	): { key: string; label: string; value: number | null; unit: string; color: string }[] {
    91	  return series.map((s) => {
    92	    const pt = (s.points ?? []).find((p) => p.date === date && hasValue(p));
    93	    return {
    94	      key: s.key,
    95	      label: s.label,
    96	      value: pt ? pt.value : null,
    97	      unit: s.unit,
    98	      color: s.color,
    99	    };
   100	  });
   101	}
   102	
   103	export function formatShortDate(date: string): string {
   104	  const d = new Date(date);
   105	  if (Number.isNaN(d.getTime())) return date;
   106	  return d.toLocaleDateString("it-IT", { day: "2-digit", month: "short" });
   107	}
   108	
   109	/** Latest finite value of a series (its points are assumed chronological-ascending or not — we scan). */
   110	export function latestValue(s: TrendSeries): number | null {
   111	  const dated = (s.points ?? [])
   112	    .filter(hasValue)
   113	    .sort((a, b) => parseTime(a.date) - parseTime(b.date));
   114	  return dated.length > 0 ? dated[dated.length - 1]!.value : null;
   115	}
