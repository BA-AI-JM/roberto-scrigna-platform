     1	"use client";
     2	
     3	/**
     4	 * Patient-portal navigation — responsive across mobile and desktop under one
     5	 * brand. Mobile (< lg): a fixed bottom tab bar (thumb-reachable). Desktop (lg+):
     6	 * a pinned top nav bar with a brand wordmark — so the portal is a real desktop
     7	 * app, not a lonely phone column with a stranded mobile tab bar.
     8	 *
     9	 * The pure tab config + active-matcher and the presentational bars are exported
    10	 * for testing; PortalBottomNav is the client wrapper that reads the path and
    11	 * renders both bars (each gated by breakpoint).
    12	 */
    13	
    14	import Link from "next/link";
    15	import { usePathname } from "next/navigation";
    16	
    17	export interface PortalNavTab {
    18	  href: string;
    19	  label: string;
    20	  icon: string;
    21	}
    22	
    23	export const PORTAL_NAV_TABS: PortalNavTab[] = [
    24	  { href: "/portal/dashboard", label: "Home", icon: "🏠" },
    25	  { href: "/portal/plan", label: "Piano", icon: "🍽️" },
    26	  { href: "/portal/diary", label: "Diario", icon: "📓" },
    27	  { href: "/portal/progress", label: "Progressi", icon: "📈" },
    28	];
    29	
    30	/** A tab is active when the path equals or is nested under its href. */
    31	export function isTabActive(pathname: string | null | undefined, href: string): boolean {
    32	  if (!pathname) return false;
    33	  return pathname === href || pathname.startsWith(href + "/");
    34	}
    35	
    36	/** Mobile: fixed bottom tab bar (hidden on lg+). */
    37	export function BottomNavBar({ pathname }: { pathname: string | null }) {
    38	  return (
    39	    <nav
    40	      aria-label="Navigazione portale"
    41	      className="fixed inset-x-0 bottom-0 z-50 flex border-t border-border bg-background lg:hidden"
    42	      style={{ boxShadow: "0 -2px 12px rgba(0,0,0,0.04)", paddingBottom: "env(safe-area-inset-bottom, 0px)" }}
    43	    >
    44	      {PORTAL_NAV_TABS.map((tab) => {
    45	        const active = isTabActive(pathname, tab.href);
    46	        return (
    47	          <Link
    48	            key={tab.href}
    49	            href={tab.href}
    50	            aria-current={active ? "page" : undefined}
    51	            className={`flex flex-1 flex-col items-center justify-center gap-0.5 px-1 pb-2.5 pt-2 no-underline ${
    52	              active ? "text-brand-deep" : "text-muted-foreground"
    53	            }`}
    54	            style={{ fontWeight: active ? 500 : 400 }}
    55	          >
    56	            <span className="text-[20px] leading-[22px]" style={{ opacity: active ? 1 : 0.7 }} aria-hidden>
    57	              {tab.icon}
    58	            </span>
    59	            <span className="text-[11px]">{tab.label}</span>
    60	          </Link>
    61	        );
    62	      })}
    63	    </nav>
    64	  );
    65	}
    66	
    67	/** Desktop: pinned top nav bar with a brand wordmark (shown on lg+). */
    68	export function TopNavBar({ pathname }: { pathname: string | null }) {
    69	  return (
    70	    <nav
    71	      aria-label="Navigazione portale"
    72	      className="fixed inset-x-0 top-0 z-50 hidden h-14 items-center gap-1 border-b border-border bg-background/90 px-6 backdrop-blur lg:flex"
    73	    >
    74	      <Link href="/portal/dashboard" className="mr-4 flex items-center gap-2 no-underline">
    75	        <span className="grid h-7 w-7 place-items-center rounded-lg bg-brand text-[14px]" aria-hidden>
    76	          🥗
    77	        </span>
    78	        <span className="text-sm font-medium text-ink">Roberto Scrigna</span>
    79	      </Link>
    80	      <div className="flex items-center gap-1">
    81	        {PORTAL_NAV_TABS.map((tab) => {
    82	          const active = isTabActive(pathname, tab.href);
    83	          return (
    84	            <Link
    85	              key={tab.href}
    86	              href={tab.href}
    87	              aria-current={active ? "page" : undefined}
    88	              className={`rounded-full px-3.5 py-1.5 text-sm no-underline transition-colors ${
    89	                active ? "bg-brand-wash text-brand-deep" : "text-muted-foreground hover:text-foreground"
    90	              }`}
    91	              style={{ fontWeight: active ? 500 : 400 }}
    92	            >
    93	              {tab.label}
    94	            </Link>
    95	          );
    96	        })}
    97	      </div>
    98	    </nav>
    99	  );
   100	}
   101	
   102	export default function PortalBottomNav() {
   103	  const pathname = usePathname();
   104	  return (
   105	    <>
   106	      <TopNavBar pathname={pathname} />
   107	      <BottomNavBar pathname={pathname} />
   108	    </>
   109	  );
   110	}
---PORTAL LAYOUT---
     1	/**
     2	 * Portal protected layout.
     3	 *
     4	 * Auth guard for all routes under /portal/(protected)/*.
     5	 * Verifies the user has an authenticated Supabase session AND a client record.
     6	 * Redirects to /portal/login if either check fails.
     7	 *
     8	 * This layout intentionally does NOT wrap /portal/login or /portal/auth/callback.
     9	 */
    10	
    11	import { redirect } from "next/navigation";
    12	import { createSupabaseServer } from "@/lib/supabase/server";
    13	import { createSupabaseServiceRole } from "@/lib/supabase/service";
    14	import { Toaster } from "@/components/ui/sonner";
    15	import PortalBottomNav from "@/components/portal/portal-bottom-nav";
    16	
    17	export default async function PortalProtectedLayout({
    18	  children,
    19	}: {
    20	  children: React.ReactNode;
    21	}) {
    22	  const supabase = await createSupabaseServer();
    23	  const {
    24	    data: { user },
    25	  } = await supabase.auth.getUser();
    26	
    27	  if (!user) {
    28	    redirect("/portal/login");
    29	  }
    30	
    31	  // Verify the authenticated user has a client record (not a partner)
    32	  const db = createSupabaseServiceRole();
    33	  const { data: client } = await db
    34	    .from("client")
    35	    .select("id, status")
    36	    .eq("auth_user_id", user.id)
    37	    .maybeSingle();
    38	
    39	  if (!client || client.status !== "active") {
    40	    // User exists in Supabase Auth but is not a registered or active client
    41	    redirect("/portal/login");
    42	  }
    43	
    44	  return (
    45	    <>
    46	      {/* Nav clearance: bottom tab bar on mobile, pinned top nav on desktop. */}
    47	      <div className="pb-20 lg:pb-0 lg:pt-14">{children}</div>
    48	      <PortalBottomNav />
    49	      <Toaster position="top-center" />
    50	    </>
    51	  );
    52	}
     1	/**
     2	 * Portal root layout.
     3	 *
     4	 * Provides the tRPC + React Query context for all portal pages.
     5	 * Auth protection is handled in the (protected) sub-layout so that
     6	 * /portal/login and /portal/auth/callback are not guarded.
     7	 */
     8	
     9	import { TRPCProvider } from "@/lib/trpc/provider";
    10	
    11	/** Root portal layout — TRPCProvider only, no auth check. */
