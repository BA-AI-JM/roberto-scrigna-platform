   113	          <p style={{ fontSize: "13px", color: "#6b7280", margin: 0 }}>Il tuo nutrizionista sta preparando il tuo piano.</p>
   114	        </div>
   115	      </div>
   116	    );
   117	  }
   118	
   119	  const targets = plan.daily_targets as Record<string, number | null | undefined> | null;
   120	  const daysOnPlan = daysBetween(plan.start_date, todayISO);
   121	
   122	  return (
   123	    <div style={cardStyle}>
   124	      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: "18px" }}>
   125	        <p style={{ ...sectionTitle, marginBottom: 0 }}>Piano Attivo</p>
   126	        <span style={pillStyle("#15803d", "#f0fdf4")}>In corso</span>
   127	      </div>
   128	
   129	      <div style={{ marginBottom: "20px" }}>
   130	        <h3 style={{ fontSize: "20px", fontWeight: 700, color: "#1a1a2e", margin: "0 0 8px" }}>{plan.name}</h3>
   131	        <div style={{ display: "flex", gap: "20px", flexWrap: "wrap" }}>
   132	          {plan.start_date && (
   133	            <span style={{ fontSize: "13px", color: "#6b7280" }}>Inizio: <strong style={{ color: "#374151" }}>{formatDate(plan.start_date)}</strong></span>
   134	          )}
   135	          {plan.end_date && (
   136	            <span style={{ fontSize: "13px", color: "#6b7280" }}>Fine: <strong style={{ color: "#374151" }}>{formatDate(plan.end_date)}</strong></span>
   137	          )}
   138	          <span style={{ fontSize: "13px", color: "#6b7280" }}>Giorni seguiti: <strong style={{ color: "#1a1a2e" }}>{daysOnPlan}</strong></span>
   139	        </div>
   140	      </div>
   141	
   142	      {targets != null ? (
   143	        <div style={{ display: "flex", gap: "12px", flexWrap: "wrap", padding: "16px", background: "#f8fafc", borderRadius: "10px", marginBottom: "20px" }}>
   144	          {[
   145	            { label: "Kcal", key: "kcal", unit: "" },
   146	            { label: "Proteine", key: "protein_g", unit: "g" },
   147	            { label: "Carboidrati", key: "carbs_g", unit: "g" },
   148	            { label: "Grassi", key: "fat_g", unit: "g" },
   149	          ].map(({ label, key, unit }) =>
   150	            targets[key] != null ? (
   151	              <div key={key} style={{ flex: "1 1 80px", minWidth: "70px", textAlign: "center" }}>
   152	                <div style={{ fontSize: "20px", fontWeight: 700, color: "#1a1a2e" }}>{String(targets[key] ?? "")}{unit}</div>
   153	                <div style={{ fontSize: "11px", color: "#6b7280", marginTop: "2px" }}>{label}</div>
   154	              </div>
   155	            ) : null
   156	          )}
   157	        </div>
   158	      ) : null}
   159	
   160	      {Array.isArray(plan.mealPlan) && plan.mealPlan.length > 0 && <MealPlanSection dayTypePlans={plan.mealPlan} trainingTime={plan.trainingTime} />}
   161	      {Array.isArray(plan.supplements) && plan.supplements.length > 0 && <SupplementSection supplements={plan.supplements} />}
   162	
