     1	"use client";
     2	
     3	/**
     4	 * ChartControls — the "customisable" layer over TrendChart.
     5	 *
     6	 * Owns pure-client state for (a) which metrics/series are shown and (b) the
     7	 * time-range window. Filters the supplied series accordingly and renders a
     8	 * TrendChart. No tRPC query — it operates entirely on the series passed in.
     9	 *
    10	 * The range window is anchored to the most-recent data point (not wall-clock
    11	 * "now"), so sparse/older measurement histories still show meaningful windows
    12	 * and the filtering is deterministic (and unit-testable).
    13	 */
    14	
    15	import { useMemo, useState } from "react";
    16	import { TrendChart, parseTime, type TrendSeries, type TrendSeriesPoint } from "./TrendChart";
    17	
    18	export type RangeKey = "4w" | "12w" | "6m" | "all";
    19	
    20	const RANGES: { key: RangeKey; label: string; days: number | null }[] = [
    21	  { key: "4w", label: "4 sett.", days: 28 },
    22	  { key: "12w", label: "12 sett.", days: 84 },
    23	  { key: "6m", label: "6 mesi", days: 182 },
    24	  { key: "all", label: "Tutto", days: null },
    25	];
    26	
    27	const DAY_MS = 24 * 60 * 60 * 1000;
    28	
    29	// ── Pure helpers (exported for testing) ──────────────────────────────────────
    30	
    31	/** Keep points within `days` before `anchorMs`. `days == null` → keep all. */
    32	export function filterByRange(
    33	  points: TrendSeriesPoint[],
    34	  days: number | null,
    35	  anchorMs: number
    36	): TrendSeriesPoint[] {
    37	  if (days == null) return points;
    38	  const cutoff = anchorMs - days * DAY_MS;
    39	  return (points ?? []).filter((p) => parseTime(p.date) >= cutoff);
    40	}
    41	
    42	/** Most-recent timestamp across all series (anchor for range filtering). */
    43	export function maxTime(series: TrendSeries[]): number {
    44	  let max = 0;
    45	  for (const s of series) {
    46	    for (const p of s.points ?? []) {
    47	      const t = parseTime(p.date);
    48	      if (t > max) max = t;
    49	    }
    50	  }
    51	  return max;
    52	}
    53	
    54	// ── Styles ───────────────────────────────────────────────────────────────────
    55	
    56	function toggleButtonStyle(active: boolean, accent?: string): React.CSSProperties {
    57	  return {
    58	    padding: "5px 11px",
    59	    borderRadius: "16px",
    60	    border: active ? `1.5px solid ${accent ?? "#1a1a2e"}` : "1px solid #d4d4d8",
    61	    background: active ? (accent ? `${accent}1a` : "#1a1a2e") : "#ffffff",
    62	    color: active ? (accent ?? "#ffffff") : "#71717a",
    63	    cursor: "pointer",
    64	    fontSize: "12px",
    65	    fontWeight: 600,
    66	    whiteSpace: "nowrap",
    67	  };
    68	}
    69	
    70	// ── Component ────────────────────────────────────────────────────────────────
    71	
    72	export interface ChartControlsProps {
    73	  series: TrendSeries[];
    74	  height?: number;
    75	  defaultRange?: RangeKey;
    76	  /** Initial selected metric keys; defaults to all series keys. */
    77	  defaultSelected?: string[];
    78	}
    79	
    80	export function ChartControls({ series, height, defaultRange = "all", defaultSelected }: ChartControlsProps) {
    81	  const [range, setRange] = useState<RangeKey>(defaultRange);
    82	  const [selected, setSelected] = useState<Set<string>>(
    83	    () => new Set(defaultSelected ?? series.map((s) => s.key))
    84	  );
    85	
    86	  const anchor = useMemo(() => maxTime(series), [series]);
    87	
    88	  const days = RANGES.find((r) => r.key === range)?.days ?? null;
    89	
    90	  const filtered = useMemo(
    91	    () =>
    92	      series
    93	        .filter((s) => selected.has(s.key))
    94	        .map((s) => ({ ...s, points: filterByRange(s.points, days, anchor) })),
    95	    [series, selected, days, anchor]
    96	  );
    97	
    98	  function toggleMetric(key: string) {
    99	    setSelected((prev) => {
   100	      const next = new Set(prev);
   101	      if (next.has(key)) {
   102	        if (next.size === 1) return prev; // keep at least one series visible
   103	        next.delete(key);
   104	      } else {
   105	        next.add(key);
   106	      }
   107	      return next;
   108	    });
   109	  }
   110	
   111	  return (
   112	    <div>
   113	      {/* Controls */}
   114	      <div style={{ display: "flex", flexWrap: "wrap", gap: "16px", alignItems: "center", marginTop: "8px" }}>
   115	        {/* Metric toggle */}
   116	        <div style={{ display: "flex", flexWrap: "wrap", gap: "6px" }}>
   117	          {series.map((s) => (
   118	            <button
   119	              key={s.key}
   120	              type="button"
   121	              onClick={() => toggleMetric(s.key)}
   122	              style={toggleButtonStyle(selected.has(s.key), s.color)}
   123	              aria-pressed={selected.has(s.key)}
   124	            >
   125	              {s.label}
   126	            </button>
   127	          ))}
   128	        </div>
   129	        {/* Range toggle */}
   130	        <div style={{ display: "flex", gap: "6px", marginLeft: "auto" }}>
   131	          {RANGES.map((r) => (
   132	            <button
   133	              key={r.key}
   134	              type="button"
   135	              onClick={() => setRange(r.key)}
   136	              style={toggleButtonStyle(range === r.key)}
   137	              aria-pressed={range === r.key}
   138	            >
   139	              {r.label}
   140	            </button>
   141	          ))}
   142	        </div>
   143	      </div>
   144	
   145	      <TrendChart series={filtered} height={height} />
   146	    </div>
   147	  );
   148	}
   149	
   150	export default ChartControls;

