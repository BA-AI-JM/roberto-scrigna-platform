   299	function SupplementSection({ supplements }: { supplements: NonNullable<ActivePlan["supplements"]> }) {
   300	  if (supplements.length === 0) return null;
   301	  return (
   302	    <div style={{ marginTop: "20px" }}>
   303	      <p style={{ fontSize: "14px", fontWeight: 700, color: "#374151", marginBottom: "12px" }}>Integratori</p>
   304	      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(180px, 1fr))", gap: "10px" }}>
   305	        {supplements.map((item, i) => (
   306	          <div key={`${item.libraryId ?? item.name}-${i}`} style={{ padding: "12px 14px", background: "#f0f9ff", border: "1px solid #bae6fd", borderRadius: "8px" }}>
   307	            <div style={{ fontSize: "13px", fontWeight: 700, color: "#0c4a6e", marginBottom: "4px" }}>{item.name}</div>
   308	            {(item.dosage || item.timing) && (
   309	              <div style={{ fontSize: "12px", color: "#0369a1" }}>{[item.dosage, item.timing].filter(Boolean).join(" · ")}</div>
   310	            )}
   311	            {(item.frequency || item.notes) && (
   312	              <div style={{ fontSize: "11px", color: "#7dd3fc", marginTop: "2px" }}>{[item.frequency, item.notes].filter(Boolean).join(" · ")}</div>
   313	            )}
   314	          </div>
   315	        ))}
   316	      </div>
   317	    </div>
   318	  );
   319	}
