     1	import { Resend } from "resend";
     2	
     3	let _resend: Resend | null = null;
     4	export function getResend() {
     5	  if (!_resend) {
     6	    _resend = new Resend(process.env.RESEND_API_KEY ?? "");
     7	  }
     8	  return _resend;
     9	}
    10	
    11	export const FROM_EMAIL =
    12	  process.env.RESEND_FROM_EMAIL ?? "noreply@example.com";
    13	
    14	/** Placeholder from-address used when RESEND_FROM_EMAIL is unset. */
    15	const UNCONFIGURED_FROM = "noreply@example.com";
    16	
    17	export interface SendEmailParams {
    18	  to: string;
    19	  subject: string;
    20	  html: string;
    21	  /** Defaults to FROM_EMAIL. */
    22	  from?: string;
    23	}
    24	
    25	/**
    26	 * Hardened Resend send (#1 email-wiring).
    27	 *
    28	 * The Resend SDK resolves `{ data, error }` and does NOT throw on API errors
    29	 * (invalid key, unverified from-domain). Call sites used to discard the result,
    30	 * so failures were silent and callers were told "sent". This wrapper:
    31	 *   1. fails loudly when Resend is misconfigured (empty key, or the placeholder
    32	 *      from-address), instead of attempting a doomed send;
    33	 *   2. inspects the returned `error`/`data` and throws a descriptive Error so
    34	 *      the caller (tRPC mutation or Inngest step) surfaces a real failure.
    35	 *
    36	 * It does NOT change the real key/from values — it only detects and surfaces
    37	 * the misconfigured/failed state. Happy path is unchanged.
    38	 */
    39	export async function sendEmail(params: SendEmailParams): Promise<void> {
    40	  const from = params.from ?? FROM_EMAIL;
    41	
    42	  if (!process.env.RESEND_API_KEY) {
    43	    throw new Error(
    44	      "Resend not configured: RESEND_API_KEY is not set — email not sent."
    45	    );
    46	  }
    47	  if (from === UNCONFIGURED_FROM) {
    48	    throw new Error(
    49	      "Resend not configured: RESEND_FROM_EMAIL is unset (placeholder noreply@example.com) — email not sent. Set a verified sender domain."
    50	    );
    51	  }
    52	
    53	  const { data, error } = await getResend().emails.send({
    54	    from,
    55	    to: params.to,
    56	    subject: params.subject,
    57	    html: params.html,
    58	  });
    59	
    60	  if (error) {
    61	    throw new Error(`Resend send failed: ${error.message ?? error.name ?? "unknown error"}`);
    62	  }
    63	  if (!data) {
    64	    throw new Error("Resend send failed: no data returned from Resend API.");
    65	  }
    66	}
