    53	        <div className="text-xs text-zinc-400">Nutrizione Sportiva</div>
    54	      </div>
    55	
    56	      {/* Navigation */}
    57	      <nav className="flex-1 space-y-1 overflow-y-auto px-3 py-4">
    58	        {NAV_ITEMS.map(({ href, label, icon: Icon }) => {
    59	          const isActive =
    60	            pathname === href ||
    61	            (href !== "/dashboard" &&
    62	              href !== "/plans/new" &&
    63	              pathname.startsWith(href));
    64	          return (
    65	            <Link
    66	              key={href}
    67	              href={href}
    68	              onClick={onNavigate}
    69	              className={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${
    70	                isActive
    71	                  ? "bg-zinc-900 text-white"
    72	                  : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900"
    73	              }`}
    74	            >
    75	              <Icon size={18} />
    76	              {label}
    77	            </Link>
    78	          );
    79	        })}
    80	      </nav>
