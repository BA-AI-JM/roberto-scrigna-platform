    51	export function DocumentsList({ documents, loading }: { documents: PortalDocument[] | undefined; loading: boolean }) {
    52	  return (
    53	    <div style={cardStyle}>
    54	      <p style={{ fontSize: "16px", fontWeight: 700, color: "#1a1a2e", margin: "0 0 14px" }}>Documenti</p>
    55	
    56	      {loading ? (
    57	        <p style={{ fontSize: "14px", color: "#6b7280", margin: 0 }}>Caricamento documenti…</p>
    58	      ) : !documents || documents.length === 0 ? (
    59	        <p style={{ fontSize: "13px", color: "#6b7280", margin: 0 }}>Nessun documento disponibile.</p>
    60	      ) : (
    61	        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
    62	          {documents.map((doc) => {
    63	            const size = formatSize(doc.file_size_bytes);
    64	            return (
    65	              <a
    66	                key={doc.id}
