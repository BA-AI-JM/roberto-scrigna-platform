+      "document",
+      "message",
+      "notification",
+      "signature_request",
+      "legal_document",
+      "legal_document_version",
+      "snapshot_edit_audit",
+      "urgent_feedback",
+      "client_reminder_settings",
+      "consent_record",
+      "client_media",
