+  );
+  const ledgerByName = new Map(ledger.map((entry) => [entry.filename, entry]));
+  const drift: MigrationDrift[] = [];
+
+  for (const entry of ledger) {
+    const migration = migrationsByName.get(entry.filename);
+    if (!migration) {
