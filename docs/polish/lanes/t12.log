+  fs: MigrationFs = { readdir, readFile },
+): Promise<MigrationFile[]> {
+  const filenames = (await fs.readdir(migrationsDir))
+    .filter((filename) => filename.endsWith(".sql"))
+    .sort((a, b) => a.localeCompare(b));
