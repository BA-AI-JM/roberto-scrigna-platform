+    try {
+      return await launchWithTimeout();
+    } catch (error) {
+      if (error instanceof PdfDependencyError) throw error;
+      lastError = error;
+      if (attempt === 1) await delay(CHROMIUM_RETRY_BACKOFF_MS);
