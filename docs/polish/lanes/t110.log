+    ? "CHROMIUM_PATH"
+    : process.env.VERCEL
+      ? process.env.CHROMIUM_PACK_URL
+        ? "CHROMIUM_PACK_URL"
+        : "default_github_release"
+      : "puppeteer_default";
+
+  console.info(
+    JSON.stringify({
+      event: "pdf_chromium_source",
+      source,
+      chromiumVersion: CHROMIUM_VERSION,
+    })
+  );
+}
