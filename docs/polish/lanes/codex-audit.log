   209	// ── N1/N2/N3: Plan Delivered → Not Viewed Chain ─────────────────────────────
   210	
   211	export const onPlanDelivered = inngest.createFunction(
   212	  { id: "plan-delivered", retries: 3, triggers: [{ event: "plan/delivered" }] },
   213	  async ({ event, step }) => {
   214	    const d = event.data as EventData;
   215	    const { planId, clientId, clientName, partnerId } = d;
   216	
   217	    await step.run("notify-plan-delivered", async () => {
   218	      await createNotification({
   219	        partnerId,
   220	        clientId,
   221	        trigger: "plan_expiring",
   222	        title: `Piano consegnato a ${clientName}`,
   223	        body: `Il piano nutrizionale è stato consegnato con successo.`,
   224	        metadata: { planId },
   225	      });
   226	    });
   227	
   228	    // N1: Email the client — piano pronto
   229	    await step.run("email-plan-delivered", async () => {
   230	      const email = await getClientEmail(clientId);
   231	      if (email) {
   232	        // Provision the portal auth account before emailing the link (#1) so
   233	        // the client can actually sign in from the access link.
   234	        await ensurePortalAuthUser(createSupabaseServiceRole(), {
   235	          clientId,
   236	          email,
   237	        });
   238	        const html = emailWrapper(
   239	          "Il tuo piano nutrizionale è pronto",
   240	          `<h2 style="margin:0 0 12px;font-size:20px;color:#1a1a2e;">Il tuo piano nutrizionale è pronto!</h2>
   241	<p style="margin:0 0 16px;font-size:14px;color:#374151;line-height:1.6;">
   242	  Ciao ${clientName},<br/>
   243	  il tuo piano nutrizionale personalizzato è stato preparato ed è ora disponibile nel portale.
   244	</p>
   245	<p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">
   246	  Accedi all'area clienti per visualizzare i tuoi pasti, gli obiettivi giornalieri e il protocollo integratori.
   247	</p>
   248	${btnHtml(portalUrl("/login"), "Visualizza il piano")}`
   249	        );
   250	        await sendEmail(email, "Il tuo piano nutrizionale è pronto!", html);
   251	      }
   252	    });
   253	
   254	    // N2: Follow-up if not viewed in 48h
   255	    await step.sleep("wait-48h", "48h");
   256	
   257	    await step.run("check-plan-viewed-48h", async () => {
   258	      const db = getServiceDb();
   259	      const { data: plan } = await db
   260	        .from("plan")
   261	        .select("id, status")
   262	        .eq("id", planId)
   263	        .single();
   264	
   265	      if (plan && plan.status === "delivered") {
   266	        await createNotification({
   267	          partnerId,
   268	          clientId,
   269	          trigger: "plan_expiring",
   270	          title: `${clientName} non ha visualizzato il piano`,
   271	          body: `Il piano consegnato 48 ore fa non è ancora stato aperto.`,
   272	          metadata: { planId, reminder: "48h" },
   273	        });
   274	      }
   275	    });
   276	
   277	    // N3: 7d escalation
   278	    await step.sleep("wait-5d-more", "5d");
   279	
   280	    await step.run("escalate-plan-not-viewed", async () => {
   281	      await createNotification({
   282	        partnerId,
   283	        clientId,
   284	        trigger: "plan_expiring",
   285	        title: `⚠️ ${clientName} — piano non visualizzato da 7 giorni`,
   286	        body: `Il piano non è stato visualizzato. Contattare il cliente.`,
   287	        metadata: { planId, reminder: "7d", escalated: true },
   288	      });
   289	
   290	      await createTask({
   291	        partnerId,
   292	        clientId,
   293	        title: `Contattare ${clientName} — piano non visualizzato`,
   294	        description: `Il piano consegnato 7 giorni fa non è stato aperto. Follow-up necessario.`,
   295	        priority: "high",
   296	      });
   297	    });
   298	  }
   299	);
