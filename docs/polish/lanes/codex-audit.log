    20	// ── Schemas ──────────────────────────────────────────────────────────────────
    21	
    22	/** Weight deviation threshold in kg — flags if check-in weight differs by more than this */
    23	const WEIGHT_DEVIATION_THRESHOLD_KG = 1.5;
    24	
    25	/** Check-in questionnaire submission schema */
    26	const checkinSubmissionSchema = z.object({
    27	  token: z.string().uuid(),
    28	  weightKg: z.number().min(30).max(300),
    29	  waistCm: z.number().min(40).max(200).optional(),
    30	  hipCm: z.number().min(50).max(200).optional(),
    31	  energyLevel: z.number().int().min(1).max(10),
    32	  sleepQuality: z.number().int().min(1).max(10),
    33	  stressLevel: z.number().int().min(1).max(10),
    34	  hungerLevel: z.number().int().min(1).max(10),
    35	  digestiveHealth: z.number().int().min(1).max(10),
    36	  adherencePct: z.number().int().min(0).max(100),
    37	  trainingAdherence: z.number().int().min(0).max(100).optional(),
    38	  notes: z.string().max(5000).optional(),
    39	  // Only allow https:// URLs to prevent javascript: or data: URI injection.
    40	  // URLs are stored and later rendered as <img> src or download links.
    41	  photos: z.array(z.string().url().startsWith("https://")).max(5).optional(),
    42	});
    43	
    44	// ── Helpers ──────────────────────────────────────────────────────────────────
    45	
    46	/** Compute weight deviation flag from previous check-in or snapshot */
    47	function computeWeightDeviation(
    48	  currentKg: number,
    49	  previousKg: number | null
    50	): { deviationKg: number; flagged: boolean } | null {
    51	  if (previousKg === null) return null;
    52	  const deviationKg = currentKg - previousKg;
    53	  return {
    54	    deviationKg: Math.round(deviationKg * 100) / 100,
    55	    flagged: Math.abs(deviationKg) > WEIGHT_DEVIATION_THRESHOLD_KG,
    56	  };
    57	}
    58	
    59	/** Generate a simple AI summary stub from check-in data */
    60	function generateCheckinSummary(data: {
    61	  weightKg: number;
    62	  energyLevel: number;
    63	  sleepQuality: number;
    64	  stressLevel: number;
    65	  adherencePct: number;
    66	  deviationKg: number | null;
    67	}): string {
    68	  const parts: string[] = [];
    69	
    70	  if (data.deviationKg !== null) {
    71	    const dir = data.deviationKg > 0 ? "+" : "";
    72	    parts.push(`Peso: ${data.weightKg}kg (${dir}${data.deviationKg}kg)`);
    73	  } else {
    74	    parts.push(`Peso: ${data.weightKg}kg (primo check-in)`);
    75	  }
    76	
    77	  if (data.energyLevel <= 4) parts.push("⚠️ Energia bassa");
    78	  if (data.sleepQuality <= 4) parts.push("⚠️ Sonno scarso");
    79	  if (data.stressLevel >= 7) parts.push("⚠️ Stress elevato");
    80	  if (data.adherencePct < 70) parts.push("⚠️ Aderenza sotto 70%");
    81	
    82	  if (data.energyLevel >= 7 && data.sleepQuality >= 7 && data.adherencePct >= 85) {
    83	    parts.push("✅ Buoni progressi generali");
    84	  }
    85	
    86	  return parts.join(" · ");
    87	}
