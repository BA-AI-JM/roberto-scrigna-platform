   181	export async function createTask(params: {
   182	  partnerId: string;
   183	  clientId?: string;
   184	  title: string;
   185	  description: string;
   186	  priority: string;
   187	  dueDate?: string;
   188	}) {
   189	  const db = getServiceDb();
   190	  const { error } = await db.from("task").insert({
   191	    partner_id: params.partnerId,
   192	    client_id: params.clientId ?? null,
   193	    title: params.title,
   194	    description: params.description,
   195	    priority: params.priority,
   196	    status: "todo",
   197	    due_date: params.dueDate ?? null,
   198	  });
   199	  // Throw so the Inngest step FAILS (retries / shows a failed run) instead of
   200	  // silently succeeding while the follow-up task is never created (#2).
   201	  if (error) {
   202	    throw new Error(`createTask insert failed (${params.title}): ${error.message}`);
   203	  }
   204	}
