   408	  // #FIX3: surface the carb-floor clamp — when protein+fat kcal alone exceed a
   409	  // day's target, carbs floor to 0 and the achieved kcal overshoots the target
   410	  // (the deficit is under-delivered). One line per affected day-type so Roberto
   411	  // sees it instead of it being silent.
   412	  const clampedSeen = new Set<DayType>();
   413	  for (const day of weeklyPlan.days) {
