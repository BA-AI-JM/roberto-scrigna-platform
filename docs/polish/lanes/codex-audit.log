     1	/**
     2	 * Signature Router — in-app SES signing behind the EsignProvider seam (Req #29).
     3	 *
     4	 * The router NEVER hardcodes a provider — it resolves the active one through
     5	 * getSignatureProvider() and calls the interface. Internal SES acceptance
     6	 * (pending -> signed) is performed here (client-scoped, internal-only); external
     7	 * providers sign on their hosted page and signal via webhook.
     8	 *
     9	 * Procedures:
    10	 * - createSignatureRequest   (partner) create a request for a client's active letter
    11	 * - getMyPendingSignatures   (client)  the client's open requests
    12	 * - getSignatureRequest      (client)  read one of the client's own requests
    13	 * - acceptSignature          (client)  internal SES: accept -> signed (+ stamps)
    14	 * - getSignatureStatus       (client)  provider status for an own request
    15	 * - downloadSignedDocument   (client)  regenerated signed PDF (base64) for an own request
    16	 *
    17	 * Data access uses the service-role client (like the portal router), scoped
    18	 * manually by ctx.partnerId / ctx.clientId; the RLS policies in migration 010
    19	 * are defence-in-depth.
    20	 */
    21	
    22	import { z } from "zod/v4";
    23	import { TRPCError } from "@trpc/server";
    24	import { router, protectedProcedure, clientProcedure } from "../trpc";
    25	import { createSupabaseServiceRole } from "../../lib/supabase/service";
    26	import { getSignatureProvider, activeSignatureProviderName } from "../esign/factory";
    27	import { renderSignedEngagementLetterPdf } from "../signature-document";
    28	import { fillEngagementLetter } from "../legal-letter";
    29	import type { SignatureProviderDeps } from "../esign/types";
    30	
    31	const OPEN_STATUSES = ["pending", "sent", "viewed"] as const;
    32	
    33	/** Build the provider deps (service-role db + on-demand signed-PDF renderer). */
    34	function buildDeps(): SignatureProviderDeps {
    35	  const db = createSupabaseServiceRole();
    36	  return { db, renderSignedLetterPdf: (id: string) => renderSignedEngagementLetterPdf(db, id) };
    37	}
    38	
    39	/**
    40	 * Resolve the signed PDF for a request → { pdfBase64, mimeType, filename }.
    41	 * Shared by the client (downloadSignedDocument) and coach (downloadSignedForClient)
    42	 * downloads so both regenerate the SAME artifact. The caller MUST authorise the
    43	 * request first (client- or partner-scoped) and ensure it is signed.
    44	 */
    45	async function resolveSignedPdf(deps: SignatureProviderDeps, requestId: string) {
    46	  const doc = await getSignatureProvider(deps).downloadSignedDocument(requestId);
    47	  return {
    48	    pdfBase64: Buffer.from(doc.bytes).toString("base64"),
    49	    mimeType: doc.contentType,
    50	    filename: `lettera-firmata-${requestId}.pdf`,
    51	  };
    52	}
    53	
    54	export const signatureRouter = router({
    55	  /**
    56	   * Create a signature request for a client using the partner's active letter
    57	   * version. Goes through the active provider (internal SES by default).
    58	   */
    59	  createSignatureRequest: protectedProcedure
    60	    .input(z.object({ clientId: z.string().uuid() }))
    61	    .mutation(async ({ ctx, input }) => {
    62	      const deps = buildDeps();
    63	      const db = deps.db;
    64	
    65	      const { data: client, error: clientErr } = await db
    66	        .from("client")
    67	        .select("id, full_name, email")
    68	        .eq("id", input.clientId)
    69	        .eq("partner_id", ctx.partnerId)
    70	        .is("deleted_at", null)
    71	        .single();
    72	      if (clientErr || !client) {
    73	        throw new TRPCError({ code: "NOT_FOUND", message: "Cliente non trovato." });
    74	      }
    75	
    76	      const { data: doc } = await db
    77	        .from("legal_document")
    78	        .select("id, name")
    79	        .eq("partner_id", ctx.partnerId)
    80	        .eq("doc_kind", "engagement_letter")
    81	        .maybeSingle();
    82	      const version = doc?.id
    83	        ? (
    84	            await db
    85	              .from("legal_document_version")
    86	              .select("id, version_label, language")
    87	              .eq("legal_document_id", doc.id)
    88	              .eq("status", "active")
    89	              .maybeSingle()
    90	          ).data
    91	        : null;
    92	      if (!doc?.id || !version?.id) {
    93	        throw new TRPCError({
    94	          code: "PRECONDITION_FAILED",
    95	          message:
    96	            "Nessun modello di lettera attivo. Pubblica prima un modello (legal.seedDefaultEngagementLetter / createVersion).",
    97	        });
    98	      }
    99	
   100	      const provider = getSignatureProvider(deps);
   101	      const result = await provider.createSignatureRequest({
   102	        clientId: client.id as string,
   103	        partnerId: ctx.partnerId,
   104	        documentVersionId: version.id as string,
   105	        title: doc.name as string,
   106	        language: version.language as string,
   107	        signer: {
   108	          fullName: client.full_name as string,
   109	          email: (client.email as string | null) ?? "",
   110	        },
   111	      });
   112	
   113	      return {
   114	        requestId: result.providerRequestId,
   115	        status: result.status,
   116	        signingUrl: result.signingUrl ?? null,
   117	        provider: provider.name,
   118	      };
   119	    }),
   120	
   121	  /** The client's open (not-yet-signed) signature requests. */
   122	  getMyPendingSignatures: clientProcedure.query(async ({ ctx }) => {
   123	    const db = createSupabaseServiceRole();
   124	    const { data, error } = await db
   125	      .from("signature_request")
   126	      .select("id, document_version_id, provider, status, created_at")
   127	      .eq("client_id", ctx.clientId)
   128	      .in("status", OPEN_STATUSES as unknown as string[])
   129	      .order("created_at", { ascending: false });
   130	    if (error) {
   131	      console.error("[router/signature.getMyPendingSignatures]", error);
   132	      throw new TRPCError({
   133	        code: "INTERNAL_SERVER_ERROR",
   134	        message: "Errore nel recupero delle firme.",
   135	      });
   136	    }
   137	    return (data ?? []).map((r: Record<string, unknown>) => ({
   138	      id: r.id as string,
   139	      documentVersionId: r.document_version_id as string,
   140	      provider: r.provider as string,
   141	      status: r.status as string,
   142	      createdAt: r.created_at as string,
   143	    }));
   144	  }),
   145	
   146	  /** Read one of the client's own requests. */
   147	  getSignatureRequest: clientProcedure
   148	    .input(z.object({ requestId: z.string().uuid() }))
   149	    .query(async ({ ctx, input }) => {
   150	      const db = createSupabaseServiceRole();
   151	      const { data, error } = await db
   152	        .from("signature_request")
   153	        .select(
   154	          "id, document_version_id, provider, status, accepted_at, acceptance_method, created_at"
   155	        )
   156	        .eq("id", input.requestId)
   157	        .eq("client_id", ctx.clientId)
   158	        .single();
   159	      if (error || !data) {
   160	        throw new TRPCError({ code: "NOT_FOUND", message: "Richiesta non trovata." });
   161	      }
   162	      return data;
   163	    }),
   164	
   165	  /**
   166	   * The engagement-letter document for one of the client's OWN requests, readable
   167	   * BEFORE signing (returned regardless of status — that's the point: the in-app
   168	   * SES screen shows it pre-sign). Returns the per-client filled BODY (markdown)
   169	   * for display, NOT a PDF (the signed PDF is downloadSignedDocument, post-sign).
   170	   * Reuses the shared fillEngagementLetter helper — no duplicated placeholder logic.
   171	   * The contentHash is the version the request points at (frozen — a newer
   172	   * published version does not change an existing request's document).
   173	   */
   174	  getSignatureDocument: clientProcedure
   175	    .input(z.object({ requestId: z.string().uuid() }))
   176	    .query(async ({ ctx, input }) => {
   177	      const db = createSupabaseServiceRole();
   178	
   179	      // Scope strictly to the caller; NO status filter (readable pre-sign).
   180	      const { data: req, error: reqErr } = await db
   181	        .from("signature_request")
   182	        .select("id, status, document_version_id, partner_id")
   183	        .eq("id", input.requestId)
   184	        .eq("client_id", ctx.clientId)
   185	        .single();
   186	      if (reqErr || !req) {
   187	        throw new TRPCError({ code: "NOT_FOUND", message: "Richiesta non trovata." });
   188	      }
   189	
   190	      const { data: version, error: verErr } = await db
   191	        .from("legal_document_version")
   192	        .select(
   193	          "legal_document_id, version_number, version_label, language, body_md, content_hash"
   194	        )
   195	        .eq("id", req.document_version_id)
   196	        .single();
   197	      if (verErr || !version) {
   198	        throw new TRPCError({ code: "NOT_FOUND", message: "Documento non trovato." });
   199	      }
   200	
   201	      const { data: docRow } = await db
   202	        .from("legal_document")
   203	        .select("name")
   204	        .eq("id", version.legal_document_id)
   205	        .single();
   206	      const { data: client } = await db
   207	        .from("client")
   208	        .select("full_name")
   209	        .eq("id", ctx.clientId)
   210	        .single();
   211	      const { data: partner } = await db
   212	        .from("partner")
   213	        .select("full_name")
   214	        .eq("id", req.partner_id)
   215	        .single();
   216	
   217	      const practitionerName = (partner?.full_name as string | undefined) ?? "Roberto Scrigna";
   218	      const patientName = (client?.full_name as string | undefined) ?? "";
   219	
   220	      const generatedDate = new Intl.DateTimeFormat("it-IT", {
   221	        timeZone: "Europe/Rome",
   222	        day: "2-digit",
   223	        month: "2-digit",
   224	        year: "numeric",
   225	      }).format(new Date());
   226	
   227	      // Same shared fill + placeholder-detection as legal.generateEngagementLetter.
   228	      const filled = fillEngagementLetter(version.body_md as string, {
   229	        client_full_name: patientName,
   230	        professional_name: practitionerName,
   231	        generated_date: generatedDate,
   232	      });
   233	
   234	      return {
   235	        requestId: req.id as string,
   236	        status: req.status as string,
   237	        documentName: (docRow?.name as string | undefined) ?? "Lettera di Incarico",
   238	        versionNumber: version.version_number as number,
   239	        versionLabel: (version.version_label as string | null) ?? `v${version.version_number}`,
   240	        language: version.language as string,
   241	        contentHash: version.content_hash as string,
   242	        bodyMd: filled.filledMd,
   243	        practitionerName,
   244	        patientName,
   245	        missingTokens: filled.missingTokens,
   246	        pendingPlaceholders: filled.pendingPlaceholders,
   247	      };
   248	    }),
   249	
   250	  /**
   251	   * Internal SES acceptance: flip the client's own pending request to 'signed'
   252	   * and stamp who/when/method. Only valid when the active provider is internal —
   253	   * external providers handle signing themselves.
   254	   */
   255	  acceptSignature: clientProcedure
   256	    .input(z.object({ requestId: z.string().uuid() }))
   257	    .mutation(async ({ ctx, input }) => {
   258	      if (activeSignatureProviderName() !== "internal") {
   259	        throw new TRPCError({
   260	          code: "PRECONDITION_FAILED",
   261	          message:
   262	            "L'accettazione in-app è disponibile solo con il provider di firma interno.",
   263	        });
   264	      }
   265	      const db = createSupabaseServiceRole();
   266	
   267	      const { data: req, error: reqErr } = await db
   268	        .from("signature_request")
   269	        .select("id, status")
   270	        .eq("id", input.requestId)
   271	        .eq("client_id", ctx.clientId)
   272	        .single();
   273	      if (reqErr || !req) {
   274	        throw new TRPCError({ code: "NOT_FOUND", message: "Richiesta non trovata." });
   275	      }
   276	      if (req.status === "signed") {
   277	        throw new TRPCError({
   278	          code: "PRECONDITION_FAILED",
   279	          message: "Documento già firmato.",
   280	        });
   281	      }
   282	      if (!(OPEN_STATUSES as readonly string[]).includes(req.status as string)) {
   283	        throw new TRPCError({
   284	          code: "PRECONDITION_FAILED",
   285	          message: "Questa richiesta non è firmabile.",
   286	        });
   287	      }
   288	
   289	      const acceptedAt = new Date().toISOString();
   290	      const { data: updated, error: upErr } = await db
   291	        .from("signature_request")
   292	        .update({
   293	          status: "signed",
   294	          accepted_at: acceptedAt,
   295	          accepted_by: ctx.userId,
   296	          acceptance_method: "in_app_ses",
   297	        })
   298	        .eq("id", req.id)
   299	        .eq("client_id", ctx.clientId)
   300	        .select("id, status, accepted_at")
   301	        .single();
   302	      if (upErr || !updated) {
   303	        console.error("[router/signature.acceptSignature]", upErr);
   304	        throw new TRPCError({
   305	          code: "INTERNAL_SERVER_ERROR",
   306	          message: "Errore nella registrazione della firma.",
   307	        });
   308	      }
   309	
   310	      return {
   311	        requestId: req.id as string,
   312	        status: "signed" as const,
   313	        acceptedAt,
   314	        acceptanceMethod: "in_app_ses" as const,
   315	      };
   316	    }),
   317	
   318	  /** Provider status for one of the client's own requests. */
   319	  getSignatureStatus: clientProcedure
   320	    .input(z.object({ requestId: z.string().uuid() }))
   321	    .query(async ({ ctx, input }) => {
   322	      const deps = buildDeps();
   323	      const { data: own } = await deps.db
   324	        .from("signature_request")
   325	        .select("id")
   326	        .eq("id", input.requestId)
   327	        .eq("client_id", ctx.clientId)
   328	        .maybeSingle();
   329	      if (!own?.id) {
   330	        throw new TRPCError({ code: "NOT_FOUND", message: "Richiesta non trovata." });
   331	      }
   332	      return getSignatureProvider(deps).getStatus(input.requestId);
   333	    }),
   334	
   335	  /** Regenerated signed PDF (base64) for one of the client's own signed requests. */
   336	  downloadSignedDocument: clientProcedure
   337	    .input(z.object({ requestId: z.string().uuid() }))
   338	    .mutation(async ({ ctx, input }) => {
   339	      const deps = buildDeps();
   340	      const { data: own } = await deps.db
   341	        .from("signature_request")
   342	        .select("id, status")
   343	        .eq("id", input.requestId)
   344	        .eq("client_id", ctx.clientId)
   345	        .maybeSingle();
   346	      if (!own?.id) {
   347	        throw new TRPCError({ code: "NOT_FOUND", message: "Richiesta non trovata." });
   348	      }
   349	      if (own.status !== "signed") {
   350	        throw new TRPCError({
   351	          code: "PRECONDITION_FAILED",
   352	          message: "Documento non ancora firmato.",
   353	        });
   354	      }
   355	      return resolveSignedPdf(deps, input.requestId);
   356	    }),
   357	
   358	  // ── Coach (partner-scoped) reads — for the engagement-letter management UI ────
   359	
   360	  /**
   361	   * #29 coach — the client's current engagement-letter signing status.
   362	   * PARTNER-SCOPED: the client must belong to ctx.partner (else NOT_FOUND). Reads
   363	   * the LATEST signature_request for that client and collapses provider statuses to
   364	   * { none | pending | signed }. Degrades cleanly to 'none' when no request exists.
   365	   * Contract: { status, requestId?, signedAt?, versionLabel? }.
   366	   */
   367	  getClientLetterStatus: protectedProcedure
   368	    .input(z.object({ clientId: z.string().uuid() }))
   369	    .query(async ({ ctx, input }) => {
   370	      const db = createSupabaseServiceRole();
   371	
   372	      // Partner-scope: the client must belong to this partner (mirrors createSignatureRequest).
   373	      const { data: client } = await db
   374	        .from("client")
   375	        .select("id")
   376	        .eq("id", input.clientId)
   377	        .eq("partner_id", ctx.partnerId)
   378	        .is("deleted_at", null)
   379	        .maybeSingle();
   380	      if (!client?.id) {
   381	        throw new TRPCError({ code: "NOT_FOUND", message: "Cliente non trovato." });
   382	      }
   383	
   384	      // Latest request for this client (any status).
   385	      const { data: req } = await db
   386	        .from("signature_request")
   387	        .select("id, status, accepted_at, document_version_id, created_at")
   388	        .eq("client_id", input.clientId)
   389	        .order("created_at", { ascending: false })
   390	        .limit(1)
   391	        .maybeSingle();
   392	
   393	      if (!req?.id) return { status: "none" as const };
   394	
   395	      // Resolve the version label for display (best-effort).
   396	      let versionLabel: string | undefined;
   397	      if (req.document_version_id) {
   398	        const { data: v } = await db
   399	          .from("legal_document_version")
   400	          .select("version_label")
   401	          .eq("id", req.document_version_id as string)
   402	          .maybeSingle();
   403	        versionLabel = (v?.version_label as string | undefined) ?? undefined;
   404	      }
   405	
   406	      const raw = req.status as string;
   407	      if (raw === "signed") {
   408	        return {
   409	          status: "signed" as const,
   410	          requestId: req.id as string,
   411	          signedAt: (req.accepted_at as string | null) ?? undefined,
   412	          versionLabel,
   413	        };
   414	      }
   415	      if ((OPEN_STATUSES as readonly string[]).includes(raw)) {
   416	        return { status: "pending" as const, requestId: req.id as string, versionLabel };
   417	      }
   418	      // declined / expired / cancelled → no active letter on file
   419	      return { status: "none" as const };
   420	    }),
   421	
   422	  /**
