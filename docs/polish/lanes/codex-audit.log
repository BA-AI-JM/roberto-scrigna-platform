   340	          `<h2 style="margin:0 0 12px;font-size:20px;color:#1a1a2e;">È il momento del check-in!</h2>
   341	<p style="margin:0 0 16px;font-size:14px;color:#374151;line-height:1.6;">
   342	  Ciao ${clientName},<br/>
   343	  è arrivato il momento del tuo check-in settimanale. Registra il tuo peso e le tue sensazioni per aiutare il tuo coach a ottimizzare il piano.
   344	</p>
   345	<p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">
   346	  Il link è valido per 7 giorni.
   347	</p>
   348	${btnHtml(checkinLink, "Inizia il check-in")}`
   349	        );
   350	        await sendEmail(email, "È il momento del check-in settimanale", html);
   351	      }
   352	    });
   353	
   354	    // N5: Wait 5 days, then check if completed
   355	    await step.sleep("wait-5d", "5d");
   356	
   357	    const isCompleted = await step.run("check-if-completed", async () => {
   358	      const db = getServiceDb();
   359	      const { data } = await db
   360	        .from("check_in")
   361	        .select("status")
   362	        .eq("id", checkinId)
   363	        .single();
   364	      return data?.status === "completed" || data?.status === "reviewed";
   365	    });
   366	
   367	    if (!isCompleted) {
   368	      await step.run("notify-checkin-overdue", async () => {
   369	        await createNotification({
   370	          partnerId,
   371	          clientId,
   372	          trigger: "checkin_overdue",
   373	          title: `⚠️ Check-in scaduto — ${clientName}`,
   374	          body: `Il check-in è scaduto da 5 giorni. Nessuna risposta ricevuta.`,
   375	          metadata: { checkinId, overdueDays: 5 },
   376	        });
   377	      });
   378	
   379	      // Second escalation after 10 days total
   380	      await step.sleep("wait-5d-more", "5d");
   381	
   382	      const stillPending = await step.run("check-if-still-pending", async () => {
   383	        const db = getServiceDb();
   384	        const { data } = await db
   385	          .from("check_in")
   386	          .select("status")
   387	          .eq("id", checkinId)
   388	          .single();
   389	        return data?.status === "pending";
   390	      });
   391	
   392	      if (stillPending) {
   393	        await step.run("escalate-checkin-overdue", async () => {
   394	          await createNotification({
   395	            partnerId,
   396	            clientId,
   397	            trigger: "checkin_overdue",
   398	            title: `🚨 Check-in non completato — ${clientName}`,
   399	            body: `Secondo sollecito: il check-in è scaduto da 10 giorni.`,
   400	            metadata: { checkinId, overdueDays: 10, escalated: true },
   401	          });
   402	
   403	          await createTask({
   404	            partnerId,
   405	            clientId,
   406	            title: `Follow-up check-in mancato — ${clientName}`,
   407	            description: `Il check-in è scaduto da 10 giorni. Contattare il cliente direttamente.`,
   408	            priority: "high",
   409	          });
   410	        });
   411	      }
   412	    }
   413	  }
   414	);
