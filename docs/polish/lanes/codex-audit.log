   136	const TRIGGER_PRIORITY: Record<string, string> = {
   137	  checkin_overdue: "high",
   138	  checkin_completed: "low",
   139	  weight_deviation: "urgent",
   140	  low_adherence: "medium",
   141	  plan_expiring: "medium",
   142	  invoice_overdue: "high",
   143	  invoice_paid: "low",
   144	  task_due_today: "medium",
   145	  task_overdue: "high",
   146	  new_message: "medium",
   147	  training_logged: "low",
