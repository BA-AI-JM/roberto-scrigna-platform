   174	  training_intense: "Allenamento Intenso",
   175	  training_double: "Doppia Seduta",
   176	} as const;
   177	
   178	// ── Pipeline Implementation ─────────────────────────────────────────────────
   179	
   180	/**
   181	 * Determine energy balance from weekly average vs maintenance estimate.
   182	 */
   183	function determineEnergyBalance(
   184	  weeklyAverageKcal: number,
   185	  maintenanceEstimate: number
   186	): "deficit" | "surplus" | "maintenance" {
   187	  const diff = weeklyAverageKcal - maintenanceEstimate;
   188	  if (Math.abs(diff) <= 50) return "maintenance";
   189	  if (diff < 0) return "deficit";
   190	  return "surplus";
   191	}
   192	
   193	/**
   194	 * Collect assumptions made during plan generation.
   195	 */
   196	function collectAssumptions(input: PlanGenerationInput): string[] {
   197	  const assumptions: string[] = [];
   198	  const { snapshot } = input;
   199	
   200	  // Body fat method
   201	  if (snapshot.skinfold7) {
   202	    assumptions.push(
   203	      "Grasso corporeo stimato con il metodo Jackson & Pollock 7 pliche (gold standard)."
   204	    );
   205	  } else if (snapshot.skinfold3) {
   206	    assumptions.push(
   207	      "Grasso corporeo stimato con il metodo Jackson & Pollock 3 pliche (buona affidabilità)."
   208	    );
   209	  } else if (snapshot.bodyFatPctOverride) {
   210	    assumptions.push(
   211	      "Grasso corporeo basato su stima visiva/plicometro — precisione limitata (±3-5%)."
   212	    );
   213	  } else {
   214	    assumptions.push(
   215	      "Grasso corporeo stimato con formula euristica basata su BMI — precisione limitata. Si consiglia una plicometria per maggiore accuratezza."
   216	    );
   217	  }
   218	
   219	  // Steps
   220	  if (snapshot.dailySteps < 3000) {
   221	    assumptions.push(
   222	      `Il NEAT è calcolato su ${snapshot.dailySteps} passi/giorno — un aumento graduale a 8.000-10.000 passi migliorerebbe significativamente il dispendio energetico.`
   223	    );
   224	  }
   225	
   226	  // Exercise method
   227	  const ts = input.engineOptions?.trainingSession;
   228	  if (ts?.method === "met_value" && ts.metValue != null) {
   229	    assumptions.push(
   230	      `Il dispendio dell'esercizio dei giorni di allenamento è stimato con i valori MET delle sessioni inserite (durata media ~${Math.round(
   231	        ts.durationMin
   232	      )} min, MET medio ~${ts.metValue}). I dati di frequenza cardiaca o a zone (Sport Correction Protocol) ne migliorerebbero la precisione.`
   233	    );
   234	  } else if (ts?.method === "heart_rate" || ts?.avgHeartRate != null || ts?.scpData != null) {
   235	    // HR / SCP path — no extra caveat needed here.
   236	  } else {
   237	    assumptions.push(
   238	      "Il dispendio dell'esercizio dei giorni di allenamento usa una stima predefinita (nessuna sessione di allenamento inserita per il cliente). Inserire le sessioni nel profilo migliorerebbe la precisione."
   239	    );
   240	  }
   241	
   242	  // Deficit / surplus override from the goal-rate calculator
   243	  const deficit = input.engineOptions?.dailyDeficitKcal;
   244	  if (deficit != null && deficit !== 0) {
   245	    if (deficit > 0) {
   246	      assumptions.push(
   247	        `L'apporto pianificato è impostato con un deficit di ${Math.round(deficit)} kcal/giorno rispetto al TDEE — derivato dall'obiettivo di peso e dalla data target.`
   248	      );
   249	    } else {
   250	      assumptions.push(
   251	        `L'apporto pianificato è impostato con un surplus di ${Math.abs(Math.round(deficit))} kcal/giorno rispetto al TDEE — derivato dall'obiettivo di peso e dalla data target.`
   252	      );
   253	    }
   254	  }
   255	
   256	  // Per-day training override (Struttura del piano wizard) — provenance so
   257	  // the review page shows the activity wasn't the intake average.
   258	  const perDay = input.engineOptions?.perDayTrainingSession;
   259	  if (perDay && perDay.some((s) => s != null)) {
   260	    const n = perDay.filter((s) => s != null).length;
   261	    assumptions.push(
   262	      `L'attività è stata impostata manualmente per ${n} ${
   263	        n === 1 ? "giorno" : "giorni"
   264	      } della settimana (anziché usare la media delle sessioni di intake).`
   265	    );
   266	  }
   267	
   268	  // Absolute macro overrides (Macro per giorno wizard) — make manual pins
   269	  // visible on the review page rather than passing silently.
   270	  const macroOv = input.engineOptions?.macroOptions?.absoluteOverrides;
   271	  if (macroOv) {
   272	    const dayTypeIt: Record<string, string> = {
   273	      training: "allenamento",
   274	      rest: "riposo",
   275	      refeed: "ricarica",
   276	      deload: "scarico",
   277	    };
   278	    const pinned: string[] = [];
   279	    for (const [dt, ov] of Object.entries(macroOv)) {
   280	      if (!ov) continue;
   281	      const parts: string[] = [];
   282	      if (ov.proteinG != null) parts.push(`P ${ov.proteinG}g`);
   283	      if (ov.fatG != null) parts.push(`G ${ov.fatG}g`);
   284	      if (ov.carbG != null) parts.push(`C ${ov.carbG}g`);
   285	      if (parts.length > 0) {
   286	        pinned.push(`${dayTypeIt[dt] ?? dt} (${parts.join(" · ")})`);
   287	      }
   288	    }
   289	    if (pinned.length > 0) {
   290	      assumptions.push(
   291	        `Macro impostate manualmente su: ${pinned.join("; ")} — gli altri valori seguono le formule automatiche.`
   292	      );
   293	    }
   294	  }
   295	
   296	  // #26 injury/stress adaptation provenance.
   297	  const inj = input.injuryStress;
   298	  if (inj && (inj.stressFactor != null || inj.injuryProteinBumpGPerKg != null || inj.reducedActivitySteps != null)) {
   299	    const parts: string[] = [];
   300	    if (inj.stressFactor != null && inj.stressFactor !== 1) {
   301	      parts.push(`fattore stress ${inj.stressFactor}× sul TDEE`);
   302	    }
   303	    if (inj.injuryProteinBumpGPerKg != null && inj.injuryProteinBumpGPerKg !== 0) {
   304	      parts.push(`+${inj.injuryProteinBumpGPerKg} g/kg di proteine (recupero infortunio)`);
   305	    }
   306	    if (inj.reducedActivitySteps != null) {
   307	      parts.push(`passi ridotti a ${inj.reducedActivitySteps}/giorno (NEAT ridotto)`);
   308	    }
   309	    if (parts.length > 0) {
   310	      assumptions.push(`Adattamento infortunio/stress: ${parts.join("; ")}.`);
   311	    }
   312	  }
   313	
   314	  return assumptions;
   315	}
