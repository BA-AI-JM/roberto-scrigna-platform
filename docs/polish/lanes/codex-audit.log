     1	/**
     2	 * Legal Router — engagement-letter generation + versioned templates (Req #29, Stage 1).
     3	 *
     4	 * #29 is Tier 2: the app GENERATES + VERSIONS the engagement letter; the binding
     5	 * SIGNATURE is delegated to an eIDAS e-signature provider in Stage 2 (contract in
     6	 * src/server/esign/provider.ts). This router does NOT implement any signing,
     7	 * acceptance, audit or consent logic — only template versioning + letter generation.
     8	 *
     9	 * Procedures (all partner-scoped — protectedProcedure, RLS-bound via ctx.supabase):
    10	 * - createVersion               publish a new engagement-letter template version
    11	 * - seedDefaultEngagementLetter idempotently publish v1 from the IT-03 template
    12	 * - getActiveVersion            the partner's current active template version
    13	 * - generateEngagementLetter    fill the active template for a client → PDF (preview)
    14	 */
    15	
    16	import { z } from "zod/v4";
    17	import { TRPCError } from "@trpc/server";
    18	import { router, protectedProcedure } from "../trpc";
    19	import type { createSupabaseServer } from "../../lib/supabase/server";
    20	import { hashDocumentBody, ENGAGEMENT_LETTER_IT } from "../legal-templates";
    21	import { fillEngagementLetter } from "../legal-letter";
    22	import { generateEngagementLetterPdf } from "../legal-letter-pdf";
    23	import { renderEngagementLetterHtml } from "../../pdf/engagement-letter-renderer";
    24	
    25	// The RLS-bound server client carried on ctx.supabase (no generated DB types in this repo).
    26	type Db = Awaited<ReturnType<typeof createSupabaseServer>>;
    27	
    28	// ── Publish helper (shared by createVersion + seed) ─────────────────────────────
    29	
    30	interface PublishInput {
    31	  docKind: "engagement_letter";
    32	  name: string;
    33	  bodyMd: string;
    34	  versionLabel?: string;
    35	  language: string;
    36	}
    37	
    38	interface PublishResult {
    39	  documentId: string;
    40	  versionId: string;
    41	  versionNumber: number;
    42	  versionLabel: string | null;
    43	  contentHash: string;
    44	  status: string;
    45	}
    46	
    47	/**
    48	 * Find-or-create the partner's legal_document for a kind, then publish a new
    49	 * version: bump version_number, archive prior active versions to 'replaced'
    50	 * (never overwrite content), insert the new active version with a SHA-256 hash.
    51	 */
    52	async function publishVersion(
    53	  db: Db,
    54	  partnerId: string,
    55	  input: PublishInput
    56	): Promise<PublishResult> {
    57	  const { data: existingDoc, error: findErr } = await db
    58	    .from("legal_document")
    59	    .select("id")
    60	    .eq("partner_id", partnerId)
    61	    .eq("doc_kind", input.docKind)
    62	    .maybeSingle();
    63	  if (findErr) {
    64	    console.error("[router/legal.publishVersion:findDoc]", findErr);
    65	    throw new TRPCError({
    66	      code: "INTERNAL_SERVER_ERROR",
    67	      message: "Errore nel recupero del documento legale.",
    68	    });
    69	  }
    70	
    71	  let documentId = existingDoc?.id as string | undefined;
    72	  if (!documentId) {
    73	    const { data: newDoc, error: insDocErr } = await db
    74	      .from("legal_document")
    75	      .insert({ partner_id: partnerId, doc_kind: input.docKind, name: input.name })
    76	      .select("id")
    77	      .single();
    78	    if (insDocErr || !newDoc) {
    79	      console.error("[router/legal.publishVersion:createDoc]", insDocErr);
    80	      throw new TRPCError({
    81	        code: "INTERNAL_SERVER_ERROR",
    82	        message: "Errore nella creazione del documento legale.",
    83	      });
    84	    }
    85	    documentId = newDoc.id as string;
    86	  }
    87	
    88	  const { data: latest, error: latestErr } = await db
    89	    .from("legal_document_version")
    90	    .select("version_number")
