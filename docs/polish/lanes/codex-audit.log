   397	  // ── Step 5: Supplement protocol ────────────────────────────────────────
   398	  // #23: NEW plans seed ZERO supplements (Roberto's explicit default — no auto-
   399	  // assignment). The coach curates supplements from the static library and they
   400	  // live in the plan bundle. The opt-in `supplementOverrides` path is preserved;
   401	  // generateSupplementProtocol/checkSupplementInteractions remain in the service
   402	  // for that path and future use.
   403	  const supplements: SupplementEntry[] = input.supplementOverrides ?? [];
