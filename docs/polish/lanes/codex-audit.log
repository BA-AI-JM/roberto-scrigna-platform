     5	
     6	import { initTRPC, TRPCError } from "@trpc/server";
     7	import superjson from "superjson";
     8	import { createSupabaseServer } from "../lib/supabase/server";
     9	import { createSupabaseServiceRole } from "../lib/supabase/service";
    10	
    11	/** tRPC context — available in all procedures */
    12	export interface TrpcContext {
    13	  /** Supabase client (always available) */
    14	  supabase: Awaited<ReturnType<typeof createSupabaseServer>>;
    15	  /** Authenticated user ID (null if not logged in) */
    16	  userId: string | null;
    17	  /** Partner record ID (null if not a partner) */
    18	  partnerId: string | null;
    19	  /** Client record ID (null if not a client portal user) */
    20	  clientId: string | null;
    21	  /** Incoming request headers — used for IP extraction in rate limiting */
    22	  headers: Headers | null;
    23	}
    24	
    25	/**
    26	 * Create the tRPC context for each request.
    27	 * Identifies both partner and client users from the session.
    28	 *
    29	 * Accepts an optional fetch `Request` so the raw headers are available
    30	 * inside procedure bodies (e.g. for rate limiting via x-forwarded-for).
    31	 */
    32	export async function createTrpcContext(opts?: {
    33	  req?: Request;
    34	}): Promise<TrpcContext> {
    35	  const supabase = await createSupabaseServer();
    36	  const {
    37	    data: { user },
    38	  } = await supabase.auth.getUser();
    39	
    40	  let partnerId: string | null = null;
    41	  let clientId: string | null = null;
    42	
    43	  if (user) {
    44	    // Check partner first (anon client + session, partner RLS allows self-read)
    45	    const { data: partner } = await supabase
    46	      .from("partner")
    47	      .select("id")
    48	      .eq("auth_user_id", user.id)
    49	      .maybeSingle();
    50	    partnerId = partner?.id ?? null;
    51	
    52	    // If not a partner, check client table using service role (no client RLS policies).
    53	    // Only active, non-deleted clients are granted portal access.
    54	    if (!partnerId) {
    55	      const serviceDb = createSupabaseServiceRole();
    56	      const { data: client } = await serviceDb
    57	        .from("client")
    58	        .select("id")
    59	        .eq("auth_user_id", user.id)
    60	        .eq("status", "active")
    61	        .is("deleted_at", null)
    62	        .maybeSingle();
    63	      clientId = client?.id ?? null;
    64	    }
    65	  }
    66	
    67	  return {
    68	    supabase,
    69	    userId: user?.id ?? null,
    70	    partnerId,
    71	    clientId,
    72	    headers: opts?.req?.headers ?? null,
    73	  };
    74	}
