   382	    const mealPlan = createMealPlan(ALL_TEMPLATES, config);
   383	    mealPlans.set(dayType, mealPlan);
   384	  }
   385	
   386	  // ── Water loading (#11) — a fluid schedule, not a macro change ──────────
   387	  const waterLoading: WaterLoadingSchedule | undefined = input.protocols?.waterLoading
   388	    ? waterLoadingSchedule(snapshot.weightKg)
