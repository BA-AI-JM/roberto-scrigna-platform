   417	      `Target non pienamente raggiungibile per «${DAY_TYPE_LABELS[day.dayType]}»: proteine e grassi da soli superano le kcal target, carboidrati azzerati e kcal oltre di ~${Math.round(
   418	        day.macros.carbFloorKcalOver ?? 0
   419	      )}. Ridurre proteine/grassi o aumentare le kcal per rispettare il deficit.`
   420	    );
   421	  }
   422	
   423	  // ── Step 7: Narrative generation ───────────────────────────────────────
   424	  const narrativeCtx: NarrativeContext = {
   425	    snapshot,
   426	    bodyComposition,
   427	    weeklyPlan,
   428	    allenamento: input.allenamento,
   429	    stileVita: input.stileVita,
   430	    obiettivo: input.obiettivo,
   431	    energyBalance,
