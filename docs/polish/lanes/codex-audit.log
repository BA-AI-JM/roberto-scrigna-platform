   397	// ── Shared plan-artifact builder (generate + createVersion) ──────────────────
   398	
   399	/** Generation parameters recoverable from wizard input or a stored plan's macro_payload. */
   400	interface PlanGenParams {
   401	  mealCount: number;
   402	  excludeAllergens?: string[];
   403	  preferTags?: string[];
   404	  maintenanceKcalEstimate?: number;
   405	  dailyDeficitKcal?: number;
   406	  goalOverride?: Record<string, unknown>;
   407	  weekScheduleOverride?: unknown;
   408	  /** #17 periodization mode label (replay/audit only; engine doesn't branch on it). */
   409	  periodizationMode?: string;
   410	  /** Raw per-weekday training-session arrays (as stored on macro_payload / wizard input). */
   411	  perDayTrainingSession?: (IntakeTrainingSession[] | null)[];
   412	  macroOverrides?: Partial<Record<DayType, { proteinG?: number; fatG?: number; carbG?: number }>>;
   413	  /** #11 combat-sport protocols (fibre/sodium restriction + water loading). */
   414	  protocols?: { fibreRestriction?: boolean; sodiumRestriction?: boolean; waterLoading?: boolean };
   415	  /** #16b coach source pins (per day-type → category → foodId). */
   416	  sourcePins?: Partial<Record<DayType, SourcePin>>;
   417	  /** #26 injury/stress adaptation (opt-in; absent = byte-identical). */
   418	  injuryStress?: InjuryStressSpec;
   419	}
   420	
   421	interface PlanArtifacts {
   422	  serialized: ReturnType<typeof serializePlanResult>;
   423	  macroPayload: Record<string, unknown>;
   424	  weeklyAverageKcal: number;
   425	  energyBalance: string;
   426	}
   427	
   428	/**
   429	 * Run the engine for a snapshot + generation params and produce the persisted
   430	 * artifacts (serialized bundle + macro_payload summary). Pure w.r.t. the DB: the
   431	 * caller fetches the snapshot/client and persists the result. Shared by
   432	 * `generate` (params from the wizard) and `createVersion` (params recovered from
   433	 * the source plan's macro_payload, re-run against the latest snapshot). Throws
   434	 * the raw engine error; callers translate to a TRPCError.
   435	 */
   436	function buildPlanArtifacts(
   437	  snapshotRecord: Record<string, unknown>,
   438	  clientSex: "male" | "female",
   439	  clientInfo: PdfClientInfo,
   440	  params: PlanGenParams
   441	): PlanArtifacts {
   442	  const snapshotBase = buildEngineSnapshot(snapshotRecord, clientSex);
   443	  const snapshot: ClientSnapshot = params.weekScheduleOverride
   444	    ? { ...snapshotBase, weekSchedule: params.weekScheduleOverride as ClientSnapshot["weekSchedule"] }
   445	    : snapshotBase;
   446	
   447	  const trainingSession = buildTrainingSessionFromIntake(
   448	    intakeTrainingSessions(snapshotRecord),
   449	    snapshot.weekSchedule
   450	  );
   451	  const perDayTrainingSession =
   452	    params.perDayTrainingSession?.map((daySessions) =>
   453	      buildTrainingSessionForDay(daySessions ?? null)
   454	    ) ?? undefined;
   455	
   456	  const engineOptions: PlanGenerationInput["engineOptions"] = {};
   457	  if (trainingSession) engineOptions.trainingSession = trainingSession;
   458	  if (params.dailyDeficitKcal != null && params.dailyDeficitKcal !== 0) {
   459	    engineOptions.dailyDeficitKcal = params.dailyDeficitKcal;
   460	  }
   461	  if (perDayTrainingSession && perDayTrainingSession.some((s) => s != null)) {
   462	    engineOptions.perDayTrainingSession = perDayTrainingSession;
   463	  }
   464	  if (params.macroOverrides) {
   465	    const cleaned: NonNullable<typeof params.macroOverrides> = {};
   466	    for (const [dt, override] of Object.entries(params.macroOverrides) as Array<
   467	      [DayType, { proteinG?: number; fatG?: number; carbG?: number } | undefined]
   468	    >) {
   469	      if (override && (override.proteinG != null || override.fatG != null || override.carbG != null)) {
   470	        cleaned[dt] = override;
   471	      }
   472	    }
   473	    if (Object.keys(cleaned).length > 0) {
   474	      engineOptions.macroOptions = { absoluteOverrides: cleaned };
   475	    }
   476	  }
   477	
   478	  const genInput: PlanGenerationInput = {
   479	    clientInfo,
   480	    snapshot,
   481	    mealCount: params.mealCount,
   482	    excludeAllergens: params.excludeAllergens as PlanGenerationInput["excludeAllergens"],
   483	    preferTags: params.preferTags as PlanGenerationInput["preferTags"],
   484	    maintenanceKcalEstimate: params.maintenanceKcalEstimate,
   485	    ...(Object.keys(engineOptions).length > 0 ? { engineOptions } : {}),
   486	    ...(params.protocols ? { protocols: params.protocols } : {}),
   487	    ...(params.sourcePins ? { sourcePins: params.sourcePins } : {}),
   488	    ...(params.injuryStress ? { injuryStress: params.injuryStress } : {}),
   489	  };
   490	
   491	  const result = generatePlan(genInput);
   492	  const serialized = serializePlanResult(result);
   493	
   494	  const uniqueDayTypes = [...new Set(snapshot.weekSchedule)];
   495	  const macroPayload: Record<string, unknown> = {
   496	    weeklyAverageKcal: result.weeklyPlan.weeklyAverageKcal,
   497	    weeklyAverageProteinG: result.weeklyPlan.weeklyAverageProteinG,
   498	    dayTypes: uniqueDayTypes,
   499	    energyBalance: result.energyBalance,
   500	    ...(params.dailyDeficitKcal != null ? { dailyDeficitKcal: params.dailyDeficitKcal } : {}),
   501	    ...(params.goalOverride ? { goalOverride: params.goalOverride } : {}),
   502	    ...(params.weekScheduleOverride ? { weekScheduleOverride: params.weekScheduleOverride } : {}),
   503	    ...(params.periodizationMode ? { periodizationMode: params.periodizationMode } : {}),
   504	    ...(params.perDayTrainingSession ? { perDayTrainingSessionRaw: params.perDayTrainingSession } : {}),
   505	    ...(params.macroOverrides ? { macroOverrides: params.macroOverrides } : {}),
   506	    ...(params.excludeAllergens ? { excludeAllergens: params.excludeAllergens } : {}),
   507	    ...(params.preferTags ? { preferTags: params.preferTags } : {}),
   508	    ...(params.protocols ? { protocols: params.protocols } : {}),
   509	    ...(params.sourcePins ? { sourcePins: params.sourcePins } : {}),
   510	    ...(params.injuryStress ? { injuryStress: params.injuryStress } : {}),
   511	    ...(result.waterLoading ? { waterLoading: result.waterLoading } : {}),
   512	  };
   513	
   514	  return {
   515	    serialized,
   516	    macroPayload,
   517	    weeklyAverageKcal: result.weeklyPlan.weeklyAverageKcal,
   518	    energyBalance: result.energyBalance as string,
   519	  };
   520	}
