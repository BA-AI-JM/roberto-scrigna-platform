    98	// ── Helpers ─────────────────────────────────────────────────────────────────
    99	
   100	/**
   101	 * Compute weeks between two dates. Returns 0 for past or invalid dates.
   102	 * Caller-friendly: accepts either an ISO string or a Date.
   103	 */
   104	export function weeksUntil(
   105	  targetDate: string | Date,
   106	  from: string | Date = new Date()
   107	): number {
   108	  const target = typeof targetDate === "string" ? new Date(targetDate) : targetDate;
   109	  const fromD = typeof from === "string" ? new Date(from) : from;
   110	  if (Number.isNaN(target.getTime()) || Number.isNaN(fromD.getTime())) return 0;
   111	  const ms = target.getTime() - fromD.getTime();
   112	  if (ms <= 0) return 0;
   113	  return ms / (1000 * 60 * 60 * 24 * 7);
   114	}
   115	
   116	function bandFromPercentBw(
   117	  direction: GoalDirection,
   118	  percentBwPerWeek: number
   119	): AggressivenessBand {
   120	  if (direction === "maintenance") return "comfortable";
   121	  const ladder = direction === "muscle_gain" ? BANDS_MUSCLE_GAIN : BANDS_FAT_LOSS;
   122	  for (const { band, max } of ladder) {
   123	    if (percentBwPerWeek <= max) return band;
   124	  }
   125	  return "extreme";
   126	}
   127	
   128	function bumpBand(band: AggressivenessBand): AggressivenessBand {
   129	  if (band === "comfortable") return "moderate";
   130	  if (band === "moderate") return "aggressive";
   131	  if (band === "aggressive") return "extreme";
   132	  return "extreme";
   133	}
