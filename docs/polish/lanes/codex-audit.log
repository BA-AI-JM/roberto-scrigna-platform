   682	-- ── Updated At Trigger ────────────────────────────────────────────────────────
   683	
   684	CREATE OR REPLACE FUNCTION update_updated_at()
   685	RETURNS TRIGGER AS $$
   686	BEGIN
   687	  NEW.updated_at = now();
   688	  RETURN NEW;
   689	END;
   690	$$ LANGUAGE plpgsql;
   691	
   692	-- Apply to all tables with updated_at
   693	DO $$
   694	DECLARE
   695	  tbl TEXT;
   696	BEGIN
   697	  FOR tbl IN
   698	    SELECT unnest(ARRAY[
   699	      'partner', 'client', 'client_snapshot', 'plan', 'training_log',
   700	      'check_in', 'supplement_protocol', 'supplement_item', 'guidance_block',
   701	      'document', 'invoice', 'notification_settings', 'task',
   702	      'diary_entry', 'example_meal'
   703	    ])
   704	  LOOP
   705	    EXECUTE format(
   706	      'CREATE TRIGGER trg_%s_updated_at BEFORE UPDATE ON %I FOR EACH ROW EXECUTE FUNCTION update_updated_at()',
   707	      tbl, tbl
   708	    );
   709	  END LOOP;
   710	END;
   711	$$;

