supabase/migrations/008_plan_update_suggested_trigger.sql
     1	-- 008_plan_update_suggested_trigger.sql
     2	-- #25 Stage A: allow the 'plan_update_suggested' notification trigger.
     3	--
     4	-- The plan-update heuristic (weight-change → suggest regenerate) emits a
     5	-- COACH-SCOPED notification (client_id = NULL) suggesting the coach regenerate
     6	-- a plan after a client loses ≥10% bodyweight. This adds the new trigger value
     7	-- to the notification.trigger CHECK constraint. PROMPT LAYER ONLY — no plan is
     8	-- ever mutated by this feature; the coach applies it via the existing #24
     9	-- createVersion flow.
    10	--
    11	-- Idempotent (mirrors 006): DROP ... IF EXISTS then re-CREATE the constraint
    12	-- with the full value list (all existing triggers + the new one), so re-running
    13	-- is a no-op.
    14	
    15	ALTER TABLE notification DROP CONSTRAINT IF EXISTS notification_trigger_check;
    16	ALTER TABLE notification ADD CONSTRAINT notification_trigger_check CHECK (trigger IN (
    17	  'checkin_overdue', 'checkin_completed', 'weight_deviation', 'low_adherence',
    18	  'plan_expiring', 'invoice_overdue', 'invoice_paid',
    19	  'task_due_today', 'task_overdue', 'new_message',
    20	  'training_logged', 'milestone_reached',
    21	  'feedback_requested',
    22	  'plan_update_suggested'
    23	));
supabase/migrations/009_legal_documents.sql
     1	-- 009_legal_documents.sql
     2	-- Requirement #29 (Legal & GDPR compliance) — Stage 1: VERSIONED engagement-letter
     3	-- template store. #29 is Tier 2 — the app generates + versions the letter; the
     4	-- binding SIGNATURE is delegated to an eIDAS e-signature provider in Stage 2
     5	-- (a signature_request table lands in that migration, NOT here).
     6	--
     7	-- This migration intentionally contains ONLY the versioned document store:
     8	-- NO acceptance/audit table, NO storage bucket, NO consent/Tessera tables.
     9	--
    10	-- APPLY STANDALONE (Supabase SQL Editor or psql), NOT via the dev db:migrate
    11	-- runner. Fully idempotent (CREATE ... IF NOT EXISTS / CREATE OR REPLACE /
    12	-- DROP ... IF EXISTS). Re-running the file is a no-op.
    13	--
    14	-- Immutability (KB §2 "previously accepted/published documents must never be
    15	-- overwritten"): a legal_document_version row's CONTENT is never rewritten — a
    16	-- new version is a NEW row. No updated_at column; not added to the 001 updated_at
    17	-- trigger array; no deleted_at. `status` may transition active -> replaced/archived
    18	-- (a lifecycle flag), and a BEFORE UPDATE trigger enforces that ONLY status may
    19	-- change — content columns are frozen even against a partner's own RLS-scoped writes.
    20	
    21	-- ── legal_document (one container per partner per doc_kind) ───────────────────
    22	CREATE TABLE IF NOT EXISTS legal_document (
    23	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    24	  partner_id UUID NOT NULL REFERENCES partner(id),
    25	  doc_kind TEXT NOT NULL CHECK (doc_kind IN ('engagement_letter', 'privacy_notice', 'health_consent')),
    26	  name TEXT NOT NULL,
    27	  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    28	  UNIQUE (partner_id, doc_kind)
    29	);
    30	
    31	CREATE INDEX IF NOT EXISTS idx_legal_document_partner ON legal_document(partner_id);
    32	
    33	-- ── legal_document_version (immutable, versioned) ────────────────────────────
    34	CREATE TABLE IF NOT EXISTS legal_document_version (
    35	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    36	  legal_document_id UUID NOT NULL REFERENCES legal_document(id),
    37	  version_number INTEGER NOT NULL,
    38	  version_label TEXT,
    39	  language TEXT NOT NULL DEFAULT 'it',
    40	  body_md TEXT NOT NULL,
    41	  content_hash TEXT NOT NULL,       -- sha256(body_md), computed in the app
    42	  status TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'archived', 'replaced')),
    43	  published_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    44	  UNIQUE (legal_document_id, version_number)
    45	);
    46	
    47	CREATE INDEX IF NOT EXISTS idx_legal_document_version_doc ON legal_document_version(legal_document_id);
    48	CREATE INDEX IF NOT EXISTS idx_legal_document_version_active ON legal_document_version(legal_document_id) WHERE status = 'active';
    49	
    50	-- ── Immutability guard: legal_document_version content is frozen ──────────────
    51	-- RLS grants partners UPDATE (needed for the active -> replaced status flip when
    52	-- publishing a new version), but the document CONTENT must never be rewritten.
    53	-- This trigger rejects any change to content columns; only `status` may change.
    54	CREATE OR REPLACE FUNCTION legal_document_version_freeze()
    55	RETURNS TRIGGER AS $$
    56	BEGIN
    57	  IF NEW.body_md IS DISTINCT FROM OLD.body_md
    58	     OR NEW.content_hash IS DISTINCT FROM OLD.content_hash
    59	     OR NEW.version_number IS DISTINCT FROM OLD.version_number
    60	     OR NEW.legal_document_id IS DISTINCT FROM OLD.legal_document_id
    61	     OR NEW.language IS DISTINCT FROM OLD.language
    62	     OR NEW.version_label IS DISTINCT FROM OLD.version_label
    63	     OR NEW.published_at IS DISTINCT FROM OLD.published_at THEN
    64	    RAISE EXCEPTION 'legal_document_version content is immutable; only status may change';
    65	  END IF;
    66	  RETURN NEW;
    67	END;
    68	$$ LANGUAGE plpgsql;
    69	
    70	DROP TRIGGER IF EXISTS trg_legal_document_version_freeze ON legal_document_version;
    71	CREATE TRIGGER trg_legal_document_version_freeze
    72	  BEFORE UPDATE ON legal_document_version
    73	  FOR EACH ROW EXECUTE FUNCTION legal_document_version_freeze();
    74	
    75	-- ── RLS ──────────────────────────────────────────────────────────────────────
    76	ALTER TABLE legal_document ENABLE ROW LEVEL SECURITY;
    77	ALTER TABLE legal_document_version ENABLE ROW LEVEL SECURITY;
    78	
    79	-- Partner-full (mirrors document_partner_access, 001:627). FOR ALL USING also
    80	-- gates INSERT/UPDATE — Postgres reuses the USING expression as WITH CHECK when
    81	-- none is given, exactly as the existing partner-table policies rely on. The
    82	-- freeze trigger constrains what an UPDATE may actually change.
    83	DROP POLICY IF EXISTS legal_document_partner_access ON legal_document;
    84	CREATE POLICY legal_document_partner_access ON legal_document
    85	  FOR ALL USING (
    86	    partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
    87	  );
    88	
    89	DROP POLICY IF EXISTS legal_document_version_partner_access ON legal_document_version;
    90	CREATE POLICY legal_document_version_partner_access ON legal_document_version
    91	  FOR ALL USING (
    92	    legal_document_id IN (
    93	      SELECT id FROM legal_document
    94	      WHERE partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
    95	    )
    96	  );
    97	
    98	-- Client read-own (mirrors client_media_client_read, 002:56) — the in-scope
    99	-- client may read their professional's published template (e.g. to view the
   100	-- letter before signing). Defence-in-depth; the runtime path uses service role.
   101	DROP POLICY IF EXISTS legal_document_client_read ON legal_document;
   102	CREATE POLICY legal_document_client_read ON legal_document
   103	  FOR SELECT TO authenticated
   104	  USING (
   105	    partner_id IN (SELECT partner_id FROM client WHERE auth_user_id = auth.uid())
   106	  );
   107	
   108	DROP POLICY IF EXISTS legal_document_version_client_read ON legal_document_version;
   109	CREATE POLICY legal_document_version_client_read ON legal_document_version
   110	  FOR SELECT TO authenticated
   111	  USING (
   112	    legal_document_id IN (
   113	      SELECT ld.id FROM legal_document ld
   114	      JOIN client c ON c.partner_id = ld.partner_id
   115	      WHERE c.auth_user_id = auth.uid()
   116	    )
   117	  );
   118	
   119	-- ── Verification (read-only; safe to run after apply) ─────────────────────────
   120	-- SELECT table_name FROM information_schema.tables
   121	--   WHERE table_schema = 'public'
   122	--     AND table_name IN ('legal_document','legal_document_version')
   123	--   ORDER BY table_name;
   124	-- SELECT tablename, policyname FROM pg_policies
   125	--   WHERE policyname LIKE 'legal_%' ORDER BY tablename, policyname;
   126	-- SELECT tgname FROM pg_trigger WHERE tgname = 'trg_legal_document_version_freeze';
supabase/migrations/010_signature_requests.sql
     1	-- 010_signature_requests.sql
     2	-- Requirement #29 — in-app signature (SES) + provider-agnostic e-sign seam.
     3	-- STACKS ON 009_legal_documents.sql: references legal_document_version. Apply
     4	-- order is 009 then 010.
     5	--
     6	-- One shared table serving BOTH signing tiers behind the EsignProvider seam:
     7	--   (1) internal SES (default) — the patient accepts in-app; we record who/when/
     8	--       which-version and regenerate a stamped signed PDF on demand.
     9	--   (2) a real eIDAS provider (Stage 2 / v1.5) — populates external_request_id /
    10	--       signed_document_path / certificate_url / provider_audit_ref instead.
    11	--
    12	-- APPLY STANDALONE (Supabase SQL Editor or psql), NOT via the dev db:migrate
    13	-- runner. Fully idempotent. Re-running is a no-op.
    14	--
    15	-- IMMUTABILITY: once status='signed', a BEFORE UPDATE trigger blocks ALL further
    16	-- changes (mirrors the legal_document_version freeze pattern from 009).
    17	
    18	-- ── signature_request (shared by both tiers) ─────────────────────────────────
    19	CREATE TABLE IF NOT EXISTS signature_request (
    20	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    21	  client_id UUID NOT NULL REFERENCES client(id),
    22	  partner_id UUID NOT NULL REFERENCES partner(id),
    23	  document_version_id UUID NOT NULL REFERENCES legal_document_version(id),
    24	  provider TEXT NOT NULL DEFAULT 'internal',
    25	  status TEXT NOT NULL DEFAULT 'pending'
    26	    CHECK (status IN ('pending', 'sent', 'viewed', 'signed', 'declined', 'expired', 'cancelled')),
    27	  accepted_at TIMESTAMPTZ,                 -- internal SES: when the patient accepted
    28	  accepted_by UUID,                        -- auth.users.id of the accepting patient
    29	  acceptance_method TEXT,                  -- e.g. 'in_app_ses'
    30	  signed_document_path TEXT,               -- external providers only (internal regenerates on demand)
    31	  external_request_id TEXT,                -- external provider's request id
    32	  certificate_url TEXT,                    -- external provider's completion certificate
    33	  provider_audit_ref TEXT,                 -- external provider's audit-trail reference
    34	  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
    35	);
    36	
    37	CREATE INDEX IF NOT EXISTS idx_signature_request_client ON signature_request(client_id);
    38	CREATE INDEX IF NOT EXISTS idx_signature_request_partner ON signature_request(partner_id);
    39	CREATE INDEX IF NOT EXISTS idx_signature_request_version ON signature_request(document_version_id);
    40	
    41	-- ── Immutability guard: a signed request is frozen ───────────────────────────
    42	CREATE OR REPLACE FUNCTION signature_request_freeze()
    43	RETURNS TRIGGER AS $$
    44	BEGIN
    45	  IF OLD.status = 'signed' THEN
    46	    RAISE EXCEPTION 'signature_request is immutable once signed';
    47	  END IF;
    48	  RETURN NEW;
    49	END;
    50	$$ LANGUAGE plpgsql;
    51	
    52	DROP TRIGGER IF EXISTS trg_signature_request_freeze ON signature_request;
    53	CREATE TRIGGER trg_signature_request_freeze
    54	  BEFORE UPDATE ON signature_request
    55	  FOR EACH ROW EXECUTE FUNCTION signature_request_freeze();
    56	
    57	-- ── RLS ──────────────────────────────────────────────────────────────────────
    58	ALTER TABLE signature_request ENABLE ROW LEVEL SECURITY;
    59	
    60	-- Partner-full for their own clients' requests (create/read/manage). FOR ALL
    61	-- USING also gates partner INSERT/UPDATE (USING reused as WITH CHECK).
    62	DROP POLICY IF EXISTS signature_request_partner_access ON signature_request;
    63	CREATE POLICY signature_request_partner_access ON signature_request
    64	  FOR ALL USING (
    65	    partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
    66	  );
    67	
    68	-- Client may READ their own requests.
    69	DROP POLICY IF EXISTS signature_request_client_read ON signature_request;
    70	CREATE POLICY signature_request_client_read ON signature_request
    71	  FOR SELECT TO authenticated
    72	  USING (
    73	    client_id IN (SELECT id FROM client WHERE auth_user_id = auth.uid())
    74	  );
    75	
    76	-- NO client UPDATE policy — intentional. The ONLY acceptance path is the
    77	-- server-side service-role router (signature.acceptSignature), which bypasses RLS
    78	-- and authoritatively stamps status='signed' + accepted_by=<authenticated client>.
    79	-- A prior version granted a client-direct UPDATE (accept -> signed), but its
    80	-- WITH CHECK did not pin partner_id / document_version_id / accepted_by, so a
    81	-- JWT-armed client could, in the same accept, reassign the request into another
    82	-- partner's tenant scope or forge the acceptor. With RLS enabled and no client
    83	-- UPDATE policy, such a write is default-denied outright. DROP any previously
    84	-- applied instance so re-running converges to the hardened state (idempotent).
    85	DROP POLICY IF EXISTS signature_request_client_accept ON signature_request;
    86	
    87	-- ── Verification (read-only; safe to run after apply) ─────────────────────────
    88	-- SELECT table_name FROM information_schema.tables
    89	--   WHERE table_schema = 'public' AND table_name = 'signature_request';
    90	-- SELECT tablename, policyname, cmd FROM pg_policies
    91	--   WHERE tablename = 'signature_request' ORDER BY policyname;
    92	-- SELECT tgname FROM pg_trigger WHERE tgname = 'trg_signature_request_freeze';
supabase/migrations/011_snapshot_edit_audit.sql
     1	-- 011_snapshot_edit_audit.sql
     2	-- #5 (retroactive measurement editing): an APPEND-ONLY audit trail of coach edits
     3	-- to a past client_snapshot (client.editSnapshot). Each edit records the changed
     4	-- fields (before -> after, changed-only) + who edited + when.
     5	--
     6	-- MIGRATION NUMBER: 011 — the previously-missing number in the sequence
     7	-- (009/010 = #29, 011 = #5 THIS FILE, 012 = #07, 013 = #28, 014 = #10). Independent
     8	-- of every other branch: it adds ONE new table and touches NO shared object (in
     9	-- particular it does NOT alter notification_trigger_check or any other constraint).
    10	-- Applies BEFORE 012 (only ordering requirement: after 001, which defines
    11	-- client_snapshot + client).
    12	--
    13	-- APPEND-ONLY: this table has INSERT + SELECT RLS policies and NO update/delete
    14	-- policy, so RLS default-denies UPDATE and DELETE for authenticated users — the
    15	-- audit trail is immutable, mirroring the legal_document_version / signature_request
    16	-- immutability pattern (here achieved purely by absence of a write path, since —
    17	-- unlike signature_request — there is no legitimate client/partner update path).
    18	--
