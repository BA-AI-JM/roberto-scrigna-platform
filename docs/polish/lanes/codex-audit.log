     1	/**
     2	 * Goal-rate calculator — translates "I want to weigh X by date Y" into a
     3	 * concrete daily kcal target, with safety floors and an aggressiveness band.
     4	 *
     5	 * Spec is silent on the upfront-deficit math, so we apply practitioner
     6	 * defaults (May 2026):
     7	 *
     8	 *   Fat-loss cap:    1.0 % bodyweight / week
     9	 *   Muscle-gain cap: 0.5 % bodyweight / week
    10	 *   kcal floor:      max(22 × lean_mass_kg, 1200 kcal/day)
    11	 *   % TDEE check:    deficit > 25 % TDEE bumps the aggressiveness band up one
    12	 *
    13	 * Pure, side-effect-free; tested in __tests__/goal-rate.test.ts.
    14	 */
    15	
    16	export type GoalDirection = "fat_loss" | "muscle_gain" | "maintenance";
    17	
    18	export type AggressivenessBand =
    19	  | "comfortable"
    20	  | "moderate"
    21	  | "aggressive"
    22	  | "extreme";
    23	
    24	export interface GoalRateInput {
    25	  /** Current bodyweight in kg. */
    26	  currentKg: number;
    27	  /** Target bodyweight in kg. */
    28	  targetKg: number;
    29	  /** Time available in weeks. */
    30	  weeks: number;
    31	  /** Weekly-average TDEE in kcal/day. */
    32	  tdeeKcal: number;
    33	  /** Lean (fat-free) mass in kg — drives the kcal safety floor. */
    34	  leanMassKg: number;
    35	}
    36	
    37	export interface GoalRateResult {
    38	  direction: GoalDirection;
    39	  /** Absolute kg delta. Positive when fat loss is required, negative for gain. */
    40	  totalDeltaKg: number;
    41	  /** Required rate in kg/week (always non-negative). */
    42	  requiredKgPerWeek: number;
    43	  /** Required rate as % of current bodyweight per week. */
    44	  percentBwPerWeek: number;
    45	  /**
    46	   * Daily kcal deficit (positive) for fat loss; daily surplus (negative)
    47	   * for muscle gain; 0 for maintenance.
    48	   */
    49	  dailyDeficitKcal: number;
    50	  /** Implied daily intake target: tdeeKcal − dailyDeficitKcal. */
    51	  targetDailyKcal: number;
    52	  /** Minimum safe daily intake. Plans that fall below this should be blocked. */
    53	  kcalFloor: number;
    54	  /** True when targetDailyKcal < kcalFloor. */
    55	  belowFloor: boolean;
    56	  /** Aggressiveness band — derived from % BW/wk, bumped up one if > 25 % TDEE. */
    57	  band: AggressivenessBand;
    58	  /** Cap for the chosen direction (% bodyweight/week). */
    59	  capPercentBwPerWeek: number;
    60	  /**
    61	   * If band is "extreme", a suggested timeline (whole weeks, rounded up) at
    62	   * which both the % BW/wk and 25 % TDEE bounds are honoured.
    63	   */
    64	  suggestedWeeks?: number;
    65	}
    66	
    67	// ── Constants ───────────────────────────────────────────────────────────────
    68	
    69	/** 1 kg of tissue ≈ 7700 kcal (classic dietetic approximation). */
    70	const KCAL_PER_KG = 7700;
    71	/** Absolute kcal floor — never go below this regardless of lean mass. */
    72	const KCAL_FLOOR_ABS = 1200;
    73	/** Per-kg-lean kcal floor multiplier — covers BMR + small NEAT margin. */
    74	const KCAL_FLOOR_PER_LEAN = 22;
    75	/** Direction is "maintenance" when |delta| ≤ this. */
    76	const MAINTENANCE_DELTA_KG = 0.5;
    77	/** Deficit-as-share-of-TDEE threshold that bumps the band up one level. */
    78	const HIGH_TDEE_DEFICIT_FRACTION = 0.25;
    79	
    80	/** % bodyweight per week caps. */
    81	const CAP_PCT_BW_PER_WEEK = {
    82	  fat_loss: 1.0,
    83	  muscle_gain: 0.5,
    84	} as const;
    85	
    86	/** Band thresholds in % BW/week. */
    87	const BANDS_FAT_LOSS: Array<{ band: AggressivenessBand; max: number }> = [
    88	  { band: "comfortable", max: 0.5 },
    89	  { band: "moderate", max: 0.75 },
    90	  { band: "aggressive", max: 1.0 },
    91	];
    92	const BANDS_MUSCLE_GAIN: Array<{ band: AggressivenessBand; max: number }> = [
    93	  { band: "comfortable", max: 0.25 },
    94	  { band: "moderate", max: 0.4 },
    95	  { band: "aggressive", max: 0.5 },
    96	];
