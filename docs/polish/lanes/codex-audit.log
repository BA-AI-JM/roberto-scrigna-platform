   441	      input.guidanceOverrides?.nutritionStrategy ??
   442	      generatedGuidance.nutritionStrategy,
   443	    trainingNotes:
   444	      input.guidanceOverrides?.trainingNotes ??
   445	      generatedGuidance.trainingNotes,
   446	    coachNotes:
   447	      input.guidanceOverrides?.coachNotes ??
   448	      generatedGuidance.coachNotes,
   449	  };
   450	
   451	  // ── Step 8: Monitoring ─────────────────────────────────────────────────
   452	  const monitoring =
   453	    input.monitoringOverride ?? generateMonitoringConfig(energyBalance);
   454	
   455	  // ── Step 9: Assemble PDF report data ───────────────────────────────────
   456	  const dayTypePlans: DayTypePlanSummary[] = uniqueDayTypes.map(
   457	    (dayType) => {
   458	      const dayPlan = weeklyPlan.days.find((d) => d.dayType === dayType);
   459	      if (!dayPlan) {
   460	        throw new Error(`No daily plan found for day type: ${dayType}`);
   461	      }
   462	
   463	      return {
   464	        dayType,
   465	        label: DAY_TYPE_LABELS[dayType],
   466	        tdee: dayPlan.tdee,
   467	        macros: dayPlan.macros,
   468	        hydration: dayPlan.hydration,
   469	        mealPlan: mealPlans.get(dayType),
   470	      };
   471	    }
   472	  );
   473	
   474	  const reportData: PdfReportData = {
   475	    client: clientInfo,
   476	    snapshot,
   477	    bodyComposition,
   478	    circonferenze: input.circonferenze,
   479	    pliche: input.pliche,
   480	    allenamento: input.allenamento,
   481	    stileVita: input.stileVita,
   482	    obiettivo: input.obiettivo,
   483	    monitoring,
   484	    dayTypePlans,
   485	    supplements,
   486	    guidance,
   487	  };
   488	
   489	  return {
   490	    reportData,
   491	    weeklyPlan,
   492	    bodyComposition,
   493	    mealPlans,
   494	    supplements,
   495	    guidance,
   496	    monitoring,
   497	    energyBalance,
   498	    assumptions,
   499	    ...(waterLoading ? { waterLoading } : {}),
   500	  };
   501	}
   502	
   503	// ── Serialization helpers for review UI ─────────────────────────────────────
   504	
   505	/** Serializable version of PlanGenerationResult (Map → Record) */
   506	export interface SerializedPlanResult {
   507	  /** Complete PDF report data */
   508	  reportData: PdfReportData;
   509	  /** Weekly plan */
   510	  weeklyPlan: WeeklyPlan;
   511	  /** Body composition */
   512	  bodyComposition: BodyComposition;
   513	  /** Meal plans keyed by day type */
   514	  mealPlans: Record<string, DayMealPlan>;
   515	  /** Supplement protocol */
   516	  supplements: SupplementEntry[];
   517	  /** Guidance narratives */
   518	  guidance: GuidanceSection;
   519	  /** Monitoring config */
   520	  monitoring: MonitoringConfig;
   521	  /** Energy balance */
   522	  energyBalance: "deficit" | "surplus" | "maintenance";
   523	  /** Assumptions */
   524	  assumptions: string[];
   525	}
   526	
   527	/**
   528	 * Serialize a PlanGenerationResult for JSON transport (e.g., tRPC response).
   529	 */
   530	export function serializePlanResult(
   531	  result: PlanGenerationResult
   532	): SerializedPlanResult {
   533	  const mealPlans: Record<string, DayMealPlan> = {};
   534	  for (const [key, value] of result.mealPlans) {
   535	    mealPlans[key] = value;
   536	  }
   537	
   538	  return {
   539	    reportData: result.reportData,
   540	    weeklyPlan: result.weeklyPlan,
   541	    bodyComposition: result.bodyComposition,
   542	    mealPlans,
   543	    supplements: result.supplements,
   544	    guidance: result.guidance,
   545	    monitoring: result.monitoring,
   546	    energyBalance: result.energyBalance,
   547	    assumptions: result.assumptions,
   548	  };
   549	}
   550	
   551	/**
   552	 * Deserialize a SerializedPlanResult back to PlanGenerationResult.
   553	 */
   554	export function deserializePlanResult(
   555	  serialized: SerializedPlanResult
   556	): PlanGenerationResult {
   557	  const mealPlans = new Map<DayType, DayMealPlan>();
   558	  for (const [key, value] of Object.entries(serialized.mealPlans)) {
   559	    mealPlans.set(key as DayType, value);
   560	  }
   561	
   562	  return {
   563	    reportData: serialized.reportData,
   564	    weeklyPlan: serialized.weeklyPlan,
   565	    bodyComposition: serialized.bodyComposition,
   566	    mealPlans,
   567	    supplements: serialized.supplements,
   568	    guidance: serialized.guidance,
   569	    monitoring: serialized.monitoring,
   570	    energyBalance: serialized.energyBalance,
   571	    assumptions: serialized.assumptions,
   572	  };
   573	}

