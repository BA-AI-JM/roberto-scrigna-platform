   183	      : -(requiredKgPerWeek * KCAL_PER_KG) / 7;
   184	  const targetDailyKcal = tdeeKcal - signedDeficit;
   185	
   186	  // Band from % BW/wk, then bump up one if deficit is also > 25 % TDEE.
   187	  let band = bandFromPercentBw(direction, percentBwPerWeek);
   188	  const percentTdee = tdeeKcal > 0 ? Math.abs(signedDeficit) / tdeeKcal : 0;
   189	  if (percentTdee > HIGH_TDEE_DEFICIT_FRACTION) {
   190	    band = bumpBand(band);
   191	  }
   192	
   193	  // Suggested timeline: the longer of "% BW cap" and "% TDEE cap" weeks counts.
   194	  let suggestedWeeks: number | undefined;
   195	  if (band === "extreme") {
   196	    const weeksAtBwCap = absDeltaKg / (currentKg * (capPercentBwPerWeek / 100));
   197	    // Daily deficit ≤ 25 % TDEE  ⇒  weekly kg ≤ (0.25 × TDEE × 7) / 7700
   198	    const weeksAtTdeeCap =
   199	      tdeeKcal > 0
   200	        ? (absDeltaKg * KCAL_PER_KG) / (HIGH_TDEE_DEFICIT_FRACTION * tdeeKcal * 7)
   201	        : weeksAtBwCap;
   202	    suggestedWeeks = Math.max(1, Math.ceil(Math.max(weeksAtBwCap, weeksAtTdeeCap)));
   203	  }
   204	
   205	  return {
   206	    direction,
   207	    totalDeltaKg,
   208	    requiredKgPerWeek: Math.round(requiredKgPerWeek * 100) / 100,
   209	    percentBwPerWeek: Math.round(percentBwPerWeek * 100) / 100,
   210	    dailyDeficitKcal: Math.round(signedDeficit),
   211	    targetDailyKcal: Math.round(targetDailyKcal),
   212	    kcalFloor: Math.round(kcalFloor),
   213	    belowFloor: targetDailyKcal < kcalFloor,
   214	    band,
   215	    capPercentBwPerWeek,
   216	    suggestedWeeks,
   217	  };
   218	}
     1	/**
     2	 * Macro target calculations: Protein, Fat, Carbs.
     3	 *
     4	 * Spec v4.4 guidelines:
     5	 * - Protein: 2.5 g/kg LBM (training) or 2.2 g/kg LBM (rest)
     6	 * - Fat: 0.8-1.2 g/kg total BW
     7	 * - Carbs: remaining kcal after protein & fat
     8	 *
     9	 * Training adjustments:
    10	 * - Training days: higher carbs, moderate fat
    11	 * - Rest days: moderate carbs, slightly higher fat
    12	 * - Refeed days: high carbs, reduced fat
    13	 * - Deload days: same as rest
    14	 */
    15	
    16	import type { DayType, MacroTargets, BodyComposition } from "./types";
    17	
    18	// ── Caloric values per gram ───────────────────────────────────────────────────
    19	
    20	const KCAL_PER_G_PROTEIN = 4;
    21	const KCAL_PER_G_CARB = 4;
    22	const KCAL_PER_G_FAT = 9;
    23	
    24	// ── Per day-type multipliers ──────────────────────────────────────────────────
    25	
    26	interface MacroMultipliers {
    27	  /** g/kg lean body mass */
    28	  proteinPerKgLbm: number;
    29	  /** g/kg total body weight */
    30	  fatPerKgBw: number;
    31	}
    32	
    33	const DAY_TYPE_MULTIPLIERS: Record<DayType, MacroMultipliers> = {
    34	  training: { proteinPerKgLbm: 2.5, fatPerKgBw: 0.9 },
    35	  rest: { proteinPerKgLbm: 2.2, fatPerKgBw: 1.0 },
    36	  refeed: { proteinPerKgLbm: 2.2, fatPerKgBw: 0.7 },
    37	  deload: { proteinPerKgLbm: 2.2, fatPerKgBw: 1.0 },
    38	  // #17 periodization tiers (modes 3-4) — provisional: clone the training
    39	  // ratios. Intensity differentiation comes from TDEE (per-day session
    40	  // expenditure) + the carb remainder, NOT from protein/fat ratio shifts.
    41	  // provisional — Roberto to calibrate intensity ratios
    42	  training_light: { proteinPerKgLbm: 2.5, fatPerKgBw: 0.9 },
    43	  training_medium: { proteinPerKgLbm: 2.5, fatPerKgBw: 0.9 },
    44	  training_intense: { proteinPerKgLbm: 2.5, fatPerKgBw: 0.9 },
    45	  training_double: { proteinPerKgLbm: 2.5, fatPerKgBw: 0.9 },
    46	};
    47	
    48	// ── Public API ────────────────────────────────────────────────────────────────
    49	
    50	/**
    51	 * Per-day-type absolute macro override (grams). Any subset of the three
    52	 * may be set — values left undefined fall back to the formula
    53	 * (proteinPerKgLbm × LBM / fatPerKgBw × BW / remaining kcal as carbs).
    54	 */
    55	export interface MacroOverrideGrams {
    56	  proteinG?: number;
    57	  fatG?: number;
    58	  carbG?: number;
    59	}
    60	
    61	export interface MacroOptions {
    62	  /** Override protein g/kg LBM */
    63	  proteinPerKgLbm?: number;
    64	  /** Override fat g/kg BW */
    65	  fatPerKgBw?: number;
    66	  /**
    67	   * Absolute-gram overrides per day-type. The wizard exposes this as
    68	   * "Macro per giorno" so the practitioner can pin P/F/C grams without
    69	   * going through the deficit math.
    70	   */
    71	  absoluteOverrides?: Partial<Record<DayType, MacroOverrideGrams>>;
    72	  /**
    73	   * #26 injury/stress — additive bump to protein g/kg LBM (on top of the
    74	   * day-type or overridden proteinPerKgLbm) for injury recovery. Absent / 0 =
    75	   * no effect (byte-identical). Only affects the FORMULA path, not an absolute
    76	   * per-day-type override. provisional — Roberto to calibrate.
    77	   */
    78	  injuryProteinBumpGPerKg?: number;
    79	}
    80	
    81	/**
    82	 * Calculate macro targets for a given day type and TDEE.
    83	 *
    84	 * @param tdeeKcal - Total daily energy expenditure
    85	 * @param bodyComp - Body composition (lean mass, total weight derived from it)
    86	 * @param totalWeightKg - Client's total body weight
    87	 * @param dayType - Type of day
    88	 * @param options - Optional overrides for multipliers
    89	 * @returns Macro targets in grams with total kcal
    90	 */
    91	export function calculateMacros(
    92	  tdeeKcal: number,
    93	  bodyComp: BodyComposition,
    94	  totalWeightKg: number,
    95	  dayType: DayType,
    96	  options: MacroOptions = {}
    97	): MacroTargets {
    98	  const multipliers = DAY_TYPE_MULTIPLIERS[dayType];
    99	  const dayOverride = options.absoluteOverrides?.[dayType];
   100	
   101	  // Protein — absolute override wins; else formula (+ #26 injury bump on the
   102	  // per-kg rate; 0 = byte-identical).
   103	  const proteinPerKgLbm =
   104	    (options.proteinPerKgLbm ?? multipliers.proteinPerKgLbm) +
   105	    (options.injuryProteinBumpGPerKg ?? 0);
   106	  const proteinG =
   107	    dayOverride?.proteinG != null
   108	      ? Math.max(0, Math.round(dayOverride.proteinG))
   109	      : Math.round(proteinPerKgLbm * bodyComp.leanMassKg);
   110	
   111	  // Fat — absolute override wins; else formula
   112	  const fatPerKgBw = options.fatPerKgBw ?? multipliers.fatPerKgBw;
   113	  const fatG =
   114	    dayOverride?.fatG != null
   115	      ? Math.max(0, Math.round(dayOverride.fatG))
   116	      : Math.round(fatPerKgBw * totalWeightKg);
   117	
   118	  // Carbs — explicit override OR remaining kcal after P+F
   119	  const proteinKcal = proteinG * KCAL_PER_G_PROTEIN;
   120	  const fatKcal = fatG * KCAL_PER_G_FAT;
   121	  // On the FORMULA path, a negative remainder means protein+fat alone exceed the
   122	  // target: carbs floor to 0 and the achieved kcal overshoots the target (the
   123	  // deficit is under-delivered). Flag it so the plan surfaces it rather than
   124	  // shipping a silently-over plan. An explicit carbG override is taken as-is.
   125	  const usesCarbFormula = dayOverride?.carbG == null;
   126	  const carbFloorApplied = usesCarbFormula && tdeeKcal - proteinKcal - fatKcal < 0;
   127	  const carbG =
   128	    dayOverride?.carbG != null
   129	      ? Math.max(0, Math.round(dayOverride.carbG))
   130	      : Math.max(0, Math.round((tdeeKcal - proteinKcal - fatKcal) / KCAL_PER_G_CARB));
   131	
   132	  // Actual total (may differ slightly from tdeeKcal due to rounding)
   133	  const totalKcal =
   134	    proteinG * KCAL_PER_G_PROTEIN +
   135	    fatG * KCAL_PER_G_FAT +
   136	    carbG * KCAL_PER_G_CARB;
   137	
   138	  return {
   139	    proteinG,
   140	    fatG,
   141	    carbG,
   142	    totalKcal,
   143	    dayType,
   144	    ...(carbFloorApplied
   145	      ? { carbFloorApplied: true, carbFloorKcalOver: Math.round(totalKcal - tdeeKcal) }
   146	      : {}),
   147	  };
   148	}
     1	/**
     2	 * Roberto Scrigna Macro Calculation Engine
     3	 *
     4	 * Pure TypeScript engine implementing spec v4.4 / v4.4.1:
     5	 * - Body fat estimation (J&P 7-site, 3-site, heuristic)
     6	 * - BMR (Katch-McArdle)
     7	 * - TEF (Thermic Effect of Food)
     8	 * - NEAT (steps + occupational)
     9	 * - Exercise kcal (4-method priority with v4.4.1 recalibration)
    10	 * - TDEE per day-type with manual overrides
    11	 * - Macro targets (P/F/C with training adjustments)
    12	 * - Hydration & salt
    13	 */
    14	
    15	// Types
    16	export type {
    17	  Sex,
    18	  OccupationalLevel,
    19	  DayType,
    20	  Skinfold7Site,
    21	  Skinfold3Site,
    22	  Skinfold3SiteMale,
    23	  Skinfold3SiteFemale,
    24	  BodyComposition,
    25	  ClientSnapshot,
    26	  ExerciseMethod,
    27	  ExerciseSession,
    28	  TdeeOverride,
    29	  BmrResult,
    30	  NeatResult,
    31	  TefResult,
    32	  ExerciseResult,
    33	  TdeeResult,
    34	  MacroTargets,
    35	  HydrationTargets,
    36	  DailyPlan,
    37	  WeeklyPlan,
    38	} from "./types";
    39	
    40	// Body Fat
    41	export { estimateBodyFat, type BodyFatMethod, type BodyFatResult } from "./body-fat";
    42	
    43	// BMR
    44	export { calculateBmr, bmrFromLeanMass } from "./bmr";
    45	
    46	// TEF
    47	export { calculateTef, TEF_RANGES, type DietEmphasis } from "./tef";
    48	
    49	// NEAT
    50	export { calculateNeat } from "./neat";
    51	
    52	// Exercise
    53	export { calculateExercise, restDayExercise, type ExerciseContext } from "./exercise";
    54	
    55	// TDEE
    56	export { calculateTdee, calculateWeeklyTdee, type TdeeOptions } from "./tdee";
    57	
    58	// Macros
    59	export { calculateMacros, type MacroOptions } from "./macros";
    60	
    61	// Hydration
    62	export { calculateHydration, waterLoadingSchedule } from "./hydration";
    63	export type { WaterLoadingSchedule, WaterLoadingDay } from "./hydration";
    64	
    65	// ── Convenience: Full Daily Plan ──────────────────────────────────────────────
    66	
    67	import type {
    68	  ClientSnapshot,
    69	  DayType,
    70	  DailyPlan,
    71	  WeeklyPlan,
    72	  ExerciseSession,
    73	} from "./types";
    74	import { isTrainingLikeDayType } from "./types";
    75	import { calculateTdee, type TdeeOptions } from "./tdee";
    76	import { calculateMacros, type MacroOptions } from "./macros";
    77	import { calculateHydration } from "./hydration";
    78	
    79	export interface PlanOptions extends TdeeOptions {
    80	  macroOptions?: MacroOptions;
    81	  /**
    82	   * Daily kcal deficit (positive) or surplus (negative) to apply to each
    83	   * day's TDEE before macros are calculated. When set, the macro engine
    84	   * targets `tdee.totalTdeeKcal − dailyDeficitKcal` per day; the weekly
    85	   * average naturally shifts too. Comes from the target-date deficit
    86	   * calculator (engine/goal-rate.ts) or a direct practitioner override.
    87	   */
    88	  dailyDeficitKcal?: number;
    89	  /**
    90	   * Per-day-of-week exercise session override (length-7 array, Mon-Sun).
    91	   * When the entry at index `i` is set AND the day's DayType is "training",
    92	   * that session is used in place of `options.trainingSession`. Entries set
    93	   * to `null`/`undefined` (or any non-training day) fall back to the global
    94	   * `trainingSession` or the engine default. Lets the practitioner schedule
    95	   * different sports on different days (BJJ Mon, lifting Tue, MMA Wed…).
    96	   */
    97	  perDayTrainingSession?: (ExerciseSession | null | undefined)[];
    98	}
    99	
   100	/**
   101	 * Generate a complete daily plan for a client.
   102	 */
   103	export function generateDailyPlan(
   104	  snapshot: ClientSnapshot,
   105	  dayType: DayType,
   106	  options: PlanOptions = {}
   107	): DailyPlan {
   108	  const tdee = calculateTdee(snapshot, dayType, options);
   109	  const targetKcal = tdee.totalTdeeKcal - (options.dailyDeficitKcal ?? 0);
   110	  const macros = calculateMacros(
   111	    targetKcal,
   112	    tdee.bmr.bodyComposition,
   113	    snapshot.weightKg,
   114	    dayType,
   115	    options.macroOptions
   116	  );
   117	  const hydration = calculateHydration(snapshot.weightKg, dayType);
   118	
   119	  return { dayType, tdee, macros, hydration };
   120	}
   121	
   122	/**
   123	 * Generate a complete weekly plan for a client.
   124	 */
   125	export function generateWeeklyPlan(
   126	  snapshot: ClientSnapshot,
   127	  options: PlanOptions = {}
   128	): WeeklyPlan {
   129	  const perDay = options.perDayTrainingSession;
   130	  const days = snapshot.weekSchedule.map((dayType, i) => {
   131	    const override = perDay?.[i];
   132	    // #17: per-day session override applies to training AND the intensity tiers
   133	    // (so a coach's per-day session flows through on tier days, not just plain
   134	    // "training"). tdee.ts routes all training-like types through calculateExercise.
   135	    if (override && isTrainingLikeDayType(dayType)) {
   136	      return generateDailyPlan(snapshot, dayType, {
   137	        ...options,
   138	        trainingSession: override,
   139	      });
   140	    }
   141	    return generateDailyPlan(snapshot, dayType, options);
   142	  }) as WeeklyPlan["days"];
   143	
   144	  const weeklyAverageKcal = Math.round(
   145	    days.reduce((sum, d) => sum + d.macros.totalKcal, 0) / 7
   146	  );
   147	  const weeklyAverageProteinG = Math.round(
   148	    days.reduce((sum, d) => sum + d.macros.proteinG, 0) / 7
   149	  );
   150	
   151	  return { days, weeklyAverageKcal, weeklyAverageProteinG };
   152	}

