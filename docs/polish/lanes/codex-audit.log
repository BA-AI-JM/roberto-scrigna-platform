   543	-- ── RLS Policies: Partner access ──────────────────────────────────────────────
   544	-- Partners can see their own data and their clients' data.
   545	
   546	-- Partner: can read own record
   547	CREATE POLICY partner_self ON partner
   548	  FOR ALL USING (auth_user_id = auth.uid());
   549	
   550	-- Client: partner can manage their clients
   551	CREATE POLICY client_partner_access ON client
   552	  FOR ALL USING (
   553	    partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
   554	  );
   555	
   556	-- Client Snapshot: via client → partner
   557	CREATE POLICY snapshot_partner_access ON client_snapshot
   558	  FOR ALL USING (
   559	    client_id IN (
   560	      SELECT id FROM client WHERE partner_id IN (
   561	        SELECT id FROM partner WHERE auth_user_id = auth.uid()
   562	      )
   563	    )
   564	  );
   565	
   566	-- Plan: partner owns plans
   567	CREATE POLICY plan_partner_access ON plan
   568	  FOR ALL USING (
   569	    partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
   570	  );
   571	
   572	-- Training Log: via client → partner (or direct partner_id)
   573	CREATE POLICY training_log_partner_access ON training_log
   574	  FOR ALL USING (
   575	    client_id IN (
   576	      SELECT id FROM client WHERE partner_id IN (
   577	        SELECT id FROM partner WHERE auth_user_id = auth.uid()
   578	      )
   579	    )
   580	  );
   581	
   582	-- Check-In: via partner_id
   583	CREATE POLICY checkin_partner_access ON check_in
   584	  FOR ALL USING (
   585	    partner_id IN (SELECT id FROM partner WHERE auth_user_id = auth.uid())
   586	  );
   587	
   588	-- Check-In Token: via client → partner
   589	CREATE POLICY checkin_token_partner_access ON check_in_token
   590	  FOR ALL USING (
   591	    client_id IN (
   592	      SELECT id FROM client WHERE partner_id IN (
   593	        SELECT id FROM partner WHERE auth_user_id = auth.uid()
   594	      )
   595	    )
   150	        max={100}
   151	        value={value}
   152	        onChange={(e) => onChange(Number(e.target.value))}
