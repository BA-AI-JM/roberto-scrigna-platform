   391	  // ── Step 4: Energy balance ─────────────────────────────────────────────
   392	  // Use weighted weekly average TDEE as maintenance baseline (not just rest-day TDEE)
   393	  const avgTdee = weeklyPlan.days.reduce((sum, d) => sum + d.tdee.totalTdeeKcal, 0) / weeklyPlan.days.length;
   394	  const maintenanceEstimate = input.maintenanceKcalEstimate ?? avgTdee;
