supabase/migrations/016_invoice_number_per_partner.sql
     1	-- 016_invoice_number_per_partner.sql
     2	-- Tranche-2 (Fable sweep #1): fix the invoice-number multi-tenant collision.
     3	--
     4	-- Invoice numbers are computed PER-PARTNER (generateInvoiceNumber → RS-YYYY-0001,
     5	-- scoped to partner_id), but 001 made invoice_number GLOBALLY unique
     6	-- (idx_invoice_number ON invoice(invoice_number) WHERE deleted_at IS NULL). So a
     7	-- SECOND partner's first invoice computes RS-2026-0001 — a number Roberto already
     8	-- owns — and the INSERT hits the global unique index → 500. This swaps the global
     9	-- index for a PER-PARTNER one so each partner has an independent RS-YYYY-NNNN run.
    10	--
    11	-- ⚠️ FOR JAMES — apply in the Supabase SQL editor (or psql) BEFORE merging the PR
    12	-- (schema-before-code, same as 015). Do NOT run via the dev db:migrate runner.
    13	--
    14	-- DORMANT for a single coach (only fires with a 2nd partner / a test-coach account),
    15	-- but the code fix (retry-on-conflict) now expects the per-partner constraint, so
    16	-- apply this first. Fully idempotent (DROP … IF EXISTS / CREATE … IF NOT EXISTS).
    17	-- SELF-CONTAINED: depends only on 001's invoice table.
    18	
    19	-- Drop the GLOBAL unique index (invoice_number unique across ALL partners).
    20	DROP INDEX IF EXISTS idx_invoice_number;
    21	
    22	-- Per-partner unique: (partner_id, invoice_number), still excluding soft-deleted
    23	-- rows. Two partners can now each hold RS-2026-0001; a partner still can't
    24	-- duplicate its own number (the retry-on-conflict path relies on this).
    25	CREATE UNIQUE INDEX IF NOT EXISTS idx_invoice_number_partner
    26	  ON invoice(partner_id, invoice_number) WHERE deleted_at IS NULL;

