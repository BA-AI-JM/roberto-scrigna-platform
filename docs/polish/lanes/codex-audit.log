   302	
   303	export const onCheckinDue = inngest.createFunction(
   304	  { id: "checkin-due", retries: 3, triggers: [{ event: "checkin/due" }] },
   305	  async ({ event, step }) => {
   306	    const d = event.data as EventData;
   307	    const { checkinId, clientId, clientName, partnerId, dueDate } = d;
   308	
   309	    // N4: Notify on due date + send email to client with check-in link
   310	    await step.run("notify-checkin-due", async () => {
   311	      await createNotification({
   312	        partnerId,
   313	        clientId,
   314	        trigger: "checkin_overdue",
   315	        title: `Check-in previsto per ${clientName}`,
   316	        body: `Il check-in di ${clientName} è previsto per oggi.`,
   317	        metadata: { checkinId, dueDate },
   318	      });
   319	    });
   320	
   321	    await step.run("email-checkin-due", async () => {
   322	      const db = getServiceDb();
   323	      // Tokens live on the check_in row itself (check_in.token column).
   324	      // The check_in_token table does not exist — token storage is on check_in.
   325	      const { data: checkinRow } = await db
   326	        .from("check_in")
   327	        .select("token")
   328	        .eq("id", checkinId)
   329	        .eq("status", "pending")
   330	        .maybeSingle();
   331	
   332	      const email = await getClientEmail(clientId);
   333	      if (email) {
   334	        const checkinLink = checkinRow?.token
   335	          ? portalUrl(`/checkin/${checkinRow.token}`)
