   317	/**
   318	 * Generate the complete nutrition plan.
   319	 *
   320	 * Orchestrates: engine calculation → meal plans → supplements → narratives → PDF data assembly.
   321	 * Returns both the final PdfReportData and intermediate results for the review UI.
   322	 */
   323	export function generatePlan(
   324	  input: PlanGenerationInput
   325	): PlanGenerationResult {
   326	  const { snapshot, clientInfo } = input;
   327	
   328	  // ── Step 1: Body composition ────────────────────────────────────────────
   329	  const bodyFatResult = estimateBodyFat(snapshot);
   330	  const bodyComposition: BodyComposition = bodyFatResult.bodyComposition;
   331	
   332	  // ── Step 2: Weekly plan (TDEE + macros + hydration) ────────────────────
   333	  // #26: fold the OPT-IN injury/stress spec into the engine options. Absent →
   334	  // engineOptions is input.engineOptions unchanged (byte-identical).
   335	  const inj = input.injuryStress;
   336	  const engineOptions: PlanOptions | undefined = inj
   337	    ? {
