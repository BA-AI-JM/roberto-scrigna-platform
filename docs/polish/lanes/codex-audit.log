    24	
    25	/**
    26	 * Hardened Resend send (#1 email-wiring).
    27	 *
    28	 * The Resend SDK resolves `{ data, error }` and does NOT throw on API errors
    29	 * (invalid key, unverified from-domain). Call sites used to discard the result,
    30	 * so failures were silent and callers were told "sent". This wrapper:
    31	 *   1. fails loudly when Resend is misconfigured (empty key, or the placeholder
    32	 *      from-address), instead of attempting a doomed send;
    33	 *   2. inspects the returned `error`/`data` and throws a descriptive Error so
    34	 *      the caller (tRPC mutation or Inngest step) surfaces a real failure.
    35	 *
    36	 * It does NOT change the real key/from values — it only detects and surfaces
    37	 * the misconfigured/failed state. Happy path is unchanged.
    38	 */
    39	export async function sendEmail(params: SendEmailParams): Promise<void> {
    40	  const from = params.from ?? FROM_EMAIL;
    41	
    42	  if (!process.env.RESEND_API_KEY) {
    43	    throw new Error(
    44	      "Resend not configured: RESEND_API_KEY is not set — email not sent."
    45	    );
    46	  }
    47	  if (from === UNCONFIGURED_FROM) {
    48	    throw new Error(
    49	      "Resend not configured: RESEND_FROM_EMAIL is unset (placeholder noreply@example.com) — email not sent. Set a verified sender domain."
    50	    );
    51	  }
    52	
    53	  const { data, error } = await getResend().emails.send({
    54	    from,
    55	    to: params.to,
    56	    subject: params.subject,
    57	    html: params.html,
    58	  });
    59	
    60	  if (error) {
    61	    throw new Error(`Resend send failed: ${error.message ?? error.name ?? "unknown error"}`);
    62	  }
    63	  if (!data) {
    64	    throw new Error("Resend send failed: no data returned from Resend API.");
    65	  }
    66	}
     1	/**
     2	 * PDF generation API route.
     3	 *
     4	 * GET /api/pdf/[planId]
     5	 *
     6	 * Reads the stored plan bundle from the database, renders the branded HTML
     7	 * report via renderReportHtml(), then converts it to a PDF using Puppeteer.
     8	 * Returns the PDF buffer with Content-Disposition: attachment so the browser
     9	 * triggers a download.
    10	 *
    11	 * Auth: reads the session cookie via the server Supabase client; returns 401
    12	 * if the user is not an authenticated partner, and 403 if the plan belongs to
    13	 * a different partner.
    14	 */
    15	
    16	import type { NextRequest } from "next/server";
    17	import { createSupabaseServer } from "../../../../lib/supabase/server";
    18	import { generatePdf } from "../../../../pdf/generator";
    19	import type { SerializedPlanResult } from "../../../../services/plan-generator";
    20	import type { PdfReportData } from "../../../../pdf/types";
    21	// #18 → PDF: representative training time from the client's intake, attached to
    22	// training-day plans so the renderer draws the peri-workout box (mirrors the
    23	// portal + coach card). Pure, framework-free helpers.
    24	import { firstTrainingTime, isTrainingDayType, type RawSession } from "../../../../components/plan/peri-workout-timing";
    25	
    26	export async function GET(
    27	  _req: NextRequest,
    28	  { params }: { params: Promise<{ planId: string }> }
    29	) {
    30	  const { planId } = await params;
    31	
    32	  // 1. Auth check — resolve partner from session
    33	  const supabase = await createSupabaseServer();
    34	  const {
    35	    data: { user },
    36	  } = await supabase.auth.getUser();
    37	
    38	  if (!user) {
    39	    return new Response("Non autorizzato.", { status: 401 });
    40	  }
    41	
    42	  const { data: partner } = await supabase
    43	    .from("partner")
    44	    .select("id")
    45	    .eq("auth_user_id", user.id)
    46	    .maybeSingle();
    47	
    48	  if (!partner) {
    49	    return new Response("Accesso negato.", { status: 403 });
    50	  }
    51	
    52	  // 2. Load the plan (scoped to the partner via RLS + explicit filter)
    53	  const { data: plan, error } = await supabase
    54	    .from("plan")
    55	    .select("id, name, status, client_id, daily_targets, created_at")
    56	    .eq("id", planId)
    57	    .eq("partner_id", partner.id)
    58	    .is("deleted_at", null)
    59	    .single();
    60	
    61	  if (error || !plan) {
    62	    return new Response("Piano non trovato.", { status: 404 });
    63	  }
    64	
    65	  // 3. Extract plan_bundle from JSONB storage
    66	  const dailyTargets = plan.daily_targets as Record<string, unknown> | null;
    67	  const planBundle = dailyTargets?.plan_bundle as SerializedPlanResult | null;
    68	
    69	  if (!planBundle?.reportData) {
    70	    return new Response(
    71	      "Dati del piano non disponibili. Rigenerare il piano.",
    72	      { status: 422 }
    73	    );
    74	  }
    75	
    76	  let reportData: PdfReportData = planBundle.reportData;
    77	
    78	  // 3b. #18 — enrich the (frozen) bundle with the client's current training time
    79	  // so training-day plans render the peri-workout timed box. Sourced from the
    80	  // latest snapshot's intake (display-only). Absent / RLS-blocked → no box
    81	  // (graceful) — the meal list renders unchanged.
    82	  const { data: snap } = await supabase
    83	    .from("client_snapshot")
    84	    .select("skinfold_data")
    85	    .eq("client_id", plan.client_id)
    86	    .order("taken_at", { ascending: false })
    87	    .limit(1)
    88	    .maybeSingle();
    89	  const trainingSessions = (
    90	    (snap?.skinfold_data as { _intake?: { training_sessions?: Record<string, RawSession[]> } } | null)
    91	      ?._intake?.training_sessions
    92	  );
    93	  const trainingTime = firstTrainingTime(trainingSessions);
    94	  if (trainingTime.startTime) {
    95	    reportData = {
    96	      ...reportData,
    97	      dayTypePlans: reportData.dayTypePlans.map((p) =>
    98	        isTrainingDayType(p.dayType) ? { ...p, trainingTime } : p
    99	      ),
   100	    };
   101	  }
   102	
   103	  // 4. Render HTML → PDF via Puppeteer
   104	  let pdfBuffer: Uint8Array;
   105	  try {
   106	    pdfBuffer = await generatePdf(reportData, {
   107	      format: "A4",
   108	      includeMealPlans: true,
   109	      includeSupplements: true,
   110	      includeGuidance: true,
   111	    });
   112	  } catch (err) {
   113	    console.error("[pdf/route] Puppeteer error:", err);
   114	    return new Response("Errore durante la generazione del PDF.", {
   115	      status: 500,
   116	    });
   117	  }
   118	
   119	  // 5. Build a clean filename from the client name and date
   120	  const clientName = reportData.client.fullName
   121	    .normalize("NFD")
   122	    .replace(/[\u0300-\u036f]/g, "") // strip accents
   123	    .replace(/[^a-zA-Z0-9 ]/g, "")
   124	    .replace(/\s+/g, "_");
   125	  const planDate = reportData.client.planDate.replace(/-/g, "");
   126	  const filename = `Piano_${clientName}_${planDate}.pdf`;
   127	
   128	  // The Web Response API accepts ArrayBuffer as BodyInit
   129	  return new Response(pdfBuffer.buffer as ArrayBuffer, {
   130	    status: 200,
   131	    headers: {
   132	      "Content-Type": "application/pdf",
   133	      "Content-Disposition": `attachment; filename="${filename}"`,
   134	      "Content-Length": String(pdfBuffer.byteLength),
   135	    },
   136	  });
   137	}
     1	/**
     2	 * Shared serverless-Chromium launcher for every PDF path (engagement letter,
     3	 * invoice, plan). Single source of truth so the three renderers can't drift.
     4	 *
     5	 * WHY @sparticuz/chromium-min + a REMOTE binary:
     6	 * The Next 16 **Turbopack** production build relocated `@sparticuz/chromium` into
     7	 * a chunk (verified: identical chunk hash before/after `serverExternalPackages` —
     8	 * that config is a no-op under this Turbopack build). At runtime the relocated
     9	 * `executablePath()` then couldn't find its sibling `bin/` dir and threw
    10	 * `The input directory ".../@sparticuz/chromium/bin" does not exist`.
    11	 *
    12	 * `@sparticuz/chromium-min` ships NO binary — it downloads the Chromium pack from
    13	 * a URL at runtime and extracts to /tmp. There is no `bin/` to bundle or trace,
    14	 * so the bundling problem cannot occur regardless of how Turbopack packages it.
    15	 *
    16	 * The pack version MUST match the installed `@sparticuz/chromium-min` version or
    17	 * puppeteer-core throws a protocol mismatch. Vercel/AWS Lambda is x64.
    18	 */
    19	import chromium from "@sparticuz/chromium-min";
    20	import puppeteerCore, { type Browser } from "puppeteer-core";
    21	
    22	/** Keep in lockstep with `@sparticuz/chromium-min` in package.json. */
    23	const CHROMIUM_VERSION = "147.0.2";
    24	
    25	/** Remote Chromium pack (override with CHROMIUM_PACK_URL). x64 = Vercel/Lambda. */
    26	const CHROMIUM_PACK_URL =
    27	  process.env.CHROMIUM_PACK_URL ??
    28	  `https://github.com/Sparticuz/chromium/releases/download/v${CHROMIUM_VERSION}/chromium-v${CHROMIUM_VERSION}-pack.x64.tar`;
    29	
    30	/**
    31	 * Resolve the Chromium executable:
    32	 *  1. CHROMIUM_PATH override (CI / custom setups)
    33	 *  2. On Vercel → fetch + extract the remote pack (chromium-min, never bundled)
    34	 *  3. Local → undefined; puppeteer-core falls back to the system browser
    35	 */
    36	async function resolveExecutablePath(): Promise<string | undefined> {
    37	  if (process.env.CHROMIUM_PATH) return process.env.CHROMIUM_PATH;
    38	  if (process.env.VERCEL) return chromium.executablePath(CHROMIUM_PACK_URL);
    39	  return undefined;
    40	}
    41	
    42	/** Launch a headless, serverless-compatible Chromium for PDF rendering. */
    43	export async function launchPdfBrowser(): Promise<Browser> {
    44	  const executablePath = await resolveExecutablePath();
    45	  return puppeteerCore.launch({
    46	    args: chromium.args,
    47	    defaultViewport: { width: 1280, height: 800 },
    48	    executablePath,
    49	    headless: true,
    50	  });
    51	}

