  1250	          },
  1251	        });
  1252	      } catch (err) {
  1253	        console.error("[router/plan.approve] inngest.send failed:", err);
  1254	      }
  1255	
  1256	      return { success: true, planId: input.id };
  1257	    }),
  1258	
  1259	  /**
