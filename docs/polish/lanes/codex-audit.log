   137	/**
   138	 * Translate a target weight + timeline into a daily kcal target + safety
   139	 * verdict. Pure and deterministic. See file header for the cap logic.
   140	 */
   141	export function computeGoalRate(input: GoalRateInput): GoalRateResult {
   142	  const { currentKg, targetKg, weeks, tdeeKcal, leanMassKg } = input;
   143	
   144	  const totalDeltaKg = currentKg - targetKg;
   145	  const absDeltaKg = Math.abs(totalDeltaKg);
   146	  const isMaintenance = absDeltaKg < MAINTENANCE_DELTA_KG || weeks <= 0;
   147	  const direction: GoalDirection = isMaintenance
   148	    ? "maintenance"
   149	    : totalDeltaKg > 0
   150	    ? "fat_loss"
   151	    : "muscle_gain";
   152	
   153	  const capPercentBwPerWeek =
   154	    direction === "muscle_gain"
   155	      ? CAP_PCT_BW_PER_WEEK.muscle_gain
   156	      : CAP_PCT_BW_PER_WEEK.fat_loss;
   157	
   158	  const kcalFloor = Math.max(KCAL_FLOOR_ABS, leanMassKg * KCAL_FLOOR_PER_LEAN);
   159	
   160	  if (isMaintenance) {
   161	    return {
   162	      direction,
   163	      totalDeltaKg,
   164	      requiredKgPerWeek: 0,
   165	      percentBwPerWeek: 0,
   166	      dailyDeficitKcal: 0,
   167	      targetDailyKcal: Math.round(tdeeKcal),
   168	      kcalFloor: Math.round(kcalFloor),
   169	      belowFloor: tdeeKcal < kcalFloor,
   170	      band: "comfortable",
   171	      capPercentBwPerWeek,
   172	    };
   173	  }
   174	
   175	  const requiredKgPerWeek = absDeltaKg / weeks;
   176	  const percentBwPerWeek = currentKg > 0 ? (requiredKgPerWeek / currentKg) * 100 : 0;
   177	
   178	  // Signed deficit: positive for fat loss (subtract from intake),
   179	  // negative for gain (add to intake).
   180	  const signedDeficit =
   181	    direction === "fat_loss"
   182	      ? (requiredKgPerWeek * KCAL_PER_KG) / 7
   183	      : -(requiredKgPerWeek * KCAL_PER_KG) / 7;
   184	  const targetDailyKcal = tdeeKcal - signedDeficit;
   185	
   186	  // Band from % BW/wk, then bump up one if deficit is also > 25 % TDEE.
   187	  let band = bandFromPercentBw(direction, percentBwPerWeek);
   188	  const percentTdee = tdeeKcal > 0 ? Math.abs(signedDeficit) / tdeeKcal : 0;
   189	  if (percentTdee > HIGH_TDEE_DEFICIT_FRACTION) {
   190	    band = bumpBand(band);
   191	  }
   192	
   193	  // Suggested timeline: the longer of "% BW cap" and "% TDEE cap" weeks counts.
   194	  let suggestedWeeks: number | undefined;
   195	  if (band === "extreme") {
   196	    const weeksAtBwCap = absDeltaKg / (currentKg * (capPercentBwPerWeek / 100));
   197	    // Daily deficit ≤ 25 % TDEE  ⇒  weekly kg ≤ (0.25 × TDEE × 7) / 7700
   198	    const weeksAtTdeeCap =
   199	      tdeeKcal > 0
   200	        ? (absDeltaKg * KCAL_PER_KG) / (HIGH_TDEE_DEFICIT_FRACTION * tdeeKcal * 7)
   201	        : weeksAtBwCap;
   202	    suggestedWeeks = Math.max(1, Math.ceil(Math.max(weeksAtBwCap, weeksAtTdeeCap)));
   203	  }
   204	
   205	  return {
   206	    direction,
   207	    totalDeltaKg,
   208	    requiredKgPerWeek: Math.round(requiredKgPerWeek * 100) / 100,
   209	    percentBwPerWeek: Math.round(percentBwPerWeek * 100) / 100,
   210	    dailyDeficitKcal: Math.round(signedDeficit),
   211	    targetDailyKcal: Math.round(targetDailyKcal),
   212	    kcalFloor: Math.round(kcalFloor),
   213	    belowFloor: targetDailyKcal < kcalFloor,
   214	    band,
   215	    capPercentBwPerWeek,
   216	    suggestedWeeks,
   217	  };
   218	}

