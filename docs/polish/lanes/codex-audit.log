     1	/**
     2	 * Simple migration runner for local development.
     3	 * Reads SQL files from supabase/migrations/ in order and executes them
     4	 * against the Supabase database.
     5	 *
     6	 * Usage: bun run supabase/migrate.ts
     7	 *
     8	 * For production, use Supabase CLI: supabase db push
     9	 */
    10	
    11	import { readdir } from "node:fs/promises";
    12	import { join } from "node:path";
    13	import { createClient } from "@supabase/supabase-js";
    14	
    15	const MIGRATIONS_DIR = join(import.meta.dir, "migrations");
    16	
    17	async function migrate() {
    18	  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
    19	  const supabaseServiceKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
    20	
    21	  if (!supabaseUrl || !supabaseServiceKey) {
    22	    console.log("⚠️  No Supabase credentials found. Validating migration files only...\n");
    23	
    24	    // Dry-run: just verify SQL files can be read
    25	    const files = await readdir(MIGRATIONS_DIR);
    26	    const sqlFiles = files.filter((f) => f.endsWith(".sql")).sort();
    27	
    28	    for (const file of sqlFiles) {
    29	      const path = join(MIGRATIONS_DIR, file);
    30	      const content = await Bun.file(path).text();
    31	      const lineCount = content.split("\n").length;
    32	      const tableMatches = content.match(/CREATE TABLE (\w+)/g) ?? [];
    33	      console.log(`✓ ${file} (${lineCount} lines, ${tableMatches.length} tables)`);
    34	    }
    35	
    36	    console.log(`\n✅ ${sqlFiles.length} migration file(s) validated successfully.`);
    37	    console.log("   Set NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to run against a real database.");
    38	    return;
    39	  }
    40	
    41	  const supabase = createClient(supabaseUrl, supabaseServiceKey, {
    42	    auth: { persistSession: false },
    43	  });
    44	
    45	  const files = await readdir(MIGRATIONS_DIR);
    46	  const sqlFiles = files.filter((f) => f.endsWith(".sql")).sort();
    47	
    48	  console.log(`Found ${sqlFiles.length} migration(s) to run.\n`);
    49	
    50	  for (const file of sqlFiles) {
    51	    const path = join(MIGRATIONS_DIR, file);
    52	    const sql = await Bun.file(path).text();
    53	
    54	    console.log(`Running: ${file}...`);
    55	    const { error } = await supabase.rpc("exec_sql", { sql_text: sql });
    56	
    57	    if (error) {
    58	      console.error(`❌ Failed: ${file}`);
    59	      console.error(error.message);
    60	      process.exit(1);
    61	    }
    62	
    63	    console.log(`✓ ${file} applied successfully.`);
    64	  }
    65	
    66	  console.log("\n✅ All migrations applied.");
    67	}
    68	
    69	migrate().catch((err) => {
    70	  console.error("Migration failed:", err);
    71	  process.exit(1);
    72	});
