   536	
   537	  /**
   538	   * Get the message thread between client and coach.
   539	   */
   540	  getMessages: clientProcedure
   541	    .input(
   542	      z.object({
   543	        limit: z.number().int().min(1).max(100).default(50),
   544	        before: z.string().datetime().optional(), // cursor: message created_at ISO datetime
   545	      })
   546	    )
   547	    .query(async ({ ctx, input }) => {
   548	      const db = svc();
   549	      let query = db
   550	        .from("message")
   551	        .select("id, sender_type, sender_id, body, attachments, is_read, read_at, created_at")
   552	        .eq("client_id", ctx.clientId)
   553	        .order("created_at", { ascending: false })
   554	        .limit(input.limit);
   555	
   556	      if (input.before) {
   557	        query = query.lt("created_at", input.before);
   558	      }
   559	
   560	      const { data, error } = await query;
   561	
   562	      if (error) {
   563	        console.error("[router/portal.getMessages]", error);
   564	        throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nel caricamento dei dati." });
   565	      }
   566	
   567	      return (data ?? []).reverse(); // chronological order
   568	    }),
   569	
   570	  /**
   571	   * Send a message from the client to the coach.
   572	   */
   573	  sendMessage: clientProcedure
   574	    .input(z.object({ body: z.string().min(1).max(5000) }))
   575	    .mutation(async ({ ctx, input }) => {
   576	      const ip = getClientIp(ctx.headers) !== "unknown" ? getClientIp(ctx.headers) : (ctx.clientId ?? "unknown");
   577	      const { success } = rateLimit(`portal:sendMessage:${ip}`, 30, 60_000);
   578	      if (!success) {
   579	        throw new TRPCError({ code: "TOO_MANY_REQUESTS", message: "Troppi tentativi. Riprova tra poco." });
   580	      }
   581	
   582	      const db = svc();
   583	      const { data, error } = await db
   584	        .from("message")
   585	        .insert({
   586	          client_id: ctx.clientId,
   587	          sender_type: "client",
   588	          sender_id: ctx.userId,
   589	          body: input.body,
   590	          is_read: false,
   591	        })
   592	        .select("id")
   593	        .single();
   594	
   595	      if (error || !data) {
   596	        throw new TRPCError({
   597	          code: "INTERNAL_SERVER_ERROR",
   598	          message: error?.message ?? "Errore nell'invio del messaggio.",
   599	        });
   600	      }
   601	
   602	      return { id: data.id };
   603	    }),
   604	
   605	  /**
   606	   * Mark all incoming coach messages as read.
   607	   */
   608	  markMessagesRead: clientProcedure.mutation(async ({ ctx }) => {
   609	    const db = svc();
   610	    const { error } = await db
   611	      .from("message")
   612	      .update({ is_read: true, read_at: new Date().toISOString() })
   613	      .eq("client_id", ctx.clientId)
   614	      .eq("sender_type", "coach")
   615	      .eq("is_read", false);
   616	
   617	    if (error) {
   618	      console.error("[router/portal.markMessagesRead]", error);
   619	      throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nell'aggiornamento. Riprova." });
   620	    }
   621	
   622	    return { success: true };
   623	  }),
   624	
   625	  /**
   626	   * Get check-in status — whether a check-in is pending/overdue and the most recent one.
   627	   */
   628	  getCheckInStatus: clientProcedure.query(async ({ ctx }) => {
   629	    const db = svc();
   630	
   631	    const { data: latest } = await db
   632	      .from("check_in")
   633	      .select("id, check_in_date, weight_kg, nutrition_adherence, training_adherence")
   634	      .eq("client_id", ctx.clientId)
   635	      .order("check_in_date", { ascending: false })
   636	      .limit(1)
   637	      .maybeSingle();
   638	
   639	    // Check for a pending check-in token.
   640	    // Tokens are stored on the check_in row (check_in.token column) — there is
   641	    // no separate check_in_token table. Query the most recent pending check-in.
   642	    const { data: pendingCheckin } = await db
   643	      .from("check_in")
   644	      .select("token")
   645	      .eq("client_id", ctx.clientId)
   646	      .eq("status", "pending")
   647	      .order("created_at", { ascending: false })
   648	      .limit(1)
   649	      .maybeSingle();
   650	
   651	    return {
   652	      latestCheckIn: latest ?? null,
   653	      pendingToken: pendingCheckin?.token ?? null,
   654	    };
   655	  }),
   656	
   657	  /**
   658	   * Save a web push subscription for this client.
   659	   * Note: Requires a push_subscription table (see ISSUES in Batch 8 output).
   660	   */
   661	  savePushSubscription: clientProcedure
