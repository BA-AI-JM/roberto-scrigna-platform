   302	// ── Helpers ──────────────────────────────────────────────────────────────────
   303	
   304	/**
   305	 * Pull the per-day training sessions captured at intake (stored under
   306	 * skinfold_data._intake.training_sessions) out of a client_snapshot row.
   307	 */
   308	export function intakeTrainingSessions(
   309	  snapshotRow: Record<string, unknown>
   310	): Record<string, IntakeTrainingSession[]> | undefined {
   311	  const skinfoldRaw = snapshotRow.skinfold_data as Record<string, unknown> | null;
   312	  const intake = skinfoldRaw?._intake as Record<string, unknown> | undefined;
   313	  return intake?.training_sessions as Record<string, IntakeTrainingSession[]> | undefined;
   314	}
   315	
   316	/**
   317	 * Map a raw client_snapshot DB row into a ClientSnapshot for the engine.
   318	 * The snapshot row stores sex on the client table, so both are passed in.
   319	 */
   320	export function buildEngineSnapshot(
   321	  snapshotRow: Record<string, unknown>,
   322	  clientSex: "male" | "female"
   323	): ClientSnapshot {
   324	  // Parse skinfold data from JSONB
   325	  const skinfoldRaw = snapshotRow.skinfold_data as Record<string, unknown> | null;
   326	
   327	  let skinfold7: ClientSnapshot["skinfold7"];
   328	  let skinfold3: ClientSnapshot["skinfold3"];
   329	  let bodyFatPctOverride: number | undefined;
   330	
   331	  if (skinfoldRaw) {
   332	    if (skinfoldRaw.method === "7site") {
   333	      skinfold7 = {
   334	        chest: Number(skinfoldRaw.chest ?? 0),
   335	        midaxillary: Number(skinfoldRaw.midaxillary ?? 0),
   336	        tricep: Number(skinfoldRaw.tricep ?? 0),
   337	        subscapular: Number(skinfoldRaw.subscapular ?? 0),
   338	        abdominal: Number(skinfoldRaw.abdominal ?? 0),
   339	        suprailiac: Number(skinfoldRaw.suprailiac ?? 0),
   340	        thigh: Number(skinfoldRaw.thigh ?? 0),
   341	      };
   342	    } else if (skinfoldRaw.method === "3site") {
   343	      if (clientSex === "male") {
   344	        skinfold3 = {
   345	          chest: Number(skinfoldRaw.chest ?? 0),
   346	          abdominal: Number(skinfoldRaw.abdominal ?? 0),
   347	          thigh: Number(skinfoldRaw.thigh ?? 0),
   348	        };
   349	      } else {
   350	        skinfold3 = {
   351	          tricep: Number(skinfoldRaw.tricep ?? 0),
   352	          suprailiac: Number(skinfoldRaw.suprailiac ?? 0),
   353	          thigh: Number(skinfoldRaw.thigh ?? 0),
   354	        };
   355	      }
   356	    } else if (skinfoldRaw.method === "override") {
   357	      bodyFatPctOverride = Number(skinfoldRaw.bodyFatPctOverride) || undefined;
   358	    }
   359	  }
   360	
   361	  // week_schedule from DB is a TEXT[] of 7 day types
   362	  const rawSchedule = (snapshotRow.week_schedule as string[] | null) ?? [
   363	    "training",
   364	    "rest",
   365	    "training",
   366	    "rest",
   367	    "training",
   368	    "rest",
   369	    "rest",
   370	  ];
   371	  const weekSchedule = rawSchedule as [
   372	    DayType,
   373	    DayType,
   374	    DayType,
   375	    DayType,
   376	    DayType,
   377	    DayType,
   378	    DayType,
   379	  ];
   380	
   381	  return {
   382	    sex: clientSex,
   383	    ageYears: Number(snapshotRow.age_years ?? 30),
   384	    weightKg: Number(snapshotRow.weight_kg ?? 70),
   385	    heightCm: Number(snapshotRow.height_cm ?? 170),
   386	    dailySteps: Number(snapshotRow.daily_steps ?? 6000),
   387	    occupationalLevel:
   388	      (snapshotRow.occupational_level as ClientSnapshot["occupationalLevel"]) ??
   389	      "sedentary",
   390	    weekSchedule,
   391	    skinfold7,
   392	    skinfold3,
   393	    bodyFatPctOverride,
   394	  };
   395	}
