     1	/**
     2	 * In-memory sliding-window rate limiter.
     3	 *
     4	 * Tracks request timestamps per key in a Map. On each call it prunes
     5	 * entries outside the current window before deciding whether to allow.
     6	 *
     7	 * SECURITY NOTE — VERCEL SERVERLESS LIMITATION:
     8	 * This store is process-local. On Vercel each serverless function invocation
     9	 * runs in its own isolated sandbox, so the Map is reset on every cold start.
    10	 * This means the rate limiter provides NO cross-request protection across
    11	 * concurrent or sequential cold-start invocations.
    12	 *
    13	 * TO FIX FOR PRODUCTION:
    14	 * Install @upstash/ratelimit + @upstash/redis and replace this module with:
    15	 *
    16	 *   import { Ratelimit } from "@upstash/ratelimit";
    17	 *   import { Redis } from "@upstash/redis";
    18	 *
    19	 *   const ratelimit = new Ratelimit({
    20	 *     redis: Redis.fromEnv(),          // UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
    21	 *     limiter: Ratelimit.slidingWindow(10, "60 s"),
    22	 *   });
    23	 *
    24	 *   export async function rateLimit(key, _limit, _windowMs) {
    25	 *     const result = await ratelimit.limit(key);
    26	 *     return { success: result.success, remaining: result.remaining };
    27	 *   }
    28	 *
    29	 * Until then, this implementation at least rate-limits within a single warm
    30	 * invocation lifecycle (multiple tRPC calls hitting the same warm instance).
    31	 * It also uses the correct x-forwarded-for extraction — see getClientIp().
    32	 */
    33	
    34	/**
    35	 * Extract the real client IP from the x-forwarded-for header.
    36	 * Vercel sets this to a comma-separated list; the first entry is the
    37	 * originating client IP (subsequent entries are proxies).
    38	 *
    39	 * Falls back to "unknown" when the header is absent (e.g. localhost dev).
    40	 */
    41	export function getClientIp(headers: Headers | null): string {
    42	  const xff = headers?.get("x-forwarded-for");
    43	  if (!xff) return "unknown";
    44	  // Take the first IP in the chain, trim whitespace
    45	  return xff.split(",")[0]?.trim() ?? "unknown";
    46	}
    47	
    48	interface WindowEntry {
    49	  timestamps: number[];
    50	}
    51	
    52	const store = new Map<string, WindowEntry>();
    53	
    54	/**
    55	 * Check and record a request for the given key.
    56	 *
    57	 * @param key       - Unique identifier for the rate-limit bucket (typically IP + endpoint)
    58	 * @param limit     - Maximum number of requests allowed within the window
    59	 * @param windowMs  - Sliding window duration in milliseconds
    60	 * @returns `success: true` if the request is within the limit; `remaining` requests left
    61	 */
    62	export function rateLimit(
    63	  key: string,
    64	  limit: number,
    65	  windowMs: number
    66	): { success: boolean; remaining: number } {
    67	  const now = Date.now();
    68	  const windowStart = now - windowMs;
    69	
    70	  let entry = store.get(key);
    71	  if (!entry) {
    72	    entry = { timestamps: [] };
    73	    store.set(key, entry);
    74	  }
    75	
    76	  // Prune timestamps that have fallen outside the window
    77	  entry.timestamps = entry.timestamps.filter((t) => t > windowStart);
    78	
    79	  const count = entry.timestamps.length;
    80	
    81	  if (count >= limit) {
    82	    return { success: false, remaining: 0 };
    83	  }
    84	
    85	  // Record this request
    86	  entry.timestamps.push(now);
    87	  return { success: true, remaining: limit - count - 1 };
    88	}
