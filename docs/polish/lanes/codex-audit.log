     3	 * Creates authenticated Supabase clients for server components and API routes.
     4	 */
     5	
     6	import "server-only";
     7	import { createServerClient } from "@supabase/ssr";
     8	import { cookies } from "next/headers";
     9	
    10	/**
    11	 * Create a Supabase client for server-side use.
    12	 * Reads auth cookies from the request to maintain session state.
    13	 */
    14	export async function createSupabaseServer() {
    15	  const cookieStore = await cookies();
    16	
    17	  return createServerClient(
    18	    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    19	    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    20	    {
    21	      cookies: {
    22	        getAll() {
    23	          return cookieStore.getAll();
    24	        },
    25	        setAll(cookiesToSet) {
    26	          try {
    27	            for (const { name, value, options } of cookiesToSet) {
    28	              cookieStore.set(name, value, options);
    29	            }
    30	          } catch {
    31	            // Cookies can only be set in Server Actions or Route Handlers
    32	          }
    33	        },
    34	      },
    35	    }
    36	  );
    37	}
     1	/**
     2	 * Supabase service-role client factory.
     3	 * Creates a client with full database access, bypassing Row Level Security.
     4	 *
     5	 * IMPORTANT: Only use server-side. Never expose the service role key to the client.
     6	 * Always apply manual authorization checks after using this client.
     7	 */
     8	
     9	import "server-only";
    10	import { createClient } from "@supabase/supabase-js";
    11	
    12	/**
    13	 * Create a Supabase client using the service role key.
    14	 * Bypasses RLS — caller is responsible for scoping queries by the authenticated entity's ID.
    15	 */
    16	export function createSupabaseServiceRole() {
    17	  return createClient(
    18	    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    19	    process.env.SUPABASE_SERVICE_ROLE_KEY!,
    20	    {
    21	      auth: {
    22	        autoRefreshToken: false,
    23	        persistSession: false,
    24	      },
    25	    }
    26	  );
    27	}
     1	/**
     2	 * tRPC server configuration.
     3	 * Defines context, middleware, and procedure helpers.
     4	 */
     5	
     6	import { initTRPC, TRPCError } from "@trpc/server";
     7	import superjson from "superjson";
     8	import { createSupabaseServer } from "../lib/supabase/server";
     9	import { createSupabaseServiceRole } from "../lib/supabase/service";
    10	
    11	/** tRPC context — available in all procedures */
    12	export interface TrpcContext {
    13	  /** Supabase client (always available) */
    14	  supabase: Awaited<ReturnType<typeof createSupabaseServer>>;
    15	  /** Authenticated user ID (null if not logged in) */
    16	  userId: string | null;
    17	  /** Partner record ID (null if not a partner) */
    18	  partnerId: string | null;
    19	  /** Client record ID (null if not a client portal user) */
    20	  clientId: string | null;
    21	  /** Incoming request headers — used for IP extraction in rate limiting */
    22	  headers: Headers | null;
    23	}
    24	
    25	/**
    26	 * Create the tRPC context for each request.
    27	 * Identifies both partner and client users from the session.
    28	 *
    29	 * Accepts an optional fetch `Request` so the raw headers are available
    30	 * inside procedure bodies (e.g. for rate limiting via x-forwarded-for).
    31	 */
    32	export async function createTrpcContext(opts?: {
    33	  req?: Request;
    34	}): Promise<TrpcContext> {
    35	  const supabase = await createSupabaseServer();
    36	  const {
    37	    data: { user },
    38	  } = await supabase.auth.getUser();
    39	
    40	  let partnerId: string | null = null;
    41	  let clientId: string | null = null;
    42	
    43	  if (user) {
    44	    // Check partner first (anon client + session, partner RLS allows self-read)
    45	    const { data: partner } = await supabase
    46	      .from("partner")
    47	      .select("id")
    48	      .eq("auth_user_id", user.id)
    49	      .maybeSingle();
    50	    partnerId = partner?.id ?? null;
    51	
    52	    // If not a partner, check client table using service role (no client RLS policies).
    53	    // Only active, non-deleted clients are granted portal access.
    54	    if (!partnerId) {
    55	      const serviceDb = createSupabaseServiceRole();
    56	      const { data: client } = await serviceDb
    57	        .from("client")
    58	        .select("id")
    59	        .eq("auth_user_id", user.id)
    60	        .eq("status", "active")
    61	        .is("deleted_at", null)
    62	        .maybeSingle();
    63	      clientId = client?.id ?? null;
    64	    }
    65	  }
    66	
    67	  return {
    68	    supabase,
    69	    userId: user?.id ?? null,
    70	    partnerId,
    71	    clientId,
    72	    headers: opts?.req?.headers ?? null,
    73	  };
    74	}
    75	
    76	const t = initTRPC.context<TrpcContext>().create({
    77	  transformer: superjson,
    78	});
    79	
    80	export const router = t.router;
    81	export const publicProcedure = t.procedure;
    82	
    83	/**
    84	 * Protected procedure — requires authenticated partner.
    85	 */
    86	export const protectedProcedure = t.procedure.use(async ({ ctx, next }) => {
    87	  if (!ctx.userId || !ctx.partnerId) {
    88	    throw new TRPCError({
    89	      code: "UNAUTHORIZED",
    90	      message: "Devi effettuare il login come professionista.",
    91	    });
    92	  }
    93	
    94	  return next({
    95	    ctx: {
    96	      ...ctx,
    97	      userId: ctx.userId,
    98	      partnerId: ctx.partnerId,
    99	    },
   100	  });
   101	});
   102	
   103	/**
   104	 * Client procedure — requires authenticated client portal user.
   105	 */
   106	export const clientProcedure = t.procedure.use(async ({ ctx, next }) => {
   107	  if (!ctx.userId || !ctx.clientId) {
   108	    throw new TRPCError({
   109	      code: "UNAUTHORIZED",
   110	      message: "Devi effettuare il login come cliente.",
   111	    });
   112	  }
   113	
   114	  return next({
   115	    ctx: {
   116	      ...ctx,
   117	      userId: ctx.userId,
   118	      clientId: ctx.clientId,
   119	    },
   120	  });
   121	});
     1	/**
     2	 * Portal Router — client-facing tRPC endpoints.
     3	 *
     4	 * All procedures require authenticated client session (clientProcedure).
     5	 * Data access uses service role to bypass partner-only RLS, scoped strictly by clientId.
     6	 *
     7	 * Endpoints:
     8	 * - getMyProfile        — client's own profile + coach info
     9	 * - getActivePlan       — active nutrition plan with supplement protocol
    10	 * - getExampleMeals     — alternative meals for swapping (by meal type + macro match)
    11	 * - getDashboardData    — weight trend, macro adherence, training consistency charts
    12	 * - getDiaryEntries     — food diary entries for a given date
    13	 * - addDiaryEntry       — add a diary entry
    14	 * - getTrainingLogs     — recent training sessions
    15	 * - addTrainingLog      — log a training session
    16	 * - getSnapshots        — weight/measurement history
    17	 * - addSnapshot         — log weight/measurements/photos
    18	 * - getMessages         — paginated message thread
    19	 * - sendMessage         — send a message to coach
    20	 * - markMessagesRead    — mark all coach messages as read
    21	 * - getCheckInStatus    — whether a check-in is pending
    22	 * - savePushSubscription — register browser push subscription
    23	 */
    24	
    25	import { z } from "zod/v4";
    26	import { router, clientProcedure } from "../trpc";
    27	import { TRPCError } from "@trpc/server";
    28	import { createSupabaseServiceRole } from "../../lib/supabase/service";
    29	import { toClientPlanHistory, type RawPlanRow } from "../plan-versioning";
    30	import type { SupplementEntry } from "../../pdf/types";
    31	import { rateLimit, getClientIp } from "../../lib/rate-limit";
    32	// #18 → portal: representative per-week training time from the client's latest
    33	// intake (_intake.training_sessions). Pure, framework-free helper shared with
    34	// the coach card so the portal timed-session box mirrors it exactly.
    35	import { firstTrainingTime, type RawSession } from "../../components/plan/peri-workout-timing";
    36	
    37	// ── Shared Helpers ────────────────────────────────────────────────────────────
    38	
    39	/** Return a fresh service-role Supabase client */
    40	function svc() {
    41	  return createSupabaseServiceRole();
    42	}
    43	
    44	// ── Input Schemas ─────────────────────────────────────────────────────────────
    45	
    46	// (mealTypeSchema removed with portal.getExampleMeals — chore/deadcode.)
    47	
    48	const diaryEntrySchema = z.object({
    49	  entryDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/, "Formato data: YYYY-MM-DD"), // ISO date YYYY-MM-DD
    50	  mealSlot: z.string().max(50).optional(),
    51	  foodItems: z
    52	    .array(
    53	      z.object({
    54	        name: z.string().max(200),
    55	        grams: z.number().min(0).max(5000),
    56	        kcal: z.number().min(0),
    57	        protein: z.number().min(0),
    58	        carbs: z.number().min(0),
    59	        fat: z.number().min(0),
    60	      })
    61	    )
    62	    .min(1),
    63	  notes: z.string().max(2000).optional(),
    64	});
    65	
    66	const trainingLogSchema = z.object({
    67	  dayType: z.enum(["training", "rest", "refeed", "deload"]),
    68	  durationMin: z.number().int().min(1).max(480).optional(),
    69	  avgHeartRate: z.number().int().min(40).max(250).optional(),
    70	  kcalEstimated: z.number().int().min(0).max(5000).optional(),
    71	  steps: z.number().int().min(0).max(100000).optional(),
    72	  rpe: z.number().min(1).max(10).optional(),
    73	  trainingNotes: z.string().max(2000).optional(),
    74	  // Storage paths (e.g. "training-screenshots/<pid>/<cid>/<file>") OR https URLs.
    75	  screenshotUrls: z.array(z.string().min(1).max(500)).max(10).optional(),
    76	});
    77	
    78	const snapshotSchema = z.object({
    79	  weightKg: z.number().min(30).max(300).optional(),
    80	  bodyFatPct: z.number().min(3).max(60).optional(),
    81	  notes: z.string().max(2000).optional(),
    82	  // #27 Stage 3: progress photos. Storage paths
    83	  // ("client-photos/<partner_id>/<client_id>/<file>") OR https URLs, like the
    84	  // training_log.screenshotUrls pattern. Persisted to client_snapshot.photo_*_url.
    85	  photoFrontUrl: z.string().min(1).max(500).optional(),
    86	  photoSideUrl: z.string().min(1).max(500).optional(),
    87	  photoBackUrl: z.string().min(1).max(500).optional(),
    88	});
    89	
    90	// ── Router ────────────────────────────────────────────────────────────────────
    91	
    92	export const portalRouter = router({
    93	  /**
    94	   * Get the client's own profile including coach information.
    95	   */
    96	  getMyProfile: clientProcedure.query(async ({ ctx }) => {
    97	    const db = svc();
    98	    const { data, error } = await db
    99	      .from("client")
   100	      .select(
   101	        `id, full_name, email, phone, date_of_birth, sex, status, tags,
   102	         partner:partner_id (id, full_name, email, avatar_url)`
   103	      )
   104	      .eq("id", ctx.clientId)
   105	      .single();
   106	
   107	    if (error || !data) {
   108	      throw new TRPCError({
   109	        code: "NOT_FOUND",
   110	        message: "Profilo cliente non trovato.",
   111	      });
   112	    }
   113	
   114	    return data;
   115	  }),
   116	
   117	  /**
   118	   * Get the client's active nutrition plan with supplement protocol.
   119	   */
   120	  getActivePlan: clientProcedure.query(async ({ ctx }) => {
   121	    const db = svc();
   122	    const { data, error } = await db
   123	      .from("plan")
   124	      .select(
   125	        `id, name, status, start_date, end_date, daily_targets,
   126	         water_ml_training, water_ml_rest, salt_g_training, salt_g_rest,
   127	         meals_per_day, meal_distribution, diet_emphasis, notes`
   128	      )
   129	      .eq("client_id", ctx.clientId)
   130	      .eq("status", "active")
   131	      .is("deleted_at", null)
   132	      .order("created_at", { ascending: false })
   133	      .limit(1)
   134	      .maybeSingle();
   135	
   136	    if (error) {
   137	      console.error("[router/portal.getActivePlan]", error);
   138	      throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nel caricamento dei dati." });
   139	    }
   140	
   141	    if (!data) return null;
   142	
   143	    // Extract the meal plan from the plan bundle stored in daily_targets.
   144	    // The engine writes meal data to daily_targets.plan_bundle.reportData.dayTypePlans,
   145	    // not to the meal_distribution column (which is never written during plan generation).
   146	    const planBundle = (data.daily_targets as Record<string, unknown> | null)?.plan_bundle as Record<string, unknown> | undefined;
   147	    const dayTypePlans = (planBundle?.reportData as Record<string, unknown> | undefined)?.dayTypePlans ?? [];
   148	    // #23: supplements live in the plan bundle (coach-curated), NOT the write-dead
   149	    // supplement_protocol relation. Read what the coach actually set.
   150	    const supplements = (planBundle?.supplements as SupplementEntry[] | undefined) ?? [];
   151	
   152	    // #18 → portal: expose the client's representative training time so the
   153	    // patient can render the same PeriWorkoutTimingCard the coach sees. Read it
   154	    // from the latest snapshot's intake (display-only; the engine ignores it).
   155	    // ADDITIVE + ctx.clientId-scoped. Absent training time → {} → no box.
   156	    const { data: snap } = await db
   157	      .from("client_snapshot")
   158	      .select("skinfold_data")
   159	      .eq("client_id", ctx.clientId)
   160	      .order("taken_at", { ascending: false })
   161	      .limit(1)
   162	      .maybeSingle();
   163	    const trainingSessions = (
   164	      (snap?.skinfold_data as { _intake?: { training_sessions?: Record<string, RawSession[]> } } | null)
   165	        ?._intake?.training_sessions
   166	    );
   167	    const trainingTime = firstTrainingTime(trainingSessions);
   168	
   169	    return {
   170	      ...data,
   171	      mealPlan: dayTypePlans as Array<{ dayType: string; label: string; mealPlan?: { withinTolerance: boolean; slots: Array<{ slot: string; primary: { template: { name: string }; scaledIngredients: Array<{ name: string; grams: number }>; actualMacros: { kcal: number; proteinG: number; carbsG: number; fatG: number } } }> } }>,
   172	      supplements,
   173	      trainingTime,
   174	    };
   175	  }),
   176	
   177	  /**
   178	   * Get the authenticated client's own plan version history (PR #10 portal
   179	   * "Storico piani"), newest-first. Strictly scoped to ctx.clientId so a patient
   180	   * can only ever see their own plans. CLIENT-VISIBLE fields only — coach-only
   181	   * internals (change_reason, review notes) are never exposed. Returns all of the
   182	   * client's versions across any chains, each tagged with rootPlanId for grouping.
   183	   */
   184	  getPlanHistory: clientProcedure.query(async ({ ctx }) => {
   185	    const db = svc();
   186	    const { data: rows, error } = await db
   187	      .from("plan")
   188	      .select("id, status, version_number, version_label, parent_plan_id, created_at")
   189	      .eq("client_id", ctx.clientId)
   190	      .is("deleted_at", null)
   191	      .order("created_at", { ascending: false });
   192	
   193	    if (error) {
   194	      console.error("[router/portal.getPlanHistory]", error);
   195	      throw new TRPCError({
   196	        code: "INTERNAL_SERVER_ERROR",
   197	        message: "Errore nel caricamento dello storico piani.",
   198	      });
   199	    }
   200	
   201	    return { versions: toClientPlanHistory((rows ?? []) as RawPlanRow[]) };
   202	  }),
   203	
   204	  /**
   205	   * #27 Stage 3 — the patient's OWN documents (PDFs etc.). The document table is
   206	   * coach-managed (document.ts is protectedProcedure); this is the patient read,
   207	   * STRICTLY scoped to ctx.clientId (a client never sees another client's docs).
   208	   * Newest-first, soft-deletes excluded.
   209	   */
   210	  getDocuments: clientProcedure.query(async ({ ctx }) => {
   211	    const db = svc();
   212	    const { data, error } = await db
   213	      .from("document")
   214	      .select("id, title, doc_type, file_url, mime_type, file_size_bytes, created_at")
   215	      .eq("client_id", ctx.clientId)
   216	      .is("deleted_at", null)
   217	      .order("created_at", { ascending: false });
   218	
   219	    if (error) {
   220	      console.error("[router/portal.getDocuments]", error);
   221	      throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nel caricamento dei documenti." });
   222	    }
   223	
   224	    return { documents: data ?? [] };
   225	  }),
   226	
   227	  /**
   228	   * #27 Stage 3 — the patient's OWN notification feed (the partner/coach feed is
   229	   * notification.getForClient). STRICTLY scoped to ctx.clientId, newest-first,
   230	   * plus a cheap unread count for a badge.
   231	   */
   232	  getNotifications: clientProcedure
   233	    .input(
   234	      z.object({
   235	        unreadOnly: z.boolean().optional(),
   236	        limit: z.number().int().min(1).max(100).default(30),
   237	      }).optional()
   238	    )
   239	    .query(async ({ ctx, input }) => {
   240	      const db = svc();
   241	      let query = db
   242	        .from("notification")
   243	        .select("id, trigger, priority, title, body, read, metadata, created_at")
   244	        .eq("client_id", ctx.clientId);
   245	      if (input?.unreadOnly) query = query.eq("read", false);
   246	
   247	      const { data, error } = await query
   248	        .order("created_at", { ascending: false })
   249	        .limit(input?.limit ?? 30);
   250	
   251	      if (error) {
   252	        console.error("[router/portal.getNotifications]", error);
   253	        throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nel caricamento delle notifiche." });
   254	      }
   255	
   256	      const { count, error: countError } = await db
   257	        .from("notification")
   258	        .select("id", { count: "exact", head: true })
   259	        .eq("client_id", ctx.clientId)
   260	        .eq("read", false);
   261	      if (countError) {
   262	        console.error("[router/portal.getNotifications] count", countError);
   263	      }
   264	
   265	      return { notifications: data ?? [], unreadCount: count ?? 0 };
   266	    }),
   267	
   268	  // NOTE (chore/deadcode): portal.getExampleMeals was removed here — 0 callers
   269	  // across all of src. The `example_meal` table is now unreferenced by any code
   270	  // → orphan / DROP candidate for a future migration (James applies schema changes).
   271	
   272	  /**
   273	   * Aggregated dashboard data: weight trend, macro adherence, training consistency.
   274	   */
   275	  getDashboardData: clientProcedure.query(async ({ ctx }) => {
   276	    const db = svc();
   277	
   278	    const [checkInsResult, trainingResult, diaryResult, planResult] = await Promise.all([
   279	      // Weight trend from last 16 check-ins
   280	      db
   281	        .from("check_in")
   282	        .select("check_in_date, weight_kg, nutrition_adherence, training_adherence")
   283	        .eq("client_id", ctx.clientId)
   284	        .order("check_in_date", { ascending: true })
   285	        .limit(16),
   286	
   287	      // Training logs last 30 days for consistency
   288	      db
   289	        .from("training_log")
   290	        .select("logged_at, day_type, kcal_calculated, kcal_override")
   291	        .eq("client_id", ctx.clientId)
   292	        .order("logged_at", { ascending: false })
   293	        .limit(30),
   294	
   295	      // Diary entries last 14 days for macro adherence
   296	      db
   297	        .from("diary_entry")
   298	        .select("entry_date, total_kcal, total_protein_g, total_carbs_g, total_fat_g")
   299	        .eq("client_id", ctx.clientId)
   300	        .order("entry_date", { ascending: false })
   301	        .limit(14),
   302	
   303	      // Active plan for targets
   304	      db
   305	        .from("plan")
   306	        .select("daily_targets, meals_per_day")
   307	        .eq("client_id", ctx.clientId)
   308	        .eq("status", "active")
   309	        .is("deleted_at", null)
   310	        .order("created_at", { ascending: false })
   311	        .limit(1)
   312	        .maybeSingle(),
   313	    ]);
   314	
   315	    return {
   316	      weightTrend: checkInsResult.data ?? [],
   317	      trainingLogs: trainingResult.data ?? [],
   318	      diaryEntries: diaryResult.data ?? [],
   319	      activePlan: planResult.data ?? null,
   320	    };
   321	  }),
   322	
   323	  /**
   324	   * Get food diary entries for a specific date.
   325	   */
   326	  getDiaryEntries: clientProcedure
   327	    .input(z.object({ date: z.string().regex(/^\d{4}-\d{2}-\d{2}$/, "Formato data: YYYY-MM-DD") })) // ISO date YYYY-MM-DD
   328	    .query(async ({ ctx, input }) => {
   329	      const db = svc();
   330	      const { data, error } = await db
   331	        .from("diary_entry")
   332	        .select("*")
   333	        .eq("client_id", ctx.clientId)
   334	        .eq("entry_date", input.date)
   335	        .order("created_at", { ascending: true });
   336	
   337	      if (error) {
   338	        console.error("[router/portal.getDiaryEntries]", error);
   339	        throw new TRPCError({ code: "INTERNAL_SERVER_ERROR", message: "Errore nel caricamento dei dati." });
   340	      }
   341	
   342	      return data ?? [];
   343	    }),
   344	
   345	  /**
   346	   * Add a food diary entry.
   347	   */
   348	  addDiaryEntry: clientProcedure
   349	    .input(diaryEntrySchema)
   350	    .mutation(async ({ ctx, input }) => {
   351	      const db = svc();
   352	
   353	      // Compute totals from food items
   354	      const totals = input.foodItems.reduce(
   355	        (acc, item) => ({
   356	          kcal: acc.kcal + item.kcal,
   357	          protein: acc.protein + item.protein,
   358	          carbs: acc.carbs + item.carbs,
   359	          fat: acc.fat + item.fat,
   360	        }),
   361	        { kcal: 0, protein: 0, carbs: 0, fat: 0 }
   362	      );
   363	
   364	      // Get active plan id for FK
   365	      const { data: plan } = await db
   366	        .from("plan")
   367	        .select("id")
   368	        .eq("client_id", ctx.clientId)
   369	        .eq("status", "active")
   370	        .limit(1)
   371	        .maybeSingle();
   372	
   373	      const { data, error } = await db
   374	        .from("diary_entry")
   375	        .insert({
   376	          client_id: ctx.clientId,
   377	          plan_id: plan?.id ?? null,
   378	          entry_date: input.entryDate,
   379	          meal_slot: input.mealSlot ?? null,
   380	          food_items: input.foodItems,
   381	          total_kcal: totals.kcal,
