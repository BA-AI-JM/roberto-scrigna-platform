   343	              macroOptions: {
   344	                ...input.engineOptions?.macroOptions,
   345	                injuryProteinBumpGPerKg: inj.injuryProteinBumpGPerKg,
   346	              },
   347	            }
   348	          : {}),
   349	      }
   350	    : input.engineOptions;
   351	  const weeklyPlan = generateWeeklyPlan(snapshot, engineOptions);
   352	
   353	  // ── Step 3: Meal plans per unique day type ─────────────────────────────
   354	  const uniqueDayTypes = [
   355	    ...new Set(snapshot.weekSchedule),
   356	  ] as DayType[];
   357	
   358	  const mealPlans = new Map<DayType, DayMealPlan>();
   359	  for (const dayType of uniqueDayTypes) {
   360	    const dayPlan = weeklyPlan.days.find((d) => d.dayType === dayType);
   361	    if (!dayPlan) continue;
   362	
   363	    const config: MealPlanConfig = {
   364	      dayType,
   365	      macroTargets: dayPlan.macros,
   366	      mealCount: input.mealCount ?? input.mealPlanConfig?.mealCount ?? 4,
   367	      excludeAllergens: input.excludeAllergens ?? input.mealPlanConfig?.excludeAllergens,
   368	      preferTags: input.preferTags ?? input.mealPlanConfig?.preferTags,
   369	      substitutionsPerSlot: input.mealPlanConfig?.substitutionsPerSlot,
   370	      fibreTargetPer1000: input.mealPlanConfig?.fibreTargetPer1000,
   371	      // #11 restriction protocols → JOINT solver/reconcile constraints.
   372	      ...(input.protocols?.fibreRestriction
   373	        ? { fibreMode: "cap" as const, fibreCapG: FIBRE_RESTRICTION_CAP_G }
   374	        : {}),
   375	      ...(input.protocols?.sodiumRestriction
   376	        ? { sodiumCapMg: SODIUM_RESTRICTION_CAP_MG }
