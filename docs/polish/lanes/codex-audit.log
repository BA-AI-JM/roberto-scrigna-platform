   153	export async function createNotification(params: {
   154	  partnerId: string;
   155	  clientId?: string;
   156	  trigger: string;
   157	  title: string;
   158	  body: string;
   159	  metadata?: Record<string, unknown>;
   160	}) {
   161	  const db = getServiceDb();
   162	  const { error } = await db.from("notification").insert({
   163	    partner_id: params.partnerId,
   164	    client_id: params.clientId ?? null,
   165	    trigger: params.trigger,
   166	    priority: TRIGGER_PRIORITY[params.trigger] ?? "medium",
   167	    title: params.title,
   168	    body: params.body,
   169	    metadata: params.metadata ?? {},
   170	    read: false,
   171	  });
   172	  // Throw so the Inngest step FAILS (retries / shows a failed run) instead of
   173	  // silently succeeding while the coach never gets the alert (#2, mirrors sendEmail).
   174	  if (error) {
   175	    throw new Error(
   176	      `createNotification insert failed (trigger=${params.trigger}): ${error.message}`
   177	    );
   178	  }
   179	}
