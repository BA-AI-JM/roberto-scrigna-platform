     1	-- Roberto Scrigna Platform: Initial Database Schema
     2	-- Reconciled with all tRPC routers and Inngest functions
     3	--
     4	-- Tables: Partner, Client, ClientSnapshot, Plan, TrainingLog, CheckIn,
     5	--         CheckInToken, SupplementProtocol, SupplementItem, GuidanceBlock,
     6	--         Document, Invoice, Notification, NotificationSettings, Task,
     7	--         Message, DiaryEntry, ExampleMeal
     8	--
     9	-- Conventions:
    10	-- - UUIDs as primary keys (gen_random_uuid())
    11	-- - Soft deletes (deleted_at) where applicable
    12	-- - Audit columns (created_at, updated_at)
    13	-- - snake_case naming
    14	-- - RLS enabled on all tables
    15	
    16	-- ── Extensions ────────────────────────────────────────────────────────────────
    17	
    18	CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
    19	
    20	-- ── Partner (Coach / Admin) ───────────────────────────────────────────────────
    21	
    22	CREATE TABLE partner (
    23	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    24	  auth_user_id UUID UNIQUE NOT NULL, -- links to Supabase auth.users
    25	  full_name TEXT NOT NULL,
    26	  email TEXT NOT NULL,
    27	  role TEXT NOT NULL DEFAULT 'coach' CHECK (role IN ('coach', 'admin', 'assistant')),
    28	  avatar_url TEXT,
    29	  is_active BOOLEAN NOT NULL DEFAULT true,
    30	  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    31	  updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    32	  deleted_at TIMESTAMPTZ
    33	);
    34	
    35	-- ── Client ────────────────────────────────────────────────────────────────────
    36	
    37	CREATE TABLE client (
    38	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    39	  auth_user_id UUID UNIQUE, -- nullable: client may not have login yet
    40	  partner_id UUID NOT NULL REFERENCES partner(id),
    41	  full_name TEXT NOT NULL,
    42	  email TEXT,
    43	  phone TEXT,
    44	  date_of_birth DATE,
    45	  sex TEXT CHECK (sex IN ('male', 'female')),
    46	  status TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'paused', 'archived')),
    47	  notes TEXT,
    48	  tags TEXT[] DEFAULT '{}',
    49	  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    50	  updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    51	  deleted_at TIMESTAMPTZ
    52	);
    53	
    54	CREATE INDEX idx_client_partner ON client(partner_id);
    55	CREATE INDEX idx_client_status ON client(status) WHERE deleted_at IS NULL;
    56	
    57	-- ── Client Snapshot (point-in-time measurements) ──────────────────────────────
    58	
    59	CREATE TABLE client_snapshot (
    60	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    61	  client_id UUID NOT NULL REFERENCES client(id),
    62	  taken_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    63	
    64	  -- Basic measurements
    65	  weight_kg NUMERIC(5,2),
    66	  height_cm NUMERIC(5,1),
    67	  age_years INTEGER,
    68	
    69	  -- Body composition
    70	  body_fat_pct NUMERIC(4,1),
    71	  body_fat_method TEXT CHECK (body_fat_method IN ('7site', '3site', 'heuristic', 'override', 'dexa', 'bioimpedance')),
    72	
    73	  -- Skinfold data (JSON for flexibility)
    74	  skinfold_data JSONB,
    75	
    76	  -- Activity
    77	  daily_steps INTEGER,
    78	  occupational_level TEXT CHECK (occupational_level IN ('sedentary', 'light', 'moderate', 'heavy', 'very_heavy')),
    79	
    80	  -- Training schedule (7-element array: Mon-Sun)
    81	  week_schedule TEXT[] CHECK (array_length(week_schedule, 1) = 7),
    82	
    83	  -- Calculated values (denormalized for historical reference)
    84	  bmr_kcal INTEGER,
    85	  lean_mass_kg NUMERIC(5,2),
    86	  fat_mass_kg NUMERIC(5,2),
    87	
    88	  -- Photos
    89	  photo_front_url TEXT,
    90	  photo_side_url TEXT,
    91	  photo_back_url TEXT,
    92	
    93	  notes TEXT,
    94	  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    95	  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
    96	);
    97	
    98	CREATE INDEX idx_snapshot_client ON client_snapshot(client_id);
    99	CREATE INDEX idx_snapshot_taken ON client_snapshot(client_id, taken_at DESC);
   100	
   101	-- ── Plan (nutrition plan per client) ──────────────────────────────────────────
   102	
   103	CREATE TABLE plan (
   104	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
   105	  client_id UUID NOT NULL REFERENCES client(id),
   106	  snapshot_id UUID REFERENCES client_snapshot(id),
   107	  partner_id UUID NOT NULL REFERENCES partner(id),
   108	
   109	  name TEXT NOT NULL,
   110	  status TEXT NOT NULL DEFAULT 'draft' CHECK (status IN ('draft', 'active', 'completed', 'archived')),
   111	  start_date DATE,
   112	  end_date DATE,
   113	
   114	  -- TDEE & macro targets per day type (JSONB for flexibility)
   115	  -- Also stores plan_bundle and macro_payload from the engine
   116	  daily_targets JSONB NOT NULL DEFAULT '{}',
   117	
   118	  -- Hydration
   119	  water_ml_training INTEGER,
   120	  water_ml_rest INTEGER,
   121	  salt_g_training NUMERIC(3,1),
   122	  salt_g_rest NUMERIC(3,1),
   123	
   124	  -- Meal structure
   125	  meals_per_day INTEGER DEFAULT 4,
   126	  meal_distribution JSONB, -- e.g. { "breakfast": 0.25, "lunch": 0.35, ... }
   127	
   128	  -- Configuration
   129	  diet_emphasis TEXT CHECK (diet_emphasis IN ('high_protein', 'mixed', 'high_fat')),
   130	  exercise_session JSONB, -- serialized ExerciseSession
   131	
   132	  notes TEXT,
   133	  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
   134	  updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
   135	  deleted_at TIMESTAMPTZ
   136	);
   137	
   138	CREATE INDEX idx_plan_client ON plan(client_id);
   139	CREATE INDEX idx_plan_status ON plan(status) WHERE deleted_at IS NULL;
   140	
   141	-- ── Training Log ──────────────────────────────────────────────────────────────
   142	-- Used by training-log.ts router (partner-facing) and portal.ts (client-facing)
   143	
   144	CREATE TABLE training_log (
   145	  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
   146	  client_id UUID NOT NULL REFERENCES client(id),
   147	  partner_id UUID REFERENCES partner(id),
   148	  plan_id UUID REFERENCES plan(id),
   149	
   150	  -- Date/time
   151	  logged_at TIMESTAMPTZ NOT NULL DEFAULT now(),
   152	  session_date DATE, -- ISO date from training-log router
   153	
   154	  -- Day/session classification
   155	  day_type TEXT CHECK (day_type IN ('training', 'rest', 'refeed', 'deload')),
   156	  session_type TEXT CHECK (session_type IN ('strength', 'hypertrophy', 'cardio', 'hiit', 'flexibility', 'deload', 'other')),
   157	
   158	  -- Exercise data
   159	  exercise_method TEXT CHECK (exercise_method IN ('heart_rate', 'met_value', 'session_estimate', 'default_estimate')),
   160	  duration_min INTEGER,
   161	  duration_minutes INTEGER, -- used by training-log router
   162	  avg_heart_rate INTEGER,
   163	  met_value NUMERIC(4,1),
   164	  kcal_estimated INTEGER,
   165	  kcal_calculated INTEGER,
   166	
   167	  -- Steps
   168	  steps INTEGER,
   169	
   170	  -- Adherence
   171	  training_notes TEXT,
   172	  rpe NUMERIC(3,1), -- Rate of Perceived Exertion (1-10)
   173	  perceived_effort INTEGER CHECK (perceived_effort BETWEEN 1 AND 10),
   174	
   175	  -- Exercise details (JSON array of exercise entries)
   176	  exercises JSONB DEFAULT '[]',
