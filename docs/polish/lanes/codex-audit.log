   665	        endpoint: z.string().url().startsWith("https://"),
   666	        keys: z.object({
   667	          p256dh: z.string(),
   668	          auth: z.string(),
   669	        }),
   670	      })
   671	    )
   672	    .mutation(async ({ ctx, input }) => {
   673	      // Stored in client.notes as a workaround until push_subscription table is added
   674	      // Real implementation: upsert into push_subscription table
   675	      void ctx; // suppress unused warning
   676	      void input;
   677	      return { success: true };
   678	    }),
   679	});
     1	/**
     2	 * Check-in Router
     3	 *
     4	 * tRPC procedures for the client check-in system:
     5	 * - sendCheckin: generate token + send email link to client
     6	 * - validateToken: verify a check-in token is valid
     7	 * - submitCheckin: client submits check-in via token-authenticated form
     8	 * - list: list check-ins for partner (with optional client filter)
     9	 * - getById: single check-in with deviation flags
    10	 * - batchReview: fetch pending check-ins with AI summary stubs
    11	 * - markReviewed: mark a check-in as reviewed
    12	 */
    13	
    14	import { z } from "zod/v4";
    15	import { router, protectedProcedure, publicProcedure } from "../trpc";
    16	import { TRPCError } from "@trpc/server";
    17	import { inngest } from "../../lib/inngest/client";
    18	import { rateLimit, getClientIp } from "../../lib/rate-limit";
    19	
    20	// ── Schemas ──────────────────────────────────────────────────────────────────
    21	
    22	/** Weight deviation threshold in kg — flags if check-in weight differs by more than this */
    23	const WEIGHT_DEVIATION_THRESHOLD_KG = 1.5;
    24	
    25	/** Check-in questionnaire submission schema */
    26	const checkinSubmissionSchema = z.object({
    27	  token: z.string().uuid(),
    28	  weightKg: z.number().min(30).max(300),
    29	  waistCm: z.number().min(40).max(200).optional(),
    30	  hipCm: z.number().min(50).max(200).optional(),
    31	  energyLevel: z.number().int().min(1).max(10),
    32	  sleepQuality: z.number().int().min(1).max(10),
    33	  stressLevel: z.number().int().min(1).max(10),
    34	  hungerLevel: z.number().int().min(1).max(10),
    35	  digestiveHealth: z.number().int().min(1).max(10),
    36	  adherencePct: z.number().int().min(0).max(100),
    37	  trainingAdherence: z.number().int().min(0).max(100).optional(),
    38	  notes: z.string().max(5000).optional(),
    39	  // Only allow https:// URLs to prevent javascript: or data: URI injection.
    40	  // URLs are stored and later rendered as <img> src or download links.
    41	  photos: z.array(z.string().url().startsWith("https://")).max(5).optional(),
    42	});
    43	
    44	// ── Helpers ──────────────────────────────────────────────────────────────────
    45	
    46	/** Compute weight deviation flag from previous check-in or snapshot */
    47	function computeWeightDeviation(
    48	  currentKg: number,
    49	  previousKg: number | null
    50	): { deviationKg: number; flagged: boolean } | null {
    51	  if (previousKg === null) return null;
    52	  const deviationKg = currentKg - previousKg;
    53	  return {
    54	    deviationKg: Math.round(deviationKg * 100) / 100,
    55	    flagged: Math.abs(deviationKg) > WEIGHT_DEVIATION_THRESHOLD_KG,
    56	  };
    57	}
    58	
    59	/** Generate a simple AI summary stub from check-in data */
    60	function generateCheckinSummary(data: {
    61	  weightKg: number;
    62	  energyLevel: number;
    63	  sleepQuality: number;
    64	  stressLevel: number;
    65	  adherencePct: number;
    66	  deviationKg: number | null;
    67	}): string {
    68	  const parts: string[] = [];
    69	
    70	  if (data.deviationKg !== null) {
    71	    const dir = data.deviationKg > 0 ? "+" : "";
    72	    parts.push(`Peso: ${data.weightKg}kg (${dir}${data.deviationKg}kg)`);
    73	  } else {
    74	    parts.push(`Peso: ${data.weightKg}kg (primo check-in)`);
    75	  }
    76	
    77	  if (data.energyLevel <= 4) parts.push("⚠️ Energia bassa");
    78	  if (data.sleepQuality <= 4) parts.push("⚠️ Sonno scarso");
    79	  if (data.stressLevel >= 7) parts.push("⚠️ Stress elevato");
    80	  if (data.adherencePct < 70) parts.push("⚠️ Aderenza sotto 70%");
    81	
    82	  if (data.energyLevel >= 7 && data.sleepQuality >= 7 && data.adherencePct >= 85) {
    83	    parts.push("✅ Buoni progressi generali");
    84	  }
    85	
    86	  return parts.join(" · ");
    87	}
    88	
    89	// ── Router ───────────────────────────────────────────────────────────────────
    90	
    91	export const checkinRouter = router({
    92	  /**
    93	   * Send check-in request to a client.
    94	   * Generates a unique token and stores it for token-based authentication.
    95	   */
    96	  sendCheckin: protectedProcedure
    97	    .input(
    98	      z.object({
    99	        clientId: z.string().uuid(),
   100	        dueDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/, "Formato data: YYYY-MM-DD").optional(),
   101	      })
   102	    )
   103	    .mutation(async ({ ctx, input }) => {
   104	      // Verify client ownership
   105	      const { data: client } = await ctx.supabase
   106	        .from("client")
   107	        .select("id, full_name, email")
   108	        .eq("id", input.clientId)
   109	        .eq("partner_id", ctx.partnerId)
   110	        .is("deleted_at", null)
   111	        .single();
   112	
   113	      if (!client) {
   114	        throw new TRPCError({ code: "NOT_FOUND", message: "Cliente non trovato." });
   115	      }
   116	
   117	      if (!client.email) {
   118	        throw new TRPCError({
   119	          code: "BAD_REQUEST",
   120	          message: "Il cliente non ha un indirizzo email.",
   121	        });
   122	      }
   123	
   124	      // Create check-in request with token
   125	      const { data: checkin, error } = await ctx.supabase
   126	        .from("check_in")
   127	        .insert({
   128	          client_id: input.clientId,
   129	          partner_id: ctx.partnerId,
   130	          status: "pending",
   131	          due_date: input.dueDate ?? null,
   132	        })
   133	        .select("id, token")
   134	        .single();
   135	
   136	      if (error || !checkin) {
   137	        throw new TRPCError({
   138	          code: "INTERNAL_SERVER_ERROR",
   139	          message: error?.message ?? "Errore nella creazione del check-in.",
   140	        });
   141	      }
   142	
   143	      // Dispatch checkin/due event — wrapped so dispatch failure never breaks the response
   144	      try {
   145	        await inngest.send({
   146	          name: "checkin/due",
   147	          data: {
   148	            checkinId: checkin.id,
   149	            clientId: input.clientId,
   150	            clientName: client.full_name,
   151	            partnerId: ctx.partnerId,
   152	            dueDate: input.dueDate ?? null,
   153	          },
   154	        });
   155	      } catch (err) {
   156	        console.error("[router/checkin.sendCheckin] inngest.send failed:", err);
   157	      }
   158	
   159	      return {
   160	        checkinId: checkin.id,
   161	        token: checkin.token,
   162	        clientName: client.full_name,
   163	        clientEmail: client.email,
   164	      };
   165	    }),
   166	
   167	  /**
   168	   * Validate a check-in token (public — used by client-facing form).
   169	   */
   170	  validateToken: publicProcedure
   171	    .input(z.object({ token: z.string().uuid() }))
   172	    .query(async ({ ctx, input }) => {
   173	      const ip = getClientIp(ctx.headers);
   174	      const { success } = rateLimit(`validateToken:${ip}`, 30, 60_000);
   175	      if (!success) {
   176	        throw new TRPCError({ code: "TOO_MANY_REQUESTS", message: "Troppi tentativi. Riprova tra poco." });
   177	      }
   178	
   179	      const { data: checkin } = await ctx.supabase
   180	        .from("check_in")
   181	        .select(
   182	          `id, status, due_date, created_at,
   183	           client:client_id (id, full_name)`
   184	        )
   185	        .eq("token", input.token)
   186	        .eq("status", "pending")
   187	        .single();
   188	
   189	      if (!checkin) {
   190	        return { valid: false as const, checkin: null };
   191	      }
   192	
   193	      return { valid: true as const, checkin };
   194	    }),
   195	
   196	  /**
   197	   * Submit check-in data (public — authenticated via token).
   198	   */
   199	  submitCheckin: publicProcedure
   200	    .input(checkinSubmissionSchema)
   201	    .mutation(async ({ ctx, input }) => {
   202	      const ip = getClientIp(ctx.headers);
   203	      const { success } = rateLimit(`submitCheckin:${ip}`, 10, 60_000);
   204	      if (!success) {
   205	        throw new TRPCError({ code: "TOO_MANY_REQUESTS", message: "Troppi tentativi. Riprova tra poco." });
   206	      }
   207	
   208	      // 1. Validate token
   209	      const { data: checkin } = await ctx.supabase
   210	        .from("check_in")
   211	        .select("id, client_id, partner_id, status")
   212	        .eq("token", input.token)
   213	        .eq("status", "pending")
   214	        .single();
   215	
   216	      if (!checkin) {
   217	        throw new TRPCError({
   218	          code: "NOT_FOUND",
   219	          message: "Check-in non trovato o già completato.",
   220	        });
   221	      }
   222	
   223	      // 2. Get previous weight for deviation calculation
   224	      const { data: previousCheckin } = await ctx.supabase
   225	        .from("check_in")
   226	        .select("weight_kg")
   227	        .eq("client_id", checkin.client_id)
   228	        .eq("status", "completed")
   229	        .order("completed_at", { ascending: false })
   230	        .limit(1)
   231	        .single();
   232	
   233	      let previousKg = previousCheckin?.weight_kg ?? null;
   234	
   235	      // If no previous check-in, try initial snapshot
   236	      if (previousKg === null) {
   237	        const { data: snapshot } = await ctx.supabase
   238	          .from("client_snapshot")
   239	          .select("weight_kg")
   240	          .eq("client_id", checkin.client_id)
   241	          .order("taken_at", { ascending: false })
   242	          .limit(1)
   243	          .single();
   244	        previousKg = snapshot?.weight_kg ?? null;
   245	      }
   246	
   247	      const deviation = computeWeightDeviation(input.weightKg, previousKg);
   248	      const summary = generateCheckinSummary({
   249	        weightKg: input.weightKg,
   250	        energyLevel: input.energyLevel,
   251	        sleepQuality: input.sleepQuality,
   252	        stressLevel: input.stressLevel,
   253	        adherencePct: input.adherencePct,
   254	        deviationKg: deviation?.deviationKg ?? null,
   255	      });
   256	
   257	      // 3. Update the check-in record
   258	      const { error } = await ctx.supabase
   259	        .from("check_in")
   260	        .update({
   261	          status: "completed",
   262	          completed_at: new Date().toISOString(),
   263	          weight_kg: input.weightKg,
   264	          waist_cm: input.waistCm ?? null,
   265	          hip_cm: input.hipCm ?? null,
   266	          energy_level: input.energyLevel,
   267	          sleep_quality: input.sleepQuality,
   268	          stress_level: input.stressLevel,
   269	          hunger_level: input.hungerLevel,
   270	          digestive_health: input.digestiveHealth,
   271	          adherence_pct: input.adherencePct,
   272	          training_adherence: input.trainingAdherence ?? null,
   273	          notes: input.notes ?? null,
   274	          photos: input.photos ?? [],
   275	          weight_deviation_kg: deviation?.deviationKg ?? null,
   276	          weight_flagged: deviation?.flagged ?? false,
   277	          ai_summary: summary,
   278	        })
   279	        .eq("id", checkin.id);
   280	
   281	      if (error) {
   282	        console.error("[router/checkin.submitCheckin]", error);
