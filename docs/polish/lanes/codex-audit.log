  1157	  /**
  1158	   * Approve a plan (set status → active).
  1159	   */
  1160	  approve: protectedProcedure
  1161	    .input(z.object({ id: z.string().uuid() }))
  1162	    .mutation(async ({ ctx, input }) => {
  1163	      // Verify ownership first — include client_id so we can dispatch the event
  1164	      const { data: plan } = await ctx.supabase
  1165	        .from("plan")
  1166	        .select("id, client_id, daily_targets, start_date")
  1167	        .eq("id", input.id)
  1168	        .eq("partner_id", ctx.partnerId)
  1169	        .is("deleted_at", null)
  1170	        .single();
  1171	
  1172	      if (!plan) {
  1173	        throw new TRPCError({
  1174	          code: "NOT_FOUND",
  1175	          message: "Piano non trovato.",
  1176	        });
  1177	      }
  1178	
  1179	      // Validate goal type matches actual calorie balance before approval
  1180	      const dailyTargets = plan.daily_targets as Record<string, unknown> | null;
  1181	      const macroPayload = dailyTargets?.macro_payload as Record<string, unknown> | undefined;
  1182	      const planBundle = dailyTargets?.plan_bundle as Record<string, unknown> | undefined;
  1183	      if (macroPayload) {
  1184	        const energyBalance = macroPayload.energyBalance as string | undefined;
  1185	        const weeklyAvgKcal = macroPayload.weeklyAverageKcal as number | undefined;
  1186	
  1187	        // maintenanceEstimate may be in macro_payload (new plans) or computed
  1188	        // from plan_bundle.weeklyPlan.days TDEE averages (existing plans)
  1189	        let maintenanceEst = macroPayload.maintenanceEstimate as number | undefined;
  1190	        if (maintenanceEst == null && planBundle) {
  1191	          const wp = (planBundle as Record<string, unknown>).weeklyPlan as Record<string, unknown> | undefined;
  1192	          const days = wp?.days as Array<Record<string, unknown>> | undefined;
  1193	          if (days && days.length > 0) {
  1194	            const tdeeSum = days.reduce((sum, d) => {
  1195	              const tdee = d.tdee as Record<string, unknown> | undefined;
  1196	              return sum + ((tdee?.totalTdeeKcal as number) ?? 0);
  1197	            }, 0);
  1198	            maintenanceEst = tdeeSum / days.length;
  1199	          }
  1200	        }
  1201	
  1202	        if (
  1203	          energyBalance === "deficit" &&
  1204	          maintenanceEst != null &&
  1205	          weeklyAvgKcal != null &&
  1206	          Math.abs(weeklyAvgKcal - maintenanceEst) <= 50
  1207	        ) {
  1208	          throw new TRPCError({
  1209	            code: "BAD_REQUEST",
  1210	            message:
  1211	              "Impossibile approvare: il piano è etichettato come 'Deficit Calorico' ma le calorie corrispondono al TDEE di mantenimento. Correggi il tipo di obiettivo.",
  1212	          });
  1213	        }
  1214	      }
  1215	
  1216	      // Set start_date on activation (preserving any existing value) so the
  1217	      // feedback-reminder cadence (≈21 days after start_date) becomes live.
  1218	      const activationDate =
  1219	        (plan.start_date as string | null) ?? new Date().toISOString().split("T")[0]!;
  1220	      const { error } = await ctx.supabase
  1221	        .from("plan")
  1222	        .update({ status: "active", start_date: activationDate })
  1223	        .eq("id", input.id)
  1224	        .eq("partner_id", ctx.partnerId);
  1225	
  1226	      if (error) {
  1227	        console.error("[router/plan.approve]", error);
  1228	        throw new TRPCError({
  1229	          code: "INTERNAL_SERVER_ERROR",
  1230	          message: "Errore nell'aggiornamento. Riprova.",
  1231	        });
  1232	      }
  1233	
  1234	      // Fetch client name for the Inngest event
  1235	      const { data: client } = await ctx.supabase
  1236	        .from("client")
  1237	        .select("full_name")
  1238	        .eq("id", plan.client_id)
  1239	        .single();
  1240	
  1241	      // Dispatch plan/delivered event — wrapped so a dispatch failure never breaks the response
  1242	      try {
  1243	        await inngest.send({
  1244	          name: "plan/delivered",
  1245	          data: {
  1246	            planId: plan.id,
  1247	            clientId: plan.client_id,
  1248	            clientName: client?.full_name ?? "Cliente",
