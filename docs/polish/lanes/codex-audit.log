    10	--   • Clients can SELECT objects rooted under their own client_id.
    11	--
    12	-- After applying this migration the buckets are usable from the browser
    13	-- directly via the Supabase JS client (the user's JWT is checked against the
    14	-- RLS policy at upload/list/read time — no signed URLs required for partners).
    15	
    16	-- ── Bucket ────────────────────────────────────────────────────────────────────
    17	
    18	INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
    19	VALUES (
    20	  'client-media',
    21	  'client-media',
    22	  false,
    23	  10485760, -- 10 MiB
    24	  ARRAY[
    25	    'image/jpeg',
    26	    'image/png',
    27	    'image/webp',
    28	    'image/heic',
    29	    'image/heif'
    30	  ]
    31	)
    32	ON CONFLICT (id) DO UPDATE
    33	  SET file_size_limit = EXCLUDED.file_size_limit,
    34	      allowed_mime_types = EXCLUDED.allowed_mime_types;
    35	
    36	-- ── Policies ──────────────────────────────────────────────────────────────────
    37	
    38	-- Partner full access for their own partner_id subtree.
    39	DROP POLICY IF EXISTS "client_media_partner_all" ON storage.objects;
    40	CREATE POLICY "client_media_partner_all" ON storage.objects
    41	  FOR ALL TO authenticated
    42	  USING (
    43	    bucket_id = 'client-media'
    44	    AND (storage.foldername(name))[2] IN (
    45	      SELECT id::text FROM partner WHERE auth_user_id = auth.uid()
    46	    )
    47	  )
    48	  WITH CHECK (
    49	    bucket_id = 'client-media'
    50	    AND (storage.foldername(name))[2] IN (
    51	      SELECT id::text FROM partner WHERE auth_user_id = auth.uid()
    52	    )
    53	  );
    54	
    55	-- Client can read their own subtree (for portal photo viewing).
    56	DROP POLICY IF EXISTS "client_media_client_read" ON storage.objects;
    57	CREATE POLICY "client_media_client_read" ON storage.objects
    58	  FOR SELECT TO authenticated
    59	  USING (
    60	    bucket_id = 'client-media'
    61	    AND (storage.foldername(name))[3] IN (
    62	      SELECT id::text FROM client WHERE auth_user_id = auth.uid()
    63	    )
    64	  );
supabase/migrations/003_client_media_client_write.sql
     1	-- Roberto Scrigna Platform: allow clients to upload their own training screenshots
     2	--
     3	-- The 002 migration only granted clients READ access to the "client-media"
     4	-- bucket. To let the client log workouts from the portal with attached
     5	-- screenshots, we need an INSERT/UPDATE/DELETE policy scoped strictly to the
     6	-- training-screenshots/<partner_id>/<client_id>/... subtree. Client photos
     7	-- under client-photos/... remain partner-only.
     8	
     9	DROP POLICY IF EXISTS "client_media_client_training_write" ON storage.objects;
    10	CREATE POLICY "client_media_client_training_write" ON storage.objects
    11	  FOR ALL TO authenticated
    12	  USING (
    13	    bucket_id = 'client-media'
    14	    AND (storage.foldername(name))[1] = 'training-screenshots'
    15	    AND (storage.foldername(name))[3] IN (
    16	      SELECT id::text FROM client WHERE auth_user_id = auth.uid()
    17	    )
    18	  )
    19	  WITH CHECK (
    20	    bucket_id = 'client-media'
    21	    AND (storage.foldername(name))[1] = 'training-screenshots'
    22	    AND (storage.foldername(name))[3] IN (
    23	      SELECT id::text FROM client WHERE auth_user_id = auth.uid()
    24	    )
    25	  );
supabase/migrations/004_training_log_session_type_freeform.sql
     1	-- Roberto Scrigna Platform: relax training_log.session_type to free-form text
     2	--
     3	-- The base schema constrained session_type to a fixed 7-value enum
     4	-- ('strength', 'hypertrophy', 'cardio', 'hiit', 'flexibility', 'deload',
     5	-- 'other'). Roberto's feedback (May 2026 #10) flagged that this dropdown
     6	-- lacked the activity types he actually uses ("Arti marziali" etc).
     7	--
     8	-- The intake form and SCP categoriser have been unified on the v4.4 spec
     9	-- Appendix D modality taxonomy. This migration removes the CHECK constraint
    10	-- so the training-log form can write the same canonical Italian display
    11	-- names (e.g. "Pesi — Ipertrofia", "BJJ — Sparring", "Corsa — Costante").
    12	--
    13	-- Existing rows with legacy values ('strength', 'cardio', etc.) remain valid
    14	-- and continue to render — the UI falls back to displaying the value itself
    15	-- when no friendly label is found.
    16	
    17	DO $$
    18	DECLARE
    19	  cname TEXT;
    20	BEGIN
    21	  FOR cname IN
    22	    SELECT con.conname
    23	    FROM pg_constraint con
    24	    JOIN pg_class rel ON rel.oid = con.conrelid
    25	    WHERE rel.relname = 'training_log'
    26	      AND con.contype = 'c'
    27	      AND pg_get_constraintdef(con.oid) ILIKE '%session_type%'
    28	  LOOP
    29	    EXECUTE 'ALTER TABLE training_log DROP CONSTRAINT ' || quote_ident(cname);
    30	  END LOOP;
    31	END$$;
supabase/migrations/005_training_log_exercise_method_freeform.sql
     1	-- Roberto Scrigna Platform: relax training_log.exercise_method to free-form text
     2	--
     3	-- The base CHECK ('heart_rate' | 'met_value' | 'session_estimate' |
     4	-- 'default_estimate') doesn't include 'sport_correction_protocol', which is
     5	-- now used when OCR-extracted HR-zone data is fed into the SCP engine to
     6	-- derive an exercise-energy estimate (see training-log.ts create).
     7	--
     8	-- Pattern matches migration 004: drop the inline CHECK via a DO block so the
     9	-- column accepts the broader set of methods (and stays validated at the Zod
    10	-- layer in the tRPC schema).
    11	
    12	DO $$
    13	DECLARE
    14	  cname TEXT;
    15	BEGIN
    16	  FOR cname IN
    17	    SELECT con.conname
    18	    FROM pg_constraint con
    19	    JOIN pg_class rel ON rel.oid = con.conrelid
    20	    WHERE rel.relname = 'training_log'
    21	      AND con.contype = 'c'
    22	      AND pg_get_constraintdef(con.oid) ILIKE '%exercise_method%'
    23	  LOOP
    24	    EXECUTE 'ALTER TABLE training_log DROP CONSTRAINT ' || quote_ident(cname);
    25	  END LOOP;
    26	END$$;
supabase/migrations/006_plan_versioning_and_feedback.sql
     1	-- 006_plan_versioning_and_feedback.sql
     2	-- Lifecycle-spine increment 1: plan versioning + feedback-reminder cadence.
     3	--
     4	-- Idempotent (the dev runner re-applies every file): all changes use
     5	-- IF NOT EXISTS / DROP ... IF EXISTS so re-running is a no-op.
     6	
     7	-- ── Plan versioning columns ──────────────────────────────────────────────────
     8	-- A plan version chain: the root plan has parent_plan_id = NULL and
     9	-- version_number = 1; each new version points parent_plan_id at the ROOT and
    10	-- bumps version_number = max(chain) + 1. version_label carries Roberto's
    11	-- human convention (v1, v1.1, v1.2 for tweaks/regenerations; v2 for a brand-new
    12	-- plan). change_reason records why the version was cut. feedback_check_in_id
    13	-- links the version to the check-in (feedback questionnaire) that prompted it.
    14	ALTER TABLE plan ADD COLUMN IF NOT EXISTS parent_plan_id UUID REFERENCES plan(id);
    15	ALTER TABLE plan ADD COLUMN IF NOT EXISTS version_number INTEGER NOT NULL DEFAULT 1;
    16	ALTER TABLE plan ADD COLUMN IF NOT EXISTS version_label TEXT;
    17	ALTER TABLE plan ADD COLUMN IF NOT EXISTS change_reason TEXT;
    18	ALTER TABLE plan ADD COLUMN IF NOT EXISTS feedback_check_in_id UUID REFERENCES check_in(id);
    19	
    20	-- Fast lookup of a version chain by its root.
    21	CREATE INDEX IF NOT EXISTS idx_plan_parent_plan_id ON plan(parent_plan_id);
    22	
    23	-- ── Notification: allow the 'feedback_requested' trigger ─────────────────────
    24	-- The trigger CHECK is an inline constraint named notification_trigger_check.
    25	-- Drop and re-create it with the new value appended (idempotent across re-runs).
    26	ALTER TABLE notification DROP CONSTRAINT IF EXISTS notification_trigger_check;
    27	ALTER TABLE notification ADD CONSTRAINT notification_trigger_check CHECK (trigger IN (
    28	  'checkin_overdue', 'checkin_completed', 'weight_deviation', 'low_adherence',
    29	  'plan_expiring', 'invoice_overdue', 'invoice_paid',
    30	  'task_due_today', 'task_overdue', 'new_message',
    31	  'training_logged', 'milestone_reached',
    32	  'feedback_requested'
    33	));
supabase/migrations/007_placeholder_skipped.sql
