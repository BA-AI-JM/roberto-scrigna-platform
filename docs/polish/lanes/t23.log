+};
+
+const raphael: ClientSnapshot = {
+  sex: "male",
+  ageYears: 35,
+  weightKg: 90,
+  heightCm: 183,
+  bodyFatPctOverride: 18,
+  dailySteps: 7000,
+  occupationalLevel: "sedentary",
